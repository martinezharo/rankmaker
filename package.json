{
  "name": "rankmaker",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "wrangler": "npx --yes wrangler@latest",
    "db:create": "npx --yes wrangler@latest d1 create rankmaker",
    "db:migrate:local": "npx --yes wrangler@latest d1 execute rankmaker --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "npx --yes wrangler@latest d1 execute rankmaker --remote --file=migrations/0001_init.sql",
    "db:seed:remote": "npx --yes wrangler@latest d1 execute rankmaker --remote --file=migrations/0002_seed_from_kv.sql",
    "db:migrate3:local": "npx --yes wrangler@latest d1 execute rankmaker --local --file=migrations/0003_users_templates.sql",
    "db:migrate3:remote": "npx --yes wrangler@latest d1 execute rankmaker --remote --file=migrations/0003_users_templates.sql",
    "db:migrate4:local": "npx --yes wrangler@latest d1 execute rankmaker --local --file=migrations/0004_template_visibility.sql",
    "db:migrate4:remote": "npx --yes wrangler@latest d1 execute rankmaker --remote --file=migrations/0004_template_visibility.sql",
    "db:counts:remote": "npx --yes wrangler@latest d1 execute rankmaker --remote --command \"SELECT slug, COUNT(*) AS n FROM rankings GROUP BY slug ORDER BY n DESC LIMIT 15\""
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.17.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "wrangler": "^4.99.0"
  }
}