---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import CategorySection from "../components/CategorySection.astro";
import HeroDemo from "../components/HeroDemo.astro";
import FollowingSection from "../components/FollowingSection.astro";
import SEOContent from "../components/SEOContent.astro";
import { getCounts } from "../lib/counts";
import { getTemplateVotes } from "../lib/template-votes";
import { CATEGORIES as categories } from "../lib/categories";
import { getOfficialTemplates, listUserTemplates } from "../lib/templates";
import { defaultLocale, localizePath, useTranslations } from "../i18n";

const locale = Astro.locals.locale ?? defaultLocale;
const t = useTranslations(locale);

// Official (JSON) + user-created (D1) templates, treated identically.
// Fetch real ranking counts from D1 (SSR). Fall back to the JSON
// `times_ranked` / official-only list if the binding/query is unavailable
// so the page never breaks.
let counts: Record<string, number> = {};
let votes: Record<string, number> = {};
let haveCounts = false;
let userTemplates: ReturnType<typeof getOfficialTemplates> = [];
try {
	const db = (Astro.locals as any)?.runtime?.env?.DB as D1Database | undefined;
	if (db) {
		[counts, userTemplates, votes] = await Promise.all([
			getCounts(db),
			listUserTemplates(db),
			getTemplateVotes(db),
		]);
		haveCounts = true;
	}
} catch {
	// keep JSON ordering / official-only as a safe fallback
}

// Use real counts (pure) when available; otherwise the JSON number.
const templates = [...getOfficialTemplates(), ...userTemplates]
	.map((t) => ({
		...t,
		times_ranked: haveCounts ? (counts[t.slug] ?? 0) : t.times_ranked,
		votes: votes[t.slug] ?? 0,
	}))
	.sort((a, b) => b.times_ranked - a.times_ranked);

// Group by category — top 4 most ranked per category
const grouped: Record<string, any[]> = {};
for (const cat of categories) {
	grouped[cat.name] = templates
		.filter((t: any) => t.category === cat.name)
		.slice(0, 4);
}

// Short edge cache so the homepage isn't a D1 hit on every request.
Astro.response.headers.set("Cache-Control", "public, max-age=60");

// Site-level structured data: identifies RANKMAKER as an entity (Organization)
// and enables the sitelinks search box (WebSite + SearchAction). Emitted only
// on the home page — the canonical root of the site.
const SITE_URL = "https://rankmaker.net";
const siteJsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Organization",
			"@id": `${SITE_URL}/#organization`,
			name: "RANKMAKER",
			url: SITE_URL,
			logo: `${SITE_URL}/favicon.webp`,
		},
		{
			"@type": "WebSite",
			"@id": `${SITE_URL}/#website`,
			name: "RANKMAKER",
			url: SITE_URL,
			publisher: { "@id": `${SITE_URL}/#organization` },
			potentialAction: {
				"@type": "SearchAction",
				target: {
					"@type": "EntryPoint",
					urlTemplate: `${SITE_URL}/search?q={search_term_string}`,
				},
				"query-input": "required name=search_term_string",
			},
		},
	],
};
---

<Layout
	title={t("home.title")}
	description={t("home.metaDescription")}
	preloadImage="/hero/star-wars.webp"
>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(siteJsonLd)}
		is:inline
	/>
	<!-- Signed-in pre-paint guard: the page HTML is publicly cached (always the
	     signed-out variant), so hide the visitor hero before first paint when
	     the last-known auth cache says the user is signed in. The header's
	     /api/auth/me reconciliation corrects the class if the cache is stale. -->
	<script is:inline data-astro-rerun>
		(() => {
			try {
				document.documentElement.classList.toggle(
					"rm-authed",
					!!localStorage.getItem("rm:me"),
				);
			} catch {}
		})();
	</script>

	<!-- Hero Section (visitors only — hidden for signed-in users) -->
	<section
		id="home-hero"
		class="relative overflow-hidden px-4 sm:px-6 lg:px-8 pt-12 pb-16 sm:pt-16 sm:pb-20"
	>
		<!-- Glow Orbs -->
		<div
			class="absolute -top-24 left-1/4 -translate-x-1/2 w-[480px] h-[480px] bg-primary/10 blur-[140px] rounded-full pointer-events-none"
		>
		</div>
		<div
			class="absolute top-1/3 -right-32 w-[380px] h-[380px] bg-gold-start/5 blur-[120px] rounded-full pointer-events-none"
		>
		</div>

		<div
			class="relative mx-auto max-w-7xl grid items-center gap-12 lg:grid-cols-[1.1fr_1fr] lg:gap-16"
		>
			<!-- Copy -->
			<div class="text-center lg:text-left space-y-6">
				<span
					class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-primary/25 bg-primary/10 text-xs font-semibold text-primary-light tracking-wide"
				>
					<i class="fa-solid fa-bolt text-[10px]"></i>
					{t("home.heroEyebrow")}
				</span>

				<h1
					class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.08]"
				>
					<span class="text-text-primary">{t("home.heroHeadline1")}</span>
					<br />
					<span class="text-gradient-gold">{t("home.heroHeadline2")}</span>
				</h1>

				<p
					class="text-base sm:text-lg text-text-secondary font-light leading-relaxed max-w-xl mx-auto lg:mx-0"
				>
					{t("home.heroSubtitle")}
				</p>

				<div
					class="flex flex-col xs:flex-row items-center justify-center lg:justify-start gap-3 pt-1"
				>
					<a
						href={localizePath("/search", locale)}
						class="inline-flex w-full xs:w-auto items-center justify-center gap-2 px-6 py-3 rounded-xl bg-primary hover:bg-primary-light text-white text-sm font-semibold transition-all duration-200 glow-primary hover:scale-[1.02] active:scale-[0.98]"
					>
						<i class="fa-solid fa-magnifying-glass text-xs"></i>
						{t("home.exploreTemplates")}
					</a>
					<a
						href={localizePath("/create", locale)}
						class="inline-flex w-full xs:w-auto items-center justify-center gap-2 px-6 py-3 rounded-xl bg-surface-elevated border border-border hover:border-primary/40 text-text-primary text-sm font-semibold transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]"
					>
						<i class="fa-solid fa-plus text-xs text-primary/70"></i>
						{t("home.createTemplate")}
					</a>
				</div>
			</div>

			<!-- Live mini-ranking demo -->
			<HeroDemo />
		</div>
	</section>

	<!-- Category Sections -->
	<div id="categories" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-20">
		<FollowingSection />
		{
			categories.map((cat) => (
				<CategorySection
					category={cat.name}
					icon={cat.icon}
					templates={grouped[cat.name] || []}
				/>
			))
		}

		{/* Empty state if no templates at all */}
		{
			(!templates || templates.length === 0) && (
				<div class="text-center py-24 space-y-4">
					<div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto">
						<i class="fa-solid fa-inbox text-primary text-2xl" />
					</div>
					<h3 class="text-lg font-semibold text-text-primary">
						{t("home.emptyTitle")}
					</h3>
					<p class="text-sm text-text-muted max-w-md mx-auto">
						{t("home.emptyBody")}
					</p>
				</div>
			)
		}
	</div>

	<SEOContent />
</Layout>
