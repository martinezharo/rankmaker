---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import Avatar from "../components/Avatar.astro";
import SmartImage from "../components/SmartImage.astro";
import { getSessionUser } from "../lib/auth";
import { MAX_BIO_LEN } from "./api/me/profile";
import { categoryIcon } from "../lib/categories";
import { getCounts } from "../lib/counts";
import { getTemplateVotes } from "../lib/template-votes";
import { listTemplatesByUserId } from "../lib/templates";
import { defaultLocale, localizePath, useTranslations } from "../i18n";

const locale = Astro.locals.locale ?? defaultLocale;
// `tr` (not `t`): the templates .map((t) => …) below binds `t` to a template.
const tr = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);

const db = Astro.locals.runtime.env.DB;
const user = await getSessionUser(Astro.cookies, db);
if (!user) {
    return Astro.redirect(
        `/api/auth/login?next=${encodeURIComponent(localizePath("/me", locale))}`,
        302,
    );
}

// Bio isn't part of the session payload; fetch it for the owner editor.
const bioRow = await db
    .prepare("SELECT bio FROM users WHERE id = ?")
    .bind(user.id)
    .first<{ bio: string | null }>();
const bio = bioRow?.bio ?? "";

// Owner view: include private/unlisted templates. Counts are merged here
// server-side because the public /api/counts (used by the client counts
// script) excludes hidden slugs.
let templates = await listTemplatesByUserId(db, user.id, true);
try {
    const [counts, votes] = await Promise.all([
        getCounts(db, true),
        getTemplateVotes(db, true),
    ]);
    templates = templates.map((t) => ({
        ...t,
        times_ranked: counts[t.slug] ?? 0,
        votes: votes[t.slug] ?? 0,
    }));
} catch {
    // keep zeros
}

const resolveImg = (path: string | null) => {
    if (!path) return null;
    if (path.startsWith("http")) return path;
    if (path.startsWith("public/")) return path.replace("public/", "/");
    return path;
};

Astro.response.headers.set("Cache-Control", "no-store");
---

<Layout title={tr("me.title")}>
    <section class="mx-auto max-w-4xl px-4 sm:px-6 py-10 pb-20">
        <!-- Profile header -->
        <div
            class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-5 mb-10"
        >
            <Avatar avatar={user.avatar} size="xl" verified={user.isVerified} />
            <div class="flex-1">
                <h1
                    class="text-2xl sm:text-3xl font-bold tracking-tight text-text-primary"
                >
                    @{user.username}
                </h1>
                <a
                    href={L(`/u/${encodeURIComponent(user.username)}`)}
                    class="inline-flex items-center gap-1.5 text-sm text-text-secondary hover:text-primary transition-colors mt-1"
                >
                    <i class="fa-solid fa-arrow-up-right-from-square text-xs"
                    ></i>
                    {tr("me.viewPublicProfile")}
                </a>
            </div>
            <a
                href={L("/create")}
                class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl text-sm font-bold text-[#1a1205] bg-gradient-to-r from-gold-start to-gold-end hover:opacity-90 transition-opacity"
            >
                <i class="fa-solid fa-plus text-xs"></i>
                {tr("me.createTemplate")}
            </a>
        </div>

        <!-- Bio -->
        <div
            id="bio-card"
            class="mb-10 rounded-2xl bg-surface-elevated border border-border p-5 sm:p-6"
            data-bio={bio}
            data-max={MAX_BIO_LEN}
        >
            <div class="flex items-center justify-between gap-3 mb-3">
                <h2
                    class="text-sm font-bold text-text-primary uppercase tracking-wider flex items-center gap-2"
                >
                    <i class="fa-solid fa-quote-left text-xs text-primary/70"></i>
                    {tr("me.bioHeading")}
                </h2>
                <button
                    type="button"
                    id="bio-edit-btn"
                    class="inline-flex items-center gap-1.5 text-xs font-semibold text-text-secondary hover:text-primary transition-colors"
                >
                    <i class="fa-solid fa-pen text-[10px]"></i>
                    {tr("me.bioEdit")}
                </button>
            </div>

            <!-- Display mode -->
            <p
                id="bio-display"
                class="text-sm whitespace-pre-wrap break-words"
                class:list={[bio ? "text-text-secondary" : "text-text-muted italic"]}
            >
                {bio || tr("me.bioEmpty")}
            </p>

            <!-- Edit mode -->
            <div id="bio-editor" class="hidden">
                <textarea
                    id="bio-input"
                    maxlength={MAX_BIO_LEN}
                    rows="3"
                    placeholder={tr("me.bioPlaceholder")}
                    class="w-full px-4 py-3 rounded-xl bg-surface border border-border text-sm text-text-primary placeholder:text-text-muted/50 focus:outline-none focus:border-primary/60 focus:ring-1 focus:ring-primary/30 transition-all resize-none field-sizing-content"
                    >{bio}</textarea
                >
                <div class="flex items-center justify-between gap-3 mt-3">
                    <span
                        id="bio-count"
                        class="text-xs text-text-muted tabular-nums"></span>
                    <div class="flex items-center gap-2">
                        <button
                            type="button"
                            id="bio-cancel"
                            class="px-4 py-2 rounded-xl text-sm font-medium text-text-secondary border border-border hover:border-border-hover transition-all"
                        >
                            {tr("common.cancel")}
                        </button>
                        <button
                            type="button"
                            id="bio-save"
                            class="px-4 py-2 rounded-xl text-sm font-bold text-[#1a1205] bg-gradient-to-r from-gold-start to-gold-end hover:opacity-90 transition-opacity disabled:opacity-50"
                        >
                            {tr("common.save")}
                        </button>
                    </div>
                </div>
                <p id="bio-error" class="text-xs text-red-400 mt-2 min-h-4"></p>
            </div>
        </div>

        <!-- Templates -->
        <div class="flex items-center gap-3 mb-5">
            <h2 class="text-lg font-bold text-text-primary tracking-tight">
                {tr("me.heading")}
            </h2>
            <div class="flex-1 h-px bg-border/50"></div>
            <span class="text-xs text-text-muted font-medium">
                {templates.length}{" "}
                {templates.length === 1
                    ? tr("me.templateSingular")
                    : tr("me.templatePlural")}
            </span>
        </div>

        {
            templates.length === 0 ? (
                <div class="rounded-2xl border border-dashed border-border p-10 text-center space-y-3">
                    <i class="fa-solid fa-layer-group text-2xl text-text-muted" />
                    <p class="text-sm text-text-secondary">
                        {tr("me.emptyBody")}
                    </p>
                    <a
                        href={L("/create")}
                        class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary-light transition-colors"
                    >
                        {tr("me.createFirst")}
                        <i class="fa-solid fa-arrow-right text-xs" />
                    </a>
                </div>
            ) : (
                <div class="space-y-3">
                    {templates.map((t) => (
                        <div
                            class="my-template-row flex items-center gap-4 p-3 rounded-xl bg-surface-elevated border border-border"
                            data-template-id={t.id}
                        >
                            <a
                                href={L(`/template/${t.slug}`)}
                                class="w-20 h-15 sm:w-24 sm:h-18 shrink-0 rounded-lg overflow-hidden bg-surface border border-border"
                            >
                                <SmartImage
                                    src={resolveImg(t.cover_image)}
                                    alt={t.title}
                                    text={t.title}
                                    className="w-full h-full object-cover"
                                />
                            </a>
                            <div class="flex-1 min-w-0">
                                <a
                                    href={L(`/template/${t.slug}`)}
                                    class="block font-semibold text-sm text-text-primary hover:text-white transition-colors truncate"
                                >
                                    {t.title}
                                </a>
                                <p class="text-xs text-text-muted mt-1 flex items-center gap-3">
                                    <span class="inline-flex items-center gap-1.5">
                                        <i
                                            class={`fa-solid ${categoryIcon(t.category)} text-[10px] text-primary/70`}
                                        />
                                        {tr(`categories.${t.category}`)}
                                    </span>
                                    <span
                                        class="inline-flex items-center gap-1.5"
                                        data-count-slug={
                                            t.visibility === "public"
                                                ? t.slug
                                                : undefined
                                        }
                                    >
                                        {tr("card.ranked", {
                                            n: t.times_ranked.toLocaleString(),
                                        })}
                                    </span>
                                    <span class="inline-flex items-center gap-1.5">
                                        <i
                                            class="fa-solid fa-arrow-up text-[10px] text-primary/70"
                                        />
                                        {tr("card.votes", {
                                            n: (t.votes ?? 0).toLocaleString(),
                                        })}
                                    </span>
                                    {t.visibility !== "public" && (
                                        <span class="inline-flex items-center gap-1.5 uppercase tracking-wider font-semibold text-text-muted">
                                            <i
                                                class={`fa-solid ${t.visibility === "private" ? "fa-lock" : "fa-link"} text-[10px]`}
                                            />
                                            {t.visibility === "private"
                                                ? tr("me.visibilityPrivate")
                                                : tr("me.visibilityUnlisted")}
                                        </span>
                                    )}
                                </p>
                            </div>
                            <div class="flex items-center gap-2 shrink-0">
                                <a
                                    href={L(`/edit/${t.slug}`)}
                                    class="w-9 h-9 rounded-lg flex items-center justify-center text-text-secondary hover:text-primary border border-border hover:border-primary/50 transition-all"
                                    aria-label={tr("me.editTemplateAria")}
                                >
                                    <i class="fa-solid fa-pen text-xs" />
                                </a>
                                <button
                                    type="button"
                                    class="delete-template-btn w-9 h-9 rounded-lg flex items-center justify-center text-text-secondary hover:text-red-400 border border-border hover:border-red-400/50 transition-all"
                                    data-id={t.id}
                                    data-title={t.title}
                                    aria-label={tr("me.deleteTemplateAria")}
                                >
                                    <i class="fa-solid fa-trash text-xs" />
                                </button>
                            </div>
                        </div>
                    ))}
                </div>
            )
        }

        <!-- Danger zone -->
        <div class="mt-16 rounded-2xl border border-red-500/25 p-5 sm:p-6">
            <h2
                class="text-sm font-bold text-red-400 uppercase tracking-wider flex items-center gap-2"
            >
                <i class="fa-solid fa-triangle-exclamation text-xs"></i>
                {tr("me.dangerZone")}
            </h2>
            <p class="text-sm text-text-secondary mt-3">
                {tr("me.dangerBody")}
            </p>
            <button
                type="button"
                id="delete-account-open"
                class="mt-4 inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-red-400 border border-red-500/40 hover:bg-red-500/10 transition-all"
            >
                <i class="fa-solid fa-user-xmark text-xs"></i>
                {tr("me.deleteMyAccount")}
            </button>
        </div>
    </section>

    <!-- Delete template modal -->
    <div
        id="delete-template-modal"
        class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4"
        role="dialog"
        aria-modal="true"
        aria-labelledby="delete-template-modal-title"
    >
        <div
            class="delete-template-backdrop absolute inset-0 bg-black/70 backdrop-blur-sm"
        >
        </div>
        <div
            class="relative w-full max-w-sm rounded-2xl bg-surface-elevated border border-border p-6 space-y-4"
        >
            <h3 id="delete-template-modal-title" class="text-lg font-bold text-text-primary">
                {tr("me.deleteTemplateTitle")}
            </h3>
            <p id="delete-template-body" class="text-sm text-text-secondary"></p>
            <div class="flex gap-3 pt-1">
                <button
                    type="button"
                    id="delete-template-cancel"
                    class="flex-1 px-4 py-2.5 rounded-xl text-sm font-medium text-text-secondary border border-border hover:border-border-hover transition-all"
                >
                    {tr("common.cancel")}
                </button>
                <button
                    type="button"
                    id="delete-template-confirm"
                    class="flex-1 px-4 py-2.5 rounded-xl text-sm font-bold text-white bg-red-500 hover:bg-red-600 transition-all disabled:opacity-50"
                >
                    {tr("common.delete")}
                </button>
            </div>
        </div>
    </div>

    <!-- Delete account modal -->
    <div
        id="delete-account-modal"
        class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4"
        data-username={user.username}
        role="dialog"
        aria-modal="true"
        aria-labelledby="delete-account-modal-title"
    >
        <div
            class="delete-account-backdrop absolute inset-0 bg-black/70 backdrop-blur-sm"
        >
        </div>
        <div
            class="relative w-full max-w-sm rounded-2xl bg-surface-elevated border border-red-500/30 p-6 space-y-4"
        >
            <h3 id="delete-account-modal-title" class="text-lg font-bold text-red-400">
                {tr("me.deleteAccountTitle")}
            </h3>
            <p
                class="text-sm text-text-secondary"
                set:html={tr("me.deleteAccountBody", {
                    username: user.username,
                })}
            />
            <input
                id="delete-account-input"
                type="text"
                autocomplete="off"
                spellcheck="false"
                placeholder={user.username}
                class="w-full px-4 py-3 rounded-xl bg-surface border border-border text-sm text-text-primary placeholder:text-text-muted/40 focus:outline-none focus:border-red-400/60 transition-all"
            />
            <p id="delete-account-error" class="text-xs text-red-400 min-h-4">
            </p>
            <div class="flex gap-3 pt-1">
                <button
                    type="button"
                    id="delete-account-cancel"
                    class="flex-1 px-4 py-2.5 rounded-xl text-sm font-medium text-text-secondary border border-border hover:border-border-hover transition-all"
                >
                    {tr("common.cancel")}
                </button>
                <button
                    type="button"
                    id="delete-account-confirm"
                    disabled
                    class="flex-1 px-4 py-2.5 rounded-xl text-sm font-bold text-white bg-red-500 hover:bg-red-600 transition-all disabled:opacity-40 disabled:cursor-not-allowed"
                >
                    {tr("me.deleteForever")}
                </button>
            </div>
        </div>
    </div>
</Layout>

<script>
    import { openModal, closeModal } from "../scripts/modal-a11y";
    import { clientT, getClientLocale } from "../i18n/client";
    import { localizePath } from "../i18n";

    document.addEventListener("astro:page-load", () => {
        const tplModal = document.getElementById("delete-template-modal");
        if (!tplModal || tplModal.dataset.bound) return;
        tplModal.dataset.bound = "1";

        const t = clientT();

        // ── Edit bio ─────────────────────────────────────────────────
        const bioCard = document.getElementById("bio-card");
        if (bioCard) {
            const maxLen = Number(bioCard.dataset.max) || 280;
            const display = document.getElementById("bio-display")!;
            const editor = document.getElementById("bio-editor")!;
            const editBtn = document.getElementById("bio-edit-btn")!;
            const input = document.getElementById(
                "bio-input",
            ) as HTMLTextAreaElement;
            const count = document.getElementById("bio-count")!;
            const saveBtn = document.getElementById(
                "bio-save",
            ) as HTMLButtonElement;
            const cancelBtn = document.getElementById("bio-cancel")!;
            const errorEl = document.getElementById("bio-error")!;

            const updateCount = () => {
                count.textContent = `${input.value.length} / ${maxLen}`;
            };

            const openEditor = () => {
                input.value = bioCard.dataset.bio || "";
                errorEl.textContent = "";
                updateCount();
                display.classList.add("hidden");
                editBtn.classList.add("hidden");
                editor.classList.remove("hidden");
                input.focus();
            };

            const closeEditor = () => {
                editor.classList.add("hidden");
                display.classList.remove("hidden");
                editBtn.classList.remove("hidden");
            };

            editBtn.addEventListener("click", openEditor);
            cancelBtn.addEventListener("click", closeEditor);
            input.addEventListener("input", updateCount);

            saveBtn.addEventListener("click", async () => {
                const value = input.value.trim();
                saveBtn.disabled = true;
                errorEl.textContent = "";
                try {
                    const res = await fetch("/api/me/profile", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ bio: value }),
                    });
                    const data = await res.json();
                    if (res.ok && data.ok) {
                        const saved = (data.bio as string | null) || "";
                        bioCard.dataset.bio = saved;
                        if (saved) {
                            display.textContent = saved;
                            display.className =
                                "text-sm whitespace-pre-wrap break-words text-text-secondary";
                        } else {
                            display.textContent = t("me.bioEmpty");
                            display.className =
                                "text-sm whitespace-pre-wrap break-words text-text-muted italic";
                        }
                        closeEditor();
                    } else {
                        errorEl.textContent =
                            data.error || t("common.genericError");
                    }
                } catch {
                    errorEl.textContent = t("common.networkError");
                }
                saveBtn.disabled = false;
            });
        }

        // ── Delete template ──────────────────────────────────────────
        const tplBody = document.getElementById("delete-template-body")!;
        const tplConfirm = document.getElementById(
            "delete-template-confirm",
        ) as HTMLButtonElement;
        let pendingId: string | null = null;

        document
            .querySelectorAll<HTMLButtonElement>(".delete-template-btn")
            .forEach((btn) => {
                btn.addEventListener("click", () => {
                    pendingId = btn.dataset.id || null;
                    tplBody.textContent = t("me.deleteTemplateBody", {
                        title: btn.dataset.title || "",
                    });
                    openModal(tplModal, {
                        focus: tplConfirm,
                        onClose: () => {
                            pendingId = null;
                        },
                    });
                });
            });

        const closeTplModal = () => closeModal(tplModal);
        document
            .getElementById("delete-template-cancel")!
            .addEventListener("click", closeTplModal);
        tplModal
            .querySelector(".delete-template-backdrop")!
            .addEventListener("click", closeTplModal);

        tplConfirm.addEventListener("click", async () => {
            if (!pendingId) return;
            tplConfirm.disabled = true;
            try {
                const res = await fetch(`/api/templates/${pendingId}`, {
                    method: "DELETE",
                });
                const data = await res.json();
                if (res.ok && data.ok) {
                    document
                        .querySelector(
                            `.my-template-row[data-template-id="${pendingId}"]`,
                        )
                        ?.remove();
                    closeTplModal();
                }
            } catch {
                /* keep the modal open so the user can retry */
            }
            tplConfirm.disabled = false;
        });

        // ── Delete account ───────────────────────────────────────────
        const accModal = document.getElementById("delete-account-modal")!;
        const username = accModal.dataset.username || "";
        const accInput = document.getElementById(
            "delete-account-input",
        ) as HTMLInputElement;
        const accConfirm = document.getElementById(
            "delete-account-confirm",
        ) as HTMLButtonElement;
        const accError = document.getElementById("delete-account-error")!;

        document
            .getElementById("delete-account-open")!
            .addEventListener("click", () => {
                accInput.value = "";
                accConfirm.disabled = true;
                accError.textContent = "";
                openModal(accModal, { focus: accInput });
            });

        const closeAccModal = () => closeModal(accModal);
        document
            .getElementById("delete-account-cancel")!
            .addEventListener("click", closeAccModal);
        accModal
            .querySelector(".delete-account-backdrop")!
            .addEventListener("click", closeAccModal);

        accInput.addEventListener("input", () => {
            accConfirm.disabled = accInput.value !== username;
        });

        accConfirm.addEventListener("click", async () => {
            accConfirm.disabled = true;
            accError.textContent = "";
            try {
                const res = await fetch("/api/auth/delete-account", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ confirmUsername: accInput.value }),
                });
                const data = await res.json();
                if (res.ok && data.ok) {
                    window.location.href = localizePath("/", getClientLocale());
                    return;
                }
                accError.textContent = data.error || t("common.genericError");
            } catch {
                accError.textContent = t("common.networkError");
            }
            accConfirm.disabled = accInput.value !== username;
        });
    });
</script>
