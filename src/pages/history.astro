---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import { getSessionUser } from "../lib/auth";

// Per-user, never cached. Logged-in users get their saved results from D1
// (cross-device); anonymous visitors get theirs from localStorage, rendered by
// the client script below. A logged-in user may also have local-only entries
// (e.g. ranked before logging in) — the client merges those in, de-duped.
const db = Astro.locals.runtime.env.DB;
const user = await getSessionUser(Astro.cookies, db);

type RankedItem = { id: number | string; name: string; image: string };
type HistoryRow = {
	slug: string;
	title: string;
	result: RankedItem[];
	cover: string;
	date: string;
};

let serverEntries: HistoryRow[] = [];
if (user) {
	try {
		const { results } = await db
			.prepare(
				`SELECT slug, title, cover, result, updated_at
				 FROM ranking_results WHERE user_id = ?
				 ORDER BY updated_at DESC`,
			)
			.bind(user.id)
			.all<{
				slug: string;
				title: string;
				cover: string | null;
				result: string;
				updated_at: string;
			}>();
		serverEntries = results.map((r) => ({
			slug: r.slug,
			title: r.title,
			date: r.updated_at,
			cover: r.cover ?? "",
			result: (() => {
				try {
					return JSON.parse(r.result) as RankedItem[];
				} catch {
					return [];
				}
			})(),
		}));
	} catch {
		// degrade to the client-rendered (localStorage) view
	}
}

const fmtDate = (d: string | number) => {
	const date = new Date(d);
	return isNaN(date.getTime())
		? ""
		: date.toLocaleDateString(undefined, {
				year: "numeric",
				month: "short",
				day: "numeric",
			});
};

// Position badge — mirrors the results page: medals + tinted pills for the top
// three, plain numbers after. Kept in sync with the client script below.
const posLabel = (i: number) =>
	i === 0 ? "🥇" : i === 1 ? "🥈" : i === 2 ? "🥉" : `${i + 1}`;
const posCls = (i: number) =>
	i === 0
		? "bg-amber-400/15 text-amber-300 text-lg"
		: i === 1
			? "bg-gray-300/15 text-gray-200 text-lg"
			: i === 2
				? "bg-orange-400/15 text-orange-300 text-lg"
				: "bg-border/60 text-text-muted text-sm font-black";

Astro.response.headers.set("Cache-Control", "no-store");
---

<Layout title="My ranking history — RANKMAKER">
	<section class="mx-auto max-w-3xl px-4 sm:px-6 py-10 pb-20">
		<div class="flex items-center gap-3 mb-2">
			<div
				class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0"
			>
				<i class="fa-solid fa-clock-rotate-left text-primary"></i>
			</div>
			<h1
				class="text-2xl sm:text-3xl font-bold tracking-tight text-text-primary"
			>
				My ranking history
			</h1>
		</div>
		<p class="text-sm text-text-secondary mb-8">
			{
				user
					? "The rankings you've completed. Tap a card to reveal the full ranking."
					: "Rankings you've completed on this device. Tap a card to reveal the full ranking. Log in to keep them across devices."
			}
		</p>

		<div id="history-list" class="space-y-3">
			{
				serverEntries.map((e) => {
					const thumb = e.cover || e.result[0]?.image || "";
					return (
						<div
							data-slug={e.slug}
							class="history-card group rounded-2xl bg-surface-elevated border border-border hover:border-primary/40 transition-all duration-300 overflow-hidden"
						>
							<button
								type="button"
								class="history-toggle w-full flex items-center gap-4 p-4 text-left"
								aria-expanded="false"
							>
								<div class="w-24 aspect-4/3 rounded-xl overflow-hidden bg-surface border border-border shrink-0">
									{thumb && (
										<img
											src={thumb}
											alt=""
											class="w-full h-full object-cover"
										/>
									)}
								</div>
								<div class="flex-1 min-w-0">
									<p class="font-semibold text-base text-text-primary truncate group-hover:text-white transition-colors">
										{e.title}
									</p>
									<div class="flex items-center gap-3 mt-1.5 text-xs text-text-muted">
										<span class="inline-flex items-center gap-1.5">
											<i class="fa-solid fa-list-ol text-[10px]" />
											{e.result.length} items
										</span>
										<span class="inline-flex items-center gap-1.5">
											<i class="fa-regular fa-clock text-[10px]" />
											{fmtDate(e.date)}
										</span>
									</div>
								</div>
								<span class="shrink-0 w-8 h-8 rounded-lg bg-surface border border-border flex items-center justify-center text-text-muted group-hover:text-text-primary group-hover:border-border-hover transition-colors">
									<i class="history-chevron fa-solid fa-chevron-down text-xs transition-transform duration-300" />
								</span>
							</button>

							<div class="history-details grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out">
								<div class="overflow-hidden">
									<div class="px-4 pb-4 pt-1">
										<div class="flex items-center gap-3 mb-3">
											<span class="text-xs font-semibold uppercase tracking-widest text-text-muted">
												Full ranking
											</span>
											<div class="flex-1 h-px bg-border/60" />
										</div>
										<ol class="space-y-1.5">
											{e.result.map((item, i) => (
												<li
													class:list={[
														"flex items-center gap-3 p-2 rounded-xl transition-colors",
														i === 0
															? "bg-amber-400/[0.06] border border-amber-400/15"
															: "hover:bg-surface-hover",
													]}
												>
													<span
														class:list={[
															"flex items-center justify-center w-9 h-9 rounded-lg shrink-0",
															posCls(i),
														]}
													>
														{posLabel(i)}
													</span>
													<div class="w-10 h-10 rounded-lg overflow-hidden bg-surface shrink-0 border border-border">
														{item.image && (
															<img
																src={item.image}
																alt=""
																class="w-full h-full object-cover"
															/>
														)}
													</div>
													<span class="text-sm font-medium text-text-primary truncate flex-1">
														{item.name}
													</span>
												</li>
											))}
										</ol>
										<div class="flex justify-end gap-2 mt-4">
											<a
												href={`/template/${e.slug}`}
												data-slug={e.slug}
												class="history-rank-again inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-surface border border-border hover:border-primary/40 text-sm font-medium text-text-secondary hover:text-text-primary transition-all"
											>
												<i class="fa-solid fa-rotate text-xs text-primary/70" />
												Rank again
											</a>
											<a
												href={`/template/${e.slug}`}
												data-slug={e.slug}
												data-title={e.title}
												data-cover={e.cover}
												data-result={JSON.stringify(e.result)}
												class="history-view-details group/details inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-gradient-to-r from-gold-start to-gold-end text-[#1a1205] text-sm font-bold hover:opacity-90 transition-all"
											>
												<i class="fa-solid fa-trophy text-xs transition-transform group-hover/details:-rotate-12" />
												View details
											</a>
										</div>
									</div>
								</div>
							</div>
						</div>
					);
				})
			}
		</div>

		<div
			id="history-empty"
			class:list={[
				"rounded-2xl border border-dashed border-border p-10 text-center space-y-3",
				serverEntries.length > 0 && "hidden",
			]}
		>
			<i class="fa-solid fa-clock-rotate-left text-2xl text-text-muted"></i>
			<p class="text-sm text-text-secondary">
				You haven't ranked anything yet.
			</p>
			<a
				href="/"
				class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary-light transition-colors"
			>
				Find something to rank
				<i class="fa-solid fa-arrow-right text-xs"></i>
			</a>
		</div>
	</section>
</Layout>

<script>
	// Merge in this device's localStorage history (covers anonymous visitors and
	// any local-only entries a logged-in user made before signing in). SSR-
	// rendered slugs win, so we skip duplicates. The markup here mirrors the
	// Astro template above so both kinds of card look and behave identically.
	import {
		getLocalHistory,
		setPendingResult,
		setForceFresh,
		type RankedItem,
	} from "../scripts/history";

	function escapeHtml(s: string): string {
		return s.replace(
			/[&<>"']/g,
			(c) =>
				({
					"&": "&amp;",
					"<": "&lt;",
					">": "&gt;",
					'"': "&quot;",
					"'": "&#39;",
				})[c]!,
		);
	}

	function fmtDate(ts: number): string {
		const d = new Date(ts);
		return isNaN(d.getTime())
			? ""
			: d.toLocaleDateString(undefined, {
					year: "numeric",
					month: "short",
					day: "numeric",
				});
	}

	const posLabel = (i: number) =>
		i === 0 ? "🥇" : i === 1 ? "🥈" : i === 2 ? "🥉" : `${i + 1}`;
	const posCls = (i: number) =>
		i === 0
			? "bg-amber-400/15 text-amber-300 text-lg"
			: i === 1
				? "bg-gray-300/15 text-gray-200 text-lg"
				: i === 2
					? "bg-orange-400/15 text-orange-300 text-lg"
					: "bg-border/60 text-text-muted text-sm font-black";

	function renderLocal() {
		const list = document.getElementById("history-list");
		const empty = document.getElementById("history-empty");
		if (!list) return;

		const seen = new Set(
			Array.from(list.querySelectorAll<HTMLElement>("[data-slug]")).map(
				(el) => el.dataset.slug,
			),
		);

		let entries: ReturnType<typeof getLocalHistory> = [];
		try {
			entries = getLocalHistory();
		} catch {
			entries = [];
		}

		for (const e of entries) {
			if (seen.has(e.slug)) continue;
			seen.add(e.slug);
			const thumb = e.cover || e.result[0]?.image || "";

			const rows = e.result
				.map(
					(item, i) => `
				<li class="flex items-center gap-3 p-2 rounded-xl transition-colors ${i === 0 ? "bg-amber-400/[0.06] border border-amber-400/15" : "hover:bg-surface-hover"}">
					<span class="flex items-center justify-center w-9 h-9 rounded-lg shrink-0 ${posCls(i)}">${posLabel(i)}</span>
					<div class="w-10 h-10 rounded-lg overflow-hidden bg-surface shrink-0 border border-border">
						${item.image ? `<img src="${escapeHtml(item.image)}" alt="" class="w-full h-full object-cover" />` : ""}
					</div>
					<span class="text-sm font-medium text-text-primary truncate flex-1">${escapeHtml(item.name)}</span>
				</li>`,
				)
				.join("");

			const card = document.createElement("div");
			card.dataset.slug = e.slug;
			card.className =
				"history-card group rounded-2xl bg-surface-elevated border border-border hover:border-primary/40 transition-all duration-300 overflow-hidden";
			card.innerHTML = `
				<button type="button" class="history-toggle w-full flex items-center gap-4 p-4 text-left" aria-expanded="false">
					<div class="w-24 aspect-4/3 rounded-xl overflow-hidden bg-surface border border-border shrink-0">
						${thumb ? `<img src="${escapeHtml(thumb)}" alt="" class="w-full h-full object-cover" />` : ""}
					</div>
					<div class="flex-1 min-w-0">
						<p class="font-semibold text-base text-text-primary truncate group-hover:text-white transition-colors">${escapeHtml(e.title)}</p>
						<div class="flex items-center gap-3 mt-1.5 text-xs text-text-muted">
							<span class="inline-flex items-center gap-1.5"><i class="fa-solid fa-list-ol text-[10px]"></i>${e.result.length} items</span>
							<span class="inline-flex items-center gap-1.5"><i class="fa-regular fa-clock text-[10px]"></i>${fmtDate(e.ts)}</span>
						</div>
					</div>
					<span class="shrink-0 w-8 h-8 rounded-lg bg-surface border border-border flex items-center justify-center text-text-muted group-hover:text-text-primary group-hover:border-border-hover transition-colors">
						<i class="history-chevron fa-solid fa-chevron-down text-xs transition-transform duration-300"></i>
					</span>
				</button>
				<div class="history-details grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out">
					<div class="overflow-hidden">
						<div class="px-4 pb-4 pt-1">
							<div class="flex items-center gap-3 mb-3">
								<span class="text-xs font-semibold uppercase tracking-widest text-text-muted">Full ranking</span>
								<div class="flex-1 h-px bg-border/60"></div>
							</div>
							<ol class="space-y-1.5">${rows}</ol>
							<div class="flex justify-end gap-2 mt-4">
								<a href="/template/${encodeURIComponent(e.slug)}" data-slug="${escapeHtml(e.slug)}" class="history-rank-again inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-surface border border-border hover:border-primary/40 text-sm font-medium text-text-secondary hover:text-text-primary transition-all"><i class="fa-solid fa-rotate text-xs text-primary/70"></i>Rank again</a>
								<a href="/template/${encodeURIComponent(e.slug)}" data-slug="${escapeHtml(e.slug)}" data-title="${escapeHtml(e.title)}" data-cover="${escapeHtml(e.cover || "")}" data-result="${escapeHtml(JSON.stringify(e.result))}" class="history-view-details group/details inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-gradient-to-r from-gold-start to-gold-end text-[#1a1205] text-sm font-bold hover:opacity-90 transition-all"><i class="fa-solid fa-trophy text-xs transition-transform group-hover/details:-rotate-12"></i>View details</a>
							</div>
						</div>
					</div>
				</div>`;
			list.appendChild(card);
		}

		if (empty) empty.classList.toggle("hidden", list.children.length > 0);
	}

	// One delegated handler covers both SSR- and client-rendered cards. The
	// expand uses a grid-rows 0fr→1fr trick so height animates without JS
	// measurement (and collapses to instant under prefers-reduced-motion).
	function onClick(ev: MouseEvent) {
		// "View details" → hand the result to the template page (via
		// sessionStorage) so it opens straight on the results view. Then let the
		// link navigate normally.
		const viewBtn = (ev.target as HTMLElement)?.closest<HTMLElement>(
			".history-view-details",
		);
		if (viewBtn) {
			const slug = viewBtn.dataset.slug || "";
			try {
				setPendingResult({
					slug,
					title: viewBtn.dataset.title || slug,
					result: JSON.parse(
						viewBtn.dataset.result || "[]",
					) as RankedItem[],
					ts: Date.now(),
					cover: viewBtn.dataset.cover || undefined,
				});
			} catch {
				/* malformed data — fall back to the template page's own lookup */
			}
			return;
		}

		// "Rank again" → tell the template page to skip the saved-results view and
		// show the normal detail/START flow for a fresh ranking.
		const again = (ev.target as HTMLElement)?.closest<HTMLElement>(
			".history-rank-again",
		);
		if (again) {
			setForceFresh(again.dataset.slug || "");
			return;
		}

		const toggle = (ev.target as HTMLElement)?.closest<HTMLElement>(
			".history-toggle",
		);
		if (!toggle) return;
		const card = toggle.closest<HTMLElement>(".history-card");
		const details = card?.querySelector<HTMLElement>(".history-details");
		const chevron = toggle.querySelector<HTMLElement>(".history-chevron");
		if (!details) return;
		const open = !details.classList.contains("grid-rows-[1fr]");
		details.classList.toggle("grid-rows-[1fr]", open);
		details.classList.toggle("grid-rows-[0fr]", !open);
		toggle.setAttribute("aria-expanded", String(open));
		chevron?.classList.toggle("rotate-180", open);
	}

	document.addEventListener("astro:page-load", () => {
		renderLocal();
		const list = document.getElementById("history-list");
		// Re-bind per page-load; remove first so we never stack duplicate handlers.
		list?.removeEventListener("click", onClick);
		list?.addEventListener("click", onClick);
	});
</script>
