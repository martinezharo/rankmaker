---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import TemplateCard from "../components/TemplateCard.astro";
import {
    CATEGORIES as categories,
    CATEGORY_ICONS as categoryIconMap,
} from "../lib/categories";
import {
    getOfficialTemplates,
    listUserTemplates,
    type Template,
} from "../lib/templates";
import { getTemplateVotes } from "../lib/template-votes";
import { avatarHtml } from "../lib/avatars";
import { defaultLocale, localizePath, useTranslations } from "../i18n";

const locale = Astro.locals.locale ?? defaultLocale;
// Named `tr` (not `t`) because several .map((t) => …) callbacks below bind `t`
// to a template item — the translation fn must not be shadowed.
const tr = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);

// Official (JSON) + user-created (D1) templates. Fall back to official-only
// if the D1 binding/query is unavailable so the page never breaks.
let userTemplates: Template[] = [];
let votes: Record<string, number> = {};
try {
    const db = (Astro.locals as any)?.runtime?.env?.DB as D1Database | undefined;
    if (db) {
        [userTemplates, votes] = await Promise.all([
            listUserTemplates(db),
            getTemplateVotes(db),
        ]);
    }
} catch {
    // official-only fallback
}

// Sort by most ranked (live counts re-sort client-side via rm:counts)
const templates = [...getOfficialTemplates(), ...userTemplates]
    .map((t) => ({ ...t, votes: votes[t.slug] ?? 0 }))
    .sort((a, b) => b.times_ranked - a.times_ranked);

const escapeHtml = (s: string) =>
    s.replace(
        /[&<>"']/g,
        (c) =>
            ((
                {
                    "&": "&amp;",
                    "<": "&lt;",
                    ">": "&gt;",
                    '"': "&quot;",
                    "'": "&#39;",
                } as Record<string, string>
            )[c]!),
    );

// Lightweight version for client — option names for search, creator line as
// prebuilt HTML so the client card markup matches TemplateCard.astro.
const templatesForClient = templates.map((t) => ({
    slug: t.slug,
    title: t.title,
    description: t.description,
    category: t.category,
    cover_image: t.cover_image,
    times_ranked: t.times_ranked,
    votes: t.votes ?? 0,
    optionNames: t.optionNames ?? "",
    creatorHtml: `<span class="creator-link inline-flex items-center gap-1.5 cursor-pointer" data-profile-href="${L(`/u/${encodeURIComponent(t.creator.username)}`)}" title="${escapeHtml(tr("card.viewProfile", { username: t.creator.username }))}">${avatarHtml(t.creator.avatar, 20, t.creator.isVerified)}<span class="text-xs text-text-muted font-medium hover:text-text-primary transition-colors">@${escapeHtml(t.creator.username)}</span></span>`,
}));

Astro.response.headers.set("Cache-Control", "public, max-age=60");
---

<Layout
    title={tr("search.title")}
    description={tr("search.metaDescription")}
    noindex={true}
>
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10 pb-20">
        <!-- Page Header -->
        <div class="text-center mb-10">
            <h1
                class="text-3xl sm:text-4xl font-bold tracking-tight text-text-primary"
            >
                {tr("search.heading")}
            </h1>
            <p class="text-sm text-text-secondary mt-2 max-w-lg mx-auto">
                {tr("search.subtitle")}
            </p>
        </div>

        <!-- Search & Filter Bar -->
        <div class="flex flex-col sm:flex-row gap-3 mb-8 max-w-3xl mx-auto">
            <!-- Search Input -->
            <div class="relative flex-1">
                <i
                    class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-text-muted text-sm pointer-events-none"
                ></i>
                <input
                    id="search-input"
                    type="text"
                    placeholder={tr("search.placeholder")}
                    autocomplete="off"
                    class="w-full pl-11 pr-10 py-3 rounded-xl bg-surface-elevated border border-border text-sm text-text-primary placeholder:text-text-muted/60 focus:outline-none focus:border-primary/60 focus:ring-1 focus:ring-primary/30 transition-all"
                />
                <button
                    id="search-clear"
                    class="absolute right-3 top-1/2 -translate-y-1/2 w-6 h-6 rounded-md items-center justify-center text-text-muted hover:text-text-primary hover:bg-white/5 transition-colors hidden"
                    aria-label={tr("search.clear")}
                >
                    <i class="fa-solid fa-xmark text-xs"></i>
                </button>
            </div>

            <!-- Category Dropdown -->
            <div class="relative sm:w-52">
                <select
                    id="category-select"
                    class="w-full appearance-none px-4 py-3 pr-10 rounded-xl bg-surface-elevated border border-border text-sm text-text-primary focus:outline-none focus:border-primary/60 focus:ring-1 focus:ring-primary/30 transition-all cursor-pointer"
                >
                    <option value="">{tr("search.allCategories")}</option>
                    {
                        categories.map((cat) => (
                            <option value={cat.name}>
                                {tr(`categories.${cat.name}`)}
                            </option>
                        ))
                    }
                </select>
                <i
                    class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-text-muted text-xs pointer-events-none"
                ></i>
            </div>
        </div>

        <!-- Results Info -->
        <div
            class="flex items-center justify-between mb-5 max-w-3xl mx-auto sm:max-w-none"
        >
            <p id="results-count" class="text-xs text-text-muted font-medium">
                {tr("search.showing", { n: templates.length })}
            </p>
            <button
                id="reset-filters"
                class="text-xs text-primary/70 hover:text-primary font-medium transition-colors hidden"
            >
                <i class="fa-solid fa-rotate-left mr-1 text-[10px]"></i>{
                    tr("search.resetFilters")
                }
            </button>
        </div>

        <!-- Template Grid -->
        <!--
            Rendered server-side so the grid has its full height at first paint.
            Leaving it empty for JS to fill caused a layout shift: the footer
            jumped down once the cards were injected (CLS reported by Cloudflare).
            The client script re-renders this on filter/search/sort.
        -->
        <div
            id="template-grid"
            class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"
        >
            {templates.map((t) => <TemplateCard template={t} />)}
        </div>

        <!-- Empty State -->
        <div id="empty-state" class="hidden text-center py-20 space-y-4">
            <div
                class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto"
            >
                <i class="fa-solid fa-magnifying-glass text-primary text-2xl"
                ></i>
            </div>
            <h3 class="text-lg font-semibold text-text-primary">
                {tr("search.emptyTitle")}
            </h3>
            <p class="text-sm text-text-muted max-w-md mx-auto">
                {tr("search.emptyBody")}
            </p>
        </div>
    </section>

    <!-- Template Data -->
    <script is:inline define:vars={{ templatesForClient, categoryIconMap }}>
        window.__SEARCH_TEMPLATES__ = templatesForClient;
        window.__CATEGORY_ICON_MAP__ = categoryIconMap;
    </script>

    <!-- Search Engine -->
    <script>
        import { clientT, getClientLocale } from "../i18n/client";
        import { localizePath } from "../i18n";
        import { initSaveButtons } from "../scripts/save-template";

        document.addEventListener("astro:page-load", () => {
            const templates: any[] = (window as any).__SEARCH_TEMPLATES__;
            const iconMap: Record<string, string> =
                (window as any).__CATEGORY_ICON_MAP__ || {};
            if (!templates) return;

            // `tt` (not `t`): renderCard(t) below binds `t` to a template item.
            const tt = clientT();
            const locale = getClientLocale();
            const L = (p: string) => localizePath(p, locale);

            const searchInput = document.getElementById(
                "search-input",
            ) as HTMLInputElement | null;
            const categorySelect = document.getElementById(
                "category-select",
            ) as HTMLSelectElement | null;
            const grid = document.getElementById("template-grid");
            const emptyState = document.getElementById("empty-state");
            const resultsCount = document.getElementById("results-count");
            const clearBtn = document.getElementById("search-clear");
            const resetBtn = document.getElementById("reset-filters");

            if (
                !searchInput ||
                !categorySelect ||
                !grid ||
                !emptyState ||
                !resultsCount
            )
                return;

            // Helper: resolve image path
            function resolveImg(path: string | null): string | null {
                if (!path) return null;
                if (path.startsWith("http")) return path;
                if (path.startsWith("public/"))
                    return path.replace("public/", "/");
                return path;
            }

            // Escape user-provided text/attributes (titles, descriptions and
            // image URLs can come from user-created templates).
            function esc(s: string): string {
                return String(s).replace(
                    /[&<>"']/g,
                    (c) =>
                        (
                            {
                                "&": "&amp;",
                                "<": "&lt;",
                                ">": "&gt;",
                                '"': "&quot;",
                                "'": "&#39;",
                            } as Record<string, string>
                        )[c]!,
                );
            }

            // Render a single template card (mirrors TemplateCard.astro)
            function renderCard(t: any): string {
                const icon = t.category
                    ? iconMap[t.category] || "fa-ellipsis-h"
                    : "fa-ellipsis-h";
                const coverSrc = resolveImg(t.cover_image);
                const imgHtml = coverSrc
                    ? `<img src="${esc(coverSrc)}" alt="${esc(t.title)}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />`
                    : `<div class="w-full h-full bg-gradient-to-br from-primary/20 to-primary/5 flex items-center justify-center">
                        <span class="text-text-muted text-xs text-center px-3 font-medium leading-tight">${esc(t.title)}</span>
                       </div>`;

                const descHtml = t.description
                    ? `<p class="text-xs text-text-muted leading-relaxed line-clamp-2">${esc(t.description)}</p>`
                    : "";

                return `<a href="${L(`/template/${esc(t.slug)}`)}" class="group flex flex-col h-full rounded-2xl bg-surface-elevated border border-border hover:border-primary/40 transition-all duration-300 overflow-hidden hover:shadow-[0_0_30px_rgba(132,0,255,0.12)]">
                    <div class="relative aspect-4/3 overflow-hidden bg-surface">
                        ${imgHtml}
                        ${t.category ? `<span class="absolute top-3 left-3 flex items-center justify-center w-8 h-8 rounded-lg bg-black/60 backdrop-blur-sm text-white transition-colors group-hover:bg-primary/80"><i class="fa-solid ${icon} text-[12px]"></i></span>` : ""}
                        <button class="save-btn absolute top-3 right-3 w-8 h-8 rounded-lg bg-black/60 backdrop-blur-sm flex items-center justify-center text-white/70 hover:text-white hover:bg-primary/80 transition-all opacity-0 group-hover:opacity-100" aria-label="${esc(tt("card.saveAria"))}" data-save-aria="${esc(tt("card.saveAria"))}" data-unsave-aria="${esc(tt("card.unsaveAria"))}" data-slug="${esc(t.slug)}"><i class="fa-regular fa-bookmark text-xs"></i></button>
                    </div>
                    <div class="flex-1 p-4 space-y-2">
                        <h3 class="font-semibold text-sm text-text-primary leading-tight line-clamp-1 group-hover:text-white transition-colors">${esc(t.title)}</h3>
                        ${t.creatorHtml || ""}
                        ${descHtml}
                        <div class="flex items-center gap-3 pt-1">
                            <span class="inline-flex items-center gap-1.5">
                                <i class="fa-solid fa-fire text-[10px] text-primary/70"></i>
                                <span class="text-xs text-text-muted font-medium" data-count-slug="${esc(t.slug)}">${esc(tt("card.ranked", { n: t.times_ranked.toLocaleString() }))}</span>
                            </span>
                            <span class="inline-flex items-center gap-1.5">
                                <i class="fa-solid fa-arrow-up text-[10px] text-primary/70"></i>
                                <span class="text-xs text-text-muted font-medium" data-vote-slug="${esc(t.slug)}">${esc(tt("card.votes", { n: (t.votes ?? 0).toLocaleString() }))}</span>
                            </span>
                        </div>
                    </div>
                </a>`;
            }

            // Filter & render
            function filterAndRender() {
                const query = (searchInput!.value || "").trim().toLowerCase();
                const category = categorySelect!.value;

                const filtered = templates.filter((t) => {
                    // Category filter
                    if (category && t.category !== category) return false;

                    // Search filter — match title, description, or option names
                    if (query) {
                        const haystack = [
                            t.title || "",
                            t.description || "",
                            t.optionNames || "",
                        ]
                            .join(" ")
                            .toLowerCase();
                        // All words in query must match
                        const words = query.split(/\s+/).filter(Boolean);
                        for (const w of words) {
                            if (!haystack.includes(w)) return false;
                        }
                    }

                    return true;
                });

                // Sort by real ranking counts (from D1) when available,
                // falling back to the build-time order otherwise.
                const counts = (window as any).__rmCounts as
                    | Record<string, number>
                    | undefined;
                if (counts) {
                    filtered.sort(
                        (a, b) =>
                            (counts[b.slug] || 0) - (counts[a.slug] || 0),
                    );
                }

                // Render
                grid!.innerHTML = filtered.map(renderCard).join("");

                // Patch "N ranked" with real counts (results are rendered client-side
                // after the global counts fetch, so apply them to the new cards).
                (window as any).__applyRankCounts?.(grid!);

                // Bind/mark save buttons on the freshly-rendered cards.
                initSaveButtons();

                // Update count
                resultsCount!.textContent =
                    filtered.length === 1
                        ? tt("search.showingOne", { n: filtered.length })
                        : tt("search.showing", { n: filtered.length });

                // Empty state
                if (filtered.length === 0) {
                    emptyState!.classList.remove("hidden");
                    grid!.classList.add("hidden");
                } else {
                    emptyState!.classList.add("hidden");
                    grid!.classList.remove("hidden");
                }

                // Clear button
                if (clearBtn) {
                    if (query) {
                        clearBtn.classList.remove("hidden");
                        clearBtn.classList.add("flex");
                    } else {
                        clearBtn.classList.add("hidden");
                        clearBtn.classList.remove("flex");
                    }
                }

                // Reset button
                if (resetBtn) {
                    if (query || category) resetBtn.classList.remove("hidden");
                    else resetBtn.classList.add("hidden");
                }
            }

            // Debounce helper
            let debounceTimer: ReturnType<typeof setTimeout>;
            function debounced(fn: () => void, ms: number) {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(fn, ms);
            }

            // Event listeners
            searchInput.addEventListener("input", () => {
                debounced(filterAndRender, 150);
            });
            categorySelect.addEventListener("change", filterAndRender);

            if (clearBtn) {
                clearBtn.addEventListener("click", () => {
                    searchInput.value = "";
                    filterAndRender();
                    searchInput.focus();
                });
            }

            if (resetBtn) {
                resetBtn.addEventListener("click", () => {
                    searchInput.value = "";
                    categorySelect.value = "";
                    filterAndRender();
                });
            }

            // Check URL params for initial search/category
            const params = new URLSearchParams(window.location.search);
            const q = params.get("q");
            const cat = params.get("category");
            if (q) searchInput.value = q;
            if (cat) categorySelect.value = cat;

            // Initial render — only when the URL carries a filter. Without one,
            // the server-rendered grid already shows the full, correctly-ordered
            // list, so rebuilding it client-side here is wasted work (and would
            // needlessly replace the SSR DOM on every load). Listeners below and
            // the rm:counts handler re-render on demand.
            if (q || cat) filterAndRender();

            // Re-render once real counts arrive so results sort by them.
            // `document` survives View Transitions, so register exactly once —
            // re-binding per astro:page-load would stack listeners holding
            // stale closures over swapped-out DOM. Dispatch the existing event
            // to a freshly-bound renderer instead.
            const w = window as any;
            if (w.__rmSearchCounts)
                document.removeEventListener("rm:counts", w.__rmSearchCounts);
            w.__rmSearchCounts = filterAndRender;
            document.addEventListener("rm:counts", filterAndRender);
        });
    </script>
</Layout>
