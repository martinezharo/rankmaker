---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import { defaultLocale, useTranslations } from "../i18n";

const locale = Astro.locals.locale ?? defaultLocale;
const t = useTranslations(locale);

Astro.response.headers.set("Cache-Control", "public, max-age=3600");
---

<Layout
    title={t("legal.privacyPolicy.title")}
    description={t("legal.privacyPolicy.metaDescription")}
>
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
        <h1 class="text-3xl font-bold text-text-primary mb-8">
            {t("legal.privacyPolicy.heading")}
        </h1>

        <div
            class="space-y-6 text-text-secondary leading-relaxed"
            set:html={t("legal.privacyPolicy.body")}
        />
    </div>
</Layout>
