---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import { defaultLocale, useTranslations } from "../i18n";

const locale = Astro.locals.locale ?? defaultLocale;
const t = useTranslations(locale);

// Static content — cache at the edge so it isn't an SSR hit every time.
Astro.response.headers.set("Cache-Control", "public, max-age=3600");
---

<Layout title={t("about.title")} description={t("about.metaDescription")}>
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
        <h1 class="text-4xl font-bold text-text-primary mb-8 tracking-tight">
            {t("about.heading")}
        </h1>

        <div class="space-y-6 text-text-secondary leading-relaxed text-lg">
            <p set:html={t("about.p1")} />
            <p set:html={t("about.p2")} />
            <p set:html={t("about.p3")} />
            <p set:html={t("about.p4")} />
            <p set:html={t("about.p5")} />
            <p set:html={t("about.p6")} />

            <h2 class="text-2xl font-bold text-text-primary pt-8 pb-4">
                {t("about.whyHeading")}
            </h2>

            <p set:html={t("about.p7")} />
            <p set:html={t("about.p8")} />

            <p class="text-xl font-medium text-primary pt-2">
                {t("about.finalLine")}
            </p>
        </div>
    </div>
</Layout>
