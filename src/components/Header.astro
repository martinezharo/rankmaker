---
// Header.astro — Fixed header with logo, nav links, Create Ranking CTA,
// auth slot (client-rendered: pages are publicly cached) and mobile menu.
---

<header
    transition:persist
    transition:name="site-header"
    transition:animate="none"
    class="fixed top-0 left-0 right-0 z-50 border-b border-border/50 bg-surface/80 backdrop-blur-xl"
>
    <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
            <!-- Logo (1200x120 source: must be allowed to shrink on mobile) -->
            <a href="/" class="flex items-center gap-2 min-w-0 mr-3">
                <img
                    src="/RANKMAKER-logo.webp"
                    alt="RANKMAKER"
                    class="h-8 w-auto max-w-full object-contain object-left"
                />
            </a>

            <!-- Desktop Nav -->
            <div class="hidden md:flex items-center gap-1">
                <a
                    href="/"
                    class="flex items-center px-4 py-2 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors rounded-lg hover:bg-white/5"
                >
                    <i class="fa-solid fa-house text-xs mr-2"></i>
                    Home
                </a>
                <a
                    href="/search"
                    class="flex items-center px-4 py-2 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors rounded-lg hover:bg-white/5"
                >
                    <i class="fa-solid fa-magnifying-glass text-xs mr-2"></i>
                    Find Templates
                </a>

                <a
                    href="/create"
                    data-astro-reload
                    class="ml-2 inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-bold text-[#1a1205] bg-gradient-to-r from-gold-start to-gold-end hover:opacity-90 transition-opacity"
                >
                    <i class="fa-solid fa-plus text-xs"></i>
                    Create Ranking
                </a>

                <!-- Auth slot (desktop) — swapped by client JS when logged in.
                     data-astro-reload: the OAuth redirect to GitHub must be a
                     full browser navigation (the ClientRouter fetch would be
                     blocked by CORS). -->
                <div class="auth-slot ml-1 relative" data-auth-slot="desktop">
                    <a
                        href="/api/auth/login"
                        data-astro-reload
                        class="auth-login-link inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium text-text-secondary hover:text-text-primary border border-border hover:border-border-hover transition-all"
                    >
                        <i class="fa-brands fa-github"></i>
                        Log in
                    </a>
                </div>
            </div>

            <!-- Mobile: auth chip + hamburger -->
            <div class="md:hidden flex items-center gap-2 shrink-0">
                <div class="auth-slot relative" data-auth-slot="mobile">
                    <a
                        href="/api/auth/login"
                        data-astro-reload
                        class="auth-login-link inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary border border-border transition-all"
                    >
                        <i class="fa-brands fa-github"></i>
                        Log in
                    </a>
                </div>
                <button
                    id="mobile-menu-toggle"
                    class="flex items-center justify-center w-10 h-10 rounded-lg text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors"
                    aria-label="Toggle menu"
                    aria-expanded="false"
                >
                    <i class="fa-solid fa-bars text-lg" id="menu-icon-open"></i>
                    <i
                        class="fa-solid fa-xmark text-lg"
                        id="menu-icon-close"
                        style="display:none;"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div
            id="mobile-menu"
            class="md:hidden overflow-hidden border-t border-border/50"
            style="display:none;"
        >
            <div class="py-3 space-y-1">
                <a
                    href="/"
                    class="block px-4 py-2.5 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 rounded-lg transition-colors"
                >
                    <i class="fa-solid fa-house w-5 mr-2 text-xs"></i>Home
                </a>
                <a
                    href="/search"
                    class="block px-4 py-2.5 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 rounded-lg transition-colors"
                >
                    <i class="fa-solid fa-magnifying-glass w-5 mr-2 text-xs"
                    ></i>Find Templates
                </a>
                <a
                    href="/create"
                    data-astro-reload
                    class="block px-4 py-2.5 text-sm font-bold text-gold-start hover:bg-white/5 rounded-lg transition-colors"
                >
                    <i class="fa-solid fa-plus w-5 mr-2 text-xs"></i>Create
                    Ranking
                </a>
                <!-- Extra links injected here by JS when logged in -->
                <div id="mobile-auth-links"></div>
            </div>
        </div>
    </nav>
</header>

<!-- Spacer to push content below fixed header -->
<div class="h-16"></div>

<script>
    import { avatarHtml } from "../lib/avatars";

    type Me = {
        username: string;
        avatar: string;
        isVerified: boolean;
    } | null;

    // Fetch the session user once per page session (header persists across
    // view transitions, but each soft navigation re-runs astro:page-load).
    let mePromise: Promise<Me> | null = null;
    function getMe(): Promise<Me> {
        if (!mePromise) {
            mePromise = fetch("/api/auth/me")
                .then((r) => (r.ok ? r.json() : { user: null }))
                .then((d) => d.user as Me)
                .catch(() => {
                    mePromise = null;
                    return null;
                });
        }
        return mePromise;
    }

    function closeAllDropdowns() {
        document
            .querySelectorAll<HTMLElement>(".auth-dropdown")
            .forEach((m) => (m.style.display = "none"));
    }

    function renderUserSlot(slot: HTMLElement, user: NonNullable<Me>) {
        if (slot.dataset.user === user.username) return;
        slot.dataset.user = user.username;
        const compact = slot.dataset.authSlot === "mobile";
        slot.innerHTML = `
            <button type="button" class="auth-user-btn inline-flex items-center gap-2 ${compact ? "px-2 py-1.5" : "px-3 py-1.5"} rounded-xl text-sm font-medium text-text-primary border border-border hover:border-border-hover transition-all" aria-haspopup="true" aria-expanded="false">
                ${avatarHtml(user.avatar, 24, user.isVerified)}
                ${compact ? "" : `<span class="max-w-28 truncate">${escapeHtml(user.username)}</span><i class="fa-solid fa-chevron-down text-[10px] text-text-muted"></i>`}
            </button>
            <div class="auth-dropdown absolute right-0 top-full mt-2 w-48 rounded-xl bg-surface-elevated border border-border shadow-xl shadow-black/40 py-1.5 z-50" style="display:none;">
                <a href="/u/${encodeURIComponent(user.username)}" class="block px-4 py-2 text-sm text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors"><i class="fa-solid fa-user w-5 mr-1 text-xs"></i>My profile</a>
                <a href="/me" class="block px-4 py-2 text-sm text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors"><i class="fa-solid fa-layer-group w-5 mr-1 text-xs"></i>My templates</a>
                <a href="/history" class="block px-4 py-2 text-sm text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors"><i class="fa-solid fa-clock-rotate-left w-5 mr-1 text-xs"></i>My history</a>
                <button type="button" class="auth-logout-btn block w-full text-left px-4 py-2 text-sm text-red-400 hover:bg-white/5 transition-colors"><i class="fa-solid fa-arrow-right-from-bracket w-5 mr-1 text-xs"></i>Log out</button>
            </div>`;

        const btn = slot.querySelector<HTMLElement>(".auth-user-btn")!;
        const menu = slot.querySelector<HTMLElement>(".auth-dropdown")!;
        btn.addEventListener("click", (e) => {
            e.stopPropagation();
            const isOpen = menu.style.display !== "none";
            closeAllDropdowns();
            menu.style.display = isOpen ? "none" : "";
            btn.setAttribute("aria-expanded", String(!isOpen));
        });
        slot.querySelector(".auth-logout-btn")!.addEventListener(
            "click",
            async () => {
                try {
                    await fetch("/api/auth/logout", { method: "POST" });
                } catch {
                    /* ignore */
                }
                window.location.href = "/";
            },
        );
    }

    function escapeHtml(s: string): string {
        return s.replace(
            /[&<>"']/g,
            (c) =>
                ({
                    "&": "&amp;",
                    "<": "&lt;",
                    ">": "&gt;",
                    '"': "&quot;",
                    "'": "&#39;",
                })[c]!,
        );
    }

    function applyAuthState() {
        // Point login links at the current page so users come back here.
        const next = encodeURIComponent(
            window.location.pathname + window.location.search,
        );
        document
            .querySelectorAll<HTMLAnchorElement>(".auth-login-link")
            .forEach((a) => (a.href = `/api/auth/login?next=${next}`));

        getMe().then((user) => {
            if (!user) return;
            document
                .querySelectorAll<HTMLElement>(".auth-slot")
                .forEach((slot) => renderUserSlot(slot, user));
            // Mobile menu: add profile/manage links once.
            const mobileLinks = document.getElementById("mobile-auth-links");
            if (mobileLinks && !mobileLinks.dataset.user) {
                mobileLinks.dataset.user = user.username;
                mobileLinks.innerHTML = `
                    <a href="/u/${encodeURIComponent(user.username)}" class="block px-4 py-2.5 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 rounded-lg transition-colors"><i class="fa-solid fa-user w-5 mr-2 text-xs"></i>My profile</a>
                    <a href="/me" class="block px-4 py-2.5 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 rounded-lg transition-colors"><i class="fa-solid fa-layer-group w-5 mr-2 text-xs"></i>My templates</a>
                    <a href="/history" class="block px-4 py-2.5 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 rounded-lg transition-colors"><i class="fa-solid fa-clock-rotate-left w-5 mr-2 text-xs"></i>My history</a>`;
            }
        });
    }

    // The header persists across View Transitions, so an open mobile menu or
    // auth dropdown would stay open after tapping a link and navigating. Reset
    // them to closed on every soft navigation.
    function resetMenus() {
        closeAllDropdowns();
        const menu = document.getElementById("mobile-menu");
        const iconOpen = document.getElementById("menu-icon-open");
        const iconClose = document.getElementById("menu-icon-close");
        const toggle = document.getElementById("mobile-menu-toggle");
        if (menu) menu.style.display = "none";
        if (iconOpen) iconOpen.style.display = "";
        if (iconClose) iconClose.style.display = "none";
        toggle?.setAttribute("aria-expanded", "false");
    }

    document.addEventListener("astro:page-load", () => {
        applyAuthState();
        resetMenus();

        const toggle = document.getElementById("mobile-menu-toggle");
        const menu = document.getElementById("mobile-menu");
        const iconOpen = document.getElementById("menu-icon-open");
        const iconClose = document.getElementById("menu-icon-close");

        if (!toggle || !menu || !iconOpen || !iconClose) return;
        // Header is transition:persist — bind these once.
        if (toggle.dataset.bound) return;
        toggle.dataset.bound = "1";

        toggle.addEventListener("click", () => {
            const isOpen = menu.style.display !== "none";

            if (isOpen) {
                menu.style.display = "none";
                iconOpen.style.display = "";
                iconClose.style.display = "none";
                toggle.setAttribute("aria-expanded", "false");
            } else {
                menu.style.display = "";
                iconOpen.style.display = "none";
                iconClose.style.display = "";
                toggle.setAttribute("aria-expanded", "true");
            }
        });

        document.addEventListener("click", closeAllDropdowns);

        // Close the mobile menu when clicking outside it. The toggle has its
        // own handler, so ignore clicks on it (otherwise the opening click
        // would immediately close the menu); clicks on menu links navigate and
        // are reset on astro:page-load.
        document.addEventListener("click", (e) => {
            if (menu.style.display === "none") return;
            const target = e.target as Node | null;
            if (toggle.contains(target) || menu.contains(target)) return;
            menu.style.display = "none";
            iconOpen.style.display = "";
            iconClose.style.display = "none";
            toggle.setAttribute("aria-expanded", "false");
        });
    });
</script>
