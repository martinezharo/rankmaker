---
// Header.astro — Fixed header with logo, nav links, Create Ranking CTA,
// auth slot (client-rendered: pages are publicly cached) and mobile menu.
import { defaultLocale, localizePath, useTranslations } from "../i18n";

const locale = Astro.locals.locale ?? defaultLocale;
const t = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);
---

<header
    transition:persist
    transition:name="site-header"
    transition:animate="none"
    class="fixed top-0 left-0 right-0 z-50 border-b border-border/50 bg-surface/80 backdrop-blur-xl"
>
    <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
            <!-- Logo (1200x120 source: must be allowed to shrink on mobile) -->
            <a href={L("/")} class="flex items-center gap-2 min-w-0 mr-3">
                <img
                    src="/RANKMAKER-logo.webp"
                    alt="RANKMAKER"
                    class="h-8 w-auto max-w-full object-contain object-left"
                />
            </a>

            <!-- Desktop Nav -->
            <div class="hidden md:flex items-center gap-1">
                <a
                    href={L("/")}
                    class="flex items-center px-4 py-2 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors rounded-lg hover:bg-white/5"
                >
                    <i class="fa-solid fa-house text-xs mr-2"></i>
                    {t("nav.home")}
                </a>
                <a
                    href={L("/search")}
                    class="flex items-center px-4 py-2 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors rounded-lg hover:bg-white/5"
                >
                    <i class="fa-solid fa-magnifying-glass text-xs mr-2"></i>
                    {t("nav.findTemplates")}
                </a>

                <a
                    href={L("/create")}
                    data-astro-reload
                    class="ml-2 inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-bold text-[#1a1205] bg-gradient-to-r from-gold-start to-gold-end hover:opacity-90 transition-opacity"
                >
                    <i class="fa-solid fa-plus text-xs"></i>
                    {t("nav.createRanking")}
                </a>

                <!-- Auth slot (desktop) — swapped by client JS when logged in.
                     data-astro-reload: the OAuth redirect to GitHub must be a
                     full browser navigation (the ClientRouter fetch would be
                     blocked by CORS). -->
                <div class="auth-slot ml-1 relative" data-auth-slot="desktop">
                    <a
                        href="/api/auth/login"
                        data-astro-reload
                        class="auth-login-link inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium text-text-secondary hover:text-text-primary border border-border hover:border-border-hover transition-all"
                    >
                        <i class="fa-brands fa-github"></i>
                        {t("nav.login")}
                    </a>
                </div>
            </div>

            <!-- Mobile: auth chip + hamburger -->
            <div class="md:hidden flex items-center gap-2 shrink-0">
                <div class="auth-slot relative" data-auth-slot="mobile">
                    <a
                        href="/api/auth/login"
                        data-astro-reload
                        class="auth-login-link inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary border border-border transition-all"
                    >
                        <i class="fa-brands fa-github"></i>
                        {t("nav.login")}
                    </a>
                </div>
                <button
                    id="mobile-menu-toggle"
                    class="flex items-center justify-center w-10 h-10 rounded-lg text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors"
                    aria-label={t("nav.toggleMenu")}
                    aria-expanded="false"
                >
                    <i class="fa-solid fa-bars text-lg" id="menu-icon-open"></i>
                    <i
                        class="fa-solid fa-xmark text-lg"
                        id="menu-icon-close"
                        style="display:none;"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div
            id="mobile-menu"
            class="md:hidden border-t border-border/50"
            style="display:none;"
        >
            <div class="py-3 space-y-1">
                <a
                    href={L("/")}
                    class="block px-4 py-2.5 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 rounded-lg transition-colors"
                >
                    <i class="fa-solid fa-house w-5 mr-2 text-xs"></i>{
                        t("nav.home")
                    }
                </a>
                <a
                    href={L("/search")}
                    class="block px-4 py-2.5 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 rounded-lg transition-colors"
                >
                    <i class="fa-solid fa-magnifying-glass w-5 mr-2 text-xs"
                    ></i>{t("nav.findTemplates")}
                </a>
                <a
                    href={L("/create")}
                    data-astro-reload
                    class="block px-4 py-2.5 text-sm font-bold text-gold-start hover:bg-white/5 rounded-lg transition-colors"
                >
                    <i class="fa-solid fa-plus w-5 mr-2 text-xs"></i>{
                        t("nav.createRanking")
                    }
                </a>
                <!-- Extra links injected here by JS when logged in -->
                <div id="mobile-auth-links"></div>
            </div>
        </div>
    </nav>
</header>

<!-- Spacer to push content below fixed header -->
<div class="h-16"></div>

<script>
    import { avatarHtml } from "../lib/avatars";
    import { clientT, getClientLocale } from "../i18n/client";
    import { localizePath } from "../i18n";

    type Me = {
        username: string;
        avatar: string;
        isVerified: boolean;
        unreadNotifications?: number;
    } | null;

    // Apply the unread count to the (persisted) header: the button badge plus
    // the dropdown / mobile-menu chips. Placeholders always exist in the markup
    // (see renderUserSlot / renderMobileLinks); this just sets their text and
    // shows/hides them, so there's a single source of truth and nothing goes
    // stale.
    // Toggle visibility via an inline display style rather than the `hidden`
    // class: these placeholders also carry a `flex`/`inline-flex` utility, and
    // because `.inline-flex` is emitted *after* `.hidden` in the generated CSS,
    // `hidden` loses the cascade on the dropdown chips and leaves an empty red
    // circle behind. An inline style always wins, regardless of class order.
    function applyNotifCount(count: number) {
        const label = count > 9 ? "9+" : String(count);
        document
            .querySelectorAll<HTMLElement>(".notif-badge")
            .forEach((el) => {
                el.textContent = label;
                el.style.display = count < 1 ? "none" : "";
            });
        document
            .querySelectorAll<HTMLElement>("[data-notif-count]")
            .forEach((el) => {
                el.textContent = count > 0 ? label : "";
                el.style.display = count < 1 ? "none" : "";
            });
    }

    // The header persists for the whole SPA session, so the unread count must be
    // re-fetched on every navigation (and whenever notifications change) rather
    // than cached — otherwise the badge freezes at its first-load value and only
    // a full reload fixes it. A sequence guard makes the latest request win, so
    // a slow stale response can't clobber a fresher count (e.g. the refetch
    // fired right after marking notifications read).
    let meSeq = 0;
    function refreshMe(): void {
        const seq = ++meSeq;
        fetch("/api/auth/me", { headers: { "cache-control": "no-cache" } })
            .then((r) => (r.ok ? r.json() : { user: null }))
            .then((d) => {
                if (seq !== meSeq) return; // superseded by a newer refresh
                const user = d.user as Me;
                if (!user) return;
                document
                    .querySelectorAll<HTMLElement>(".auth-slot")
                    .forEach((slot) => renderUserSlot(slot, user));
                renderMobileLinks(user);
                applyNotifCount(user.unreadNotifications ?? 0);
            })
            .catch(() => {
                /* leave whatever is currently shown */
            });
    }

    // The notifications page (and any future notification action) fires this
    // after the server state changes so the badge updates immediately, without
    // waiting for the next navigation.
    document.addEventListener("rm:notif-changed", refreshMe);


    function closeAllDropdowns() {
        document
            .querySelectorAll<HTMLElement>(".auth-dropdown")
            .forEach((m) => (m.style.display = "none"));
    }

    function renderUserSlot(slot: HTMLElement, user: NonNullable<Me>) {
        if (slot.dataset.user === user.username) return;
        slot.dataset.user = user.username;
        const compact = slot.dataset.authSlot === "mobile";
        const t = clientT();
        const locale = getClientLocale();
        const L = (p: string) => localizePath(p, locale);
        slot.innerHTML = `
            <button type="button" class="auth-user-btn relative inline-flex items-center gap-2 ${compact ? "px-2 py-1.5" : "px-3 py-1.5"} rounded-xl text-sm font-medium text-text-primary border border-border hover:border-border-hover transition-all" aria-haspopup="true" aria-expanded="false">
                ${avatarHtml(user.avatar, 24, user.isVerified)}
                ${compact ? "" : `<span class="max-w-28 truncate">${escapeHtml(user.username)}</span><i class="fa-solid fa-chevron-down text-[10px] text-text-muted"></i>`}
                <span class="notif-badge absolute -top-1.5 -right-1.5 min-w-[18px] h-[18px] px-1 rounded-full bg-red-500 text-white text-[10px] leading-none font-bold flex items-center justify-center ring-2 ring-surface" style="display:none"></span>
            </button>
            <div class="auth-dropdown absolute right-0 top-full mt-2 w-48 rounded-xl bg-surface-elevated border border-border shadow-xl shadow-black/40 py-1.5 z-50" style="display:none;">
                <a href="${L("/me")}" class="block px-4 py-2 text-sm text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors"><i class="fa-solid fa-user w-5 mr-1 text-xs"></i>${escapeHtml(t("nav.myProfile"))}</a>
                <a href="${L("/notifications")}" class="flex items-center gap-1 px-4 py-2 text-sm text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors"><i class="fa-solid fa-bell w-5 mr-1 text-xs"></i>${escapeHtml(t("nav.notifications"))}<span data-notif-count class="ml-auto min-w-[18px] h-[18px] px-1 rounded-full bg-red-500 text-white text-[10px] leading-none font-bold inline-flex items-center justify-center" style="display:none"></span></a>
                <a href="${L("/saved")}" class="block px-4 py-2 text-sm text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors"><i class="fa-solid fa-bookmark w-5 mr-1 text-xs"></i>${escapeHtml(t("nav.mySaved"))}</a>
                <a href="${L("/history")}" class="block px-4 py-2 text-sm text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors"><i class="fa-solid fa-clock-rotate-left w-5 mr-1 text-xs"></i>${escapeHtml(t("nav.myHistory"))}</a>
                <button type="button" class="auth-logout-btn block w-full text-left px-4 py-2 text-sm text-red-400 hover:bg-white/5 transition-colors"><i class="fa-solid fa-arrow-right-from-bracket w-5 mr-1 text-xs"></i>${escapeHtml(t("nav.logout"))}</button>
            </div>`;

        const btn = slot.querySelector<HTMLElement>(".auth-user-btn")!;
        const menu = slot.querySelector<HTMLElement>(".auth-dropdown")!;
        btn.addEventListener("click", (e) => {
            e.stopPropagation();
            const isOpen = menu.style.display !== "none";
            closeAllDropdowns();
            menu.style.display = isOpen ? "none" : "";
            btn.setAttribute("aria-expanded", String(!isOpen));
        });
        slot.querySelector(".auth-logout-btn")!.addEventListener(
            "click",
            async () => {
                try {
                    await fetch("/api/auth/logout", { method: "POST" });
                } catch {
                    /* ignore */
                }
                window.location.href = localizePath("/", getClientLocale());
            },
        );
    }

    function escapeHtml(s: string): string {
        return s.replace(
            /[&<>"']/g,
            (c) =>
                ({
                    "&": "&amp;",
                    "<": "&lt;",
                    ">": "&gt;",
                    '"': "&quot;",
                    "'": "&#39;",
                })[c]!,
        );
    }

    function applyAuthState() {
        // Point login links at the current page so users come back here.
        const next = encodeURIComponent(
            window.location.pathname + window.location.search,
        );
        document
            .querySelectorAll<HTMLAnchorElement>(".auth-login-link")
            .forEach((a) => (a.href = `/api/auth/login?next=${next}`));

        refreshMe();
    }

    // Mobile menu: profile/manage links, rendered once. The notification chip
    // is a persistent placeholder filled by applyNotifCount.
    function renderMobileLinks(user: NonNullable<Me>) {
        const mobileLinks = document.getElementById("mobile-auth-links");
        if (!mobileLinks || mobileLinks.dataset.user) return;
        mobileLinks.dataset.user = user.username;
        const t = clientT();
        const L = (p: string) => localizePath(p, getClientLocale());
        mobileLinks.innerHTML = `
            <a href="${L("/me")}" class="block px-4 py-2.5 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 rounded-lg transition-colors"><i class="fa-solid fa-user w-5 mr-2 text-xs"></i>${escapeHtml(t("nav.myProfile"))}</a>
            <a href="${L("/notifications")}" class="flex items-center px-4 py-2.5 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 rounded-lg transition-colors"><i class="fa-solid fa-bell w-5 mr-2 text-xs"></i>${escapeHtml(t("nav.notifications"))}<span data-notif-count class="ml-auto min-w-[18px] h-[18px] px-1 rounded-full bg-red-500 text-white text-[10px] leading-none font-bold inline-flex items-center justify-center" style="display:none"></span></a>
            <a href="${L("/saved")}" class="block px-4 py-2.5 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 rounded-lg transition-colors"><i class="fa-solid fa-bookmark w-5 mr-2 text-xs"></i>${escapeHtml(t("nav.mySaved"))}</a>
            <a href="${L("/history")}" class="block px-4 py-2.5 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 rounded-lg transition-colors"><i class="fa-solid fa-clock-rotate-left w-5 mr-2 text-xs"></i>${escapeHtml(t("nav.myHistory"))}</a>`;
    }

    // The header persists across View Transitions, so an open mobile menu or
    // auth dropdown would stay open after tapping a link and navigating. Reset
    // them to closed on every soft navigation.
    function resetMenus() {
        closeAllDropdowns();
        const menu = document.getElementById("mobile-menu");
        const iconOpen = document.getElementById("menu-icon-open");
        const iconClose = document.getElementById("menu-icon-close");
        const toggle = document.getElementById("mobile-menu-toggle");
        if (menu) menu.style.display = "none";
        if (iconOpen) iconOpen.style.display = "";
        if (iconClose) iconClose.style.display = "none";
        toggle?.setAttribute("aria-expanded", "false");
    }

    document.addEventListener("astro:page-load", () => {
        applyAuthState();
        resetMenus();

        const toggle = document.getElementById("mobile-menu-toggle");
        const menu = document.getElementById("mobile-menu");
        const iconOpen = document.getElementById("menu-icon-open");
        const iconClose = document.getElementById("menu-icon-close");

        if (!toggle || !menu || !iconOpen || !iconClose) return;
        // Header is transition:persist — bind these once.
        if (toggle.dataset.bound) return;
        toggle.dataset.bound = "1";

        toggle.addEventListener("click", () => {
            const isOpen = menu.style.display !== "none";

            if (isOpen) {
                menu.style.display = "none";
                iconOpen.style.display = "";
                iconClose.style.display = "none";
                toggle.setAttribute("aria-expanded", "false");
            } else {
                menu.style.display = "";
                iconOpen.style.display = "none";
                iconClose.style.display = "";
                toggle.setAttribute("aria-expanded", "true");
            }
        });

        document.addEventListener("click", closeAllDropdowns);

        // Close the mobile menu when clicking outside it. The toggle has its
        // own handler, so ignore clicks on it (otherwise the opening click
        // would immediately close the menu); clicks on menu links navigate and
        // are reset on astro:page-load.
        document.addEventListener("click", (e) => {
            if (menu.style.display === "none") return;
            const target = e.target as Node | null;
            if (toggle.contains(target) || menu.contains(target)) return;
            menu.style.display = "none";
            iconOpen.style.display = "";
            iconClose.style.display = "none";
            toggle.setAttribute("aria-expanded", "false");
        });
    });
</script>
