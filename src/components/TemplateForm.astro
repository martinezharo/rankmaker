---
// TemplateForm.astro — shared create/edit form for user templates.
// Images are URL-only by design (no uploads). Rows are rendered client-side
// from #template-form-data so create and edit share one row markup source.
import { CATEGORIES } from "../lib/categories";
import { MAX_OPTIONS, MIN_OPTIONS } from "../lib/templates";

interface Props {
    mode: "create" | "edit";
    template?: {
        id: string;
        slug: string;
        title: string;
        description: string | null;
        category: string | null;
        cover_image: string | null;
        options: { name: string; image: string | null }[];
    };
}

const { mode, template } = Astro.props;

const initial = {
    mode,
    id: template?.id ?? null,
    slug: template?.slug ?? null,
    title: template?.title ?? "",
    description: template?.description ?? "",
    category: template?.category ?? "",
    cover_image: template?.cover_image ?? "",
    options: template?.options?.map((o) => ({
        name: o.name,
        image: o.image ?? "",
    })) ?? [],
    minOptions: MIN_OPTIONS,
    maxOptions: MAX_OPTIONS,
};

const inputClass =
    "w-full px-4 py-3 rounded-xl bg-surface border border-border text-sm text-text-primary placeholder:text-text-muted/60 focus:outline-none focus:border-primary/60 focus:ring-1 focus:ring-primary/30 transition-all";
---

<form id="template-form" class="space-y-6" novalidate>
    <!-- Details -->
    <section class="rounded-2xl bg-surface-elevated border border-border p-5 sm:p-6 space-y-5">
        <h2 class="text-sm font-bold text-text-primary uppercase tracking-wider flex items-center gap-2">
            <i class="fa-solid fa-pen text-primary text-xs"></i>
            Details
        </h2>

        <div>
            <div class="flex items-center justify-between mb-2">
                <label for="tf-title" class="text-sm font-semibold text-text-primary">Title</label>
                <span class="text-xs text-text-muted"><span id="tf-title-count">0</span>/80</span>
            </div>
            <input
                id="tf-title"
                type="text"
                maxlength="80"
                placeholder="Best Pizza Toppings Ranking"
                class={inputClass}
                value={initial.title}
            />
        </div>

        <div>
            <div class="flex items-center justify-between mb-2">
                <label for="tf-description" class="text-sm font-semibold text-text-primary">
                    Description <span class="font-normal text-text-muted">(optional)</span>
                </label>
                <span class="text-xs text-text-muted"><span id="tf-desc-count">0</span>/300</span>
            </div>
            <textarea
                id="tf-description"
                maxlength="300"
                rows="3"
                placeholder="What should people rank, and why is it fun?"
                class={inputClass + " resize-none"}>{initial.description}</textarea>
        </div>

        <div>
            <label for="tf-category" class="block text-sm font-semibold text-text-primary mb-2">Category</label>
            <div class="relative">
                <select
                    id="tf-category"
                    class={inputClass + " appearance-none pr-10 cursor-pointer"}
                >
                    <option value="" disabled selected={!initial.category}>
                        Pick a category…
                    </option>
                    {
                        CATEGORIES.map((c) => (
                            <option
                                value={c.name}
                                selected={c.name === initial.category}
                            >
                                {c.name}
                            </option>
                        ))
                    }
                </select>
                <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-text-muted text-xs pointer-events-none"></i>
            </div>
        </div>
    </section>

    <!-- Cover image -->
    <section class="rounded-2xl bg-surface-elevated border border-border p-5 sm:p-6 space-y-4">
        <h2 class="text-sm font-bold text-text-primary uppercase tracking-wider flex items-center gap-2">
            <i class="fa-solid fa-image text-primary text-xs"></i>
            Cover image
            <span class="font-normal normal-case tracking-normal text-text-muted">(optional, by URL)</span>
        </h2>

        <input
            id="tf-cover"
            type="url"
            placeholder="https://example.com/cover.jpg"
            class={inputClass}
            value={initial.cover_image}
        />

        <div class="relative aspect-4/3 max-w-sm rounded-xl overflow-hidden bg-surface border border-border">
            <img
                id="tf-cover-preview"
                alt="Cover preview"
                class="w-full h-full object-cover"
                style="display:none;"
            />
            <div
                id="tf-cover-placeholder"
                class="absolute inset-0 flex flex-col items-center justify-center gap-2 text-text-muted"
            >
                <i class="fa-regular fa-image text-2xl"></i>
                <span class="text-xs" id="tf-cover-placeholder-text">Preview appears here</span>
            </div>
        </div>
    </section>

    <!-- Options -->
    <section class="rounded-2xl bg-surface-elevated border border-border p-5 sm:p-6 space-y-4">
        <div class="flex items-center justify-between">
            <h2 class="text-sm font-bold text-text-primary uppercase tracking-wider flex items-center gap-2">
                <i class="fa-solid fa-layer-group text-primary text-xs"></i>
                Options
            </h2>
            <span class="text-xs font-medium text-text-muted">
                <span id="tf-option-count">0</span>/{MAX_OPTIONS}
                <span class="ml-2 text-text-muted/70">min {MIN_OPTIONS}</span>
            </span>
        </div>
        <p class="text-xs text-text-muted -mt-2">
            The things people will rank in 1v1 battles. Images are optional —
            paste an image URL and you'll see a preview.
        </p>

        <div id="tf-options" class="space-y-3">
            <!-- Rows rendered by client script -->
        </div>

        <button
            type="button"
            id="tf-add-option"
            class="w-full flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-dashed border-border hover:border-primary/50 text-sm font-medium text-text-secondary hover:text-primary transition-all"
        >
            <i class="fa-solid fa-plus text-xs"></i>
            Add option
        </button>
    </section>

    <!-- Submit -->
    <div class="space-y-3">
        <p id="tf-error" class="text-sm text-red-400 min-h-5"></p>
        <button
            type="submit"
            id="tf-submit"
            class="w-full sm:w-auto px-8 py-3.5 rounded-xl font-bold text-sm uppercase tracking-wider text-[#1a1205] bg-gradient-to-r from-gold-start to-gold-end hover:opacity-90 transition-all disabled:opacity-40 disabled:cursor-not-allowed"
        >
            {mode === "create" ? "Create template" : "Save changes"}
        </button>
    </div>
</form>

<!-- Option row markup (cloned by the client script) -->
<template id="tf-option-row-template">
    <div class="option-row flex items-start gap-3 p-3 rounded-xl bg-surface border border-border">
        <div
            class="option-thumb relative w-12 h-12 shrink-0 rounded-lg overflow-hidden bg-surface-elevated border border-border flex items-center justify-center"
        >
            <img
                class="option-thumb-img w-full h-full object-cover"
                alt=""
                style="display:none;"
            />
            <i class="option-thumb-icon fa-regular fa-image text-text-muted text-sm"></i>
        </div>
        <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 gap-2">
            <input
                type="text"
                maxlength="80"
                placeholder="Option name"
                class="option-name w-full px-3 py-2.5 rounded-lg bg-surface-elevated border border-border text-sm text-text-primary placeholder:text-text-muted/60 focus:outline-none focus:border-primary/60 transition-all"
            />
            <input
                type="url"
                placeholder="Image URL (optional)"
                class="option-image w-full px-3 py-2.5 rounded-lg bg-surface-elevated border border-border text-sm text-text-primary placeholder:text-text-muted/60 focus:outline-none focus:border-primary/60 transition-all"
            />
        </div>
        <button
            type="button"
            class="option-remove w-9 h-9 shrink-0 rounded-lg flex items-center justify-center text-text-muted hover:text-red-400 hover:bg-red-400/10 transition-all"
            aria-label="Remove option"
        >
            <i class="fa-solid fa-xmark text-sm"></i>
        </button>
    </div>
</template>

<script
    type="application/json"
    id="template-form-data"
    set:html={JSON.stringify(initial).replace(/</g, "\\u003c")}
/>

<script>
    document.addEventListener("astro:page-load", () => {
        const form = document.getElementById(
            "template-form",
        ) as HTMLFormElement | null;
        if (!form || form.dataset.bound) return;
        form.dataset.bound = "1";

        const data = JSON.parse(
            document.getElementById("template-form-data")!.textContent || "{}",
        );

        const title = document.getElementById("tf-title") as HTMLInputElement;
        const titleCount = document.getElementById("tf-title-count")!;
        const desc = document.getElementById(
            "tf-description",
        ) as HTMLTextAreaElement;
        const descCount = document.getElementById("tf-desc-count")!;
        const category = document.getElementById(
            "tf-category",
        ) as HTMLSelectElement;
        const cover = document.getElementById("tf-cover") as HTMLInputElement;
        const coverPreview = document.getElementById(
            "tf-cover-preview",
        ) as HTMLImageElement;
        const coverPlaceholder = document.getElementById(
            "tf-cover-placeholder",
        )!;
        const coverPlaceholderText = document.getElementById(
            "tf-cover-placeholder-text",
        )!;
        const optionsEl = document.getElementById("tf-options")!;
        const optionCount = document.getElementById("tf-option-count")!;
        const addBtn = document.getElementById("tf-add-option")!;
        const rowTemplate = document.getElementById(
            "tf-option-row-template",
        ) as HTMLTemplateElement;
        const errorEl = document.getElementById("tf-error")!;
        const submit = document.getElementById(
            "tf-submit",
        ) as HTMLButtonElement;

        function isHttpUrl(value: string): boolean {
            try {
                const u = new URL(value);
                return u.protocol === "http:" || u.protocol === "https:";
            } catch {
                return false;
            }
        }

        // ── Image previews ───────────────────────────────────────────
        function bindPreview(
            input: HTMLInputElement,
            img: HTMLImageElement,
            onState: (state: "empty" | "loading" | "ok" | "error") => void,
        ) {
            let timer: ReturnType<typeof setTimeout> | undefined;
            const update = () => {
                const url = input.value.trim();
                if (!url || !isHttpUrl(url)) {
                    img.style.display = "none";
                    img.removeAttribute("src");
                    onState(url ? "error" : "empty");
                    return;
                }
                onState("loading");
                img.onload = () => {
                    img.style.display = "";
                    onState("ok");
                };
                img.onerror = () => {
                    img.style.display = "none";
                    onState("error");
                };
                img.src = url;
            };
            input.addEventListener("input", () => {
                clearTimeout(timer);
                timer = setTimeout(update, 400);
            });
            update();
        }

        bindPreview(cover, coverPreview, (state) => {
            coverPlaceholder.style.display = state === "ok" ? "none" : "";
            coverPlaceholderText.textContent =
                state === "error"
                    ? "Couldn't load that image"
                    : state === "loading"
                      ? "Loading…"
                      : "Preview appears here";
        });

        // ── Option rows ──────────────────────────────────────────────
        function rows(): HTMLElement[] {
            return Array.from(optionsEl.querySelectorAll(".option-row"));
        }

        function updateCount() {
            const n = rows().length;
            optionCount.textContent = String(n);
            (addBtn as HTMLButtonElement).style.display =
                n >= data.maxOptions ? "none" : "";
        }

        function addRow(name = "", image = "", focus = false) {
            if (rows().length >= data.maxOptions) return;
            const row = (
                rowTemplate.content.cloneNode(true) as DocumentFragment
            ).firstElementChild as HTMLElement;
            const nameInput =
                row.querySelector<HTMLInputElement>(".option-name")!;
            const imageInput =
                row.querySelector<HTMLInputElement>(".option-image")!;
            const thumbImg =
                row.querySelector<HTMLImageElement>(".option-thumb-img")!;
            const thumbIcon = row.querySelector<HTMLElement>(
                ".option-thumb-icon",
            )!;
            nameInput.value = name;
            imageInput.value = image;

            bindPreview(imageInput, thumbImg, (state) => {
                thumbIcon.style.display = state === "ok" ? "none" : "";
                thumbIcon.className = `option-thumb-icon text-sm ${
                    state === "error"
                        ? "fa-solid fa-triangle-exclamation text-red-400/70"
                        : "fa-regular fa-image text-text-muted"
                }`;
            });

            row.querySelector(".option-remove")!.addEventListener(
                "click",
                () => {
                    row.remove();
                    updateCount();
                },
            );

            optionsEl.appendChild(row);
            updateCount();
            if (focus) nameInput.focus();
        }

        addBtn.addEventListener("click", () => addRow("", "", true));

        // Initial rows: existing options (edit) or MIN empty rows (create).
        if (data.options.length > 0) {
            data.options.forEach((o: { name: string; image: string }) =>
                addRow(o.name, o.image),
            );
        } else {
            for (let i = 0; i < data.minOptions; i++) addRow();
        }

        // ── Char counters ────────────────────────────────────────────
        function bindCounter(
            el: HTMLInputElement | HTMLTextAreaElement,
            counter: HTMLElement,
        ) {
            const update = () => (counter.textContent = String(el.value.length));
            el.addEventListener("input", update);
            update();
        }
        bindCounter(title, titleCount);
        bindCounter(desc, descCount);

        // ── Submit ───────────────────────────────────────────────────
        function validate(): string | null {
            if (title.value.trim().length < 3)
                return "Title must be at least 3 characters.";
            if (!category.value) return "Pick a category.";
            const coverVal = cover.value.trim();
            if (coverVal && !isHttpUrl(coverVal))
                return "Cover image must be a valid http(s) URL.";
            const opts = rows();
            const named = opts.filter(
                (r) =>
                    r
                        .querySelector<HTMLInputElement>(".option-name")!
                        .value.trim().length > 0,
            );
            if (named.length < data.minOptions)
                return `Add at least ${data.minOptions} options with a name.`;
            for (const r of opts) {
                const name = r
                    .querySelector<HTMLInputElement>(".option-name")!
                    .value.trim();
                const image = r
                    .querySelector<HTMLInputElement>(".option-image")!
                    .value.trim();
                if (!name && image)
                    return "Every option with an image needs a name.";
                if (image && !isHttpUrl(image))
                    return `Option "${name}": image must be a valid http(s) URL.`;
            }
            return null;
        }

        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            errorEl.textContent = "";

            const problem = validate();
            if (problem) {
                errorEl.textContent = problem;
                return;
            }

            const payload = {
                title: title.value.trim(),
                description: desc.value.trim() || null,
                category: category.value,
                cover_image: cover.value.trim() || null,
                options: rows()
                    .map((r) => ({
                        name: r
                            .querySelector<HTMLInputElement>(".option-name")!
                            .value.trim(),
                        image:
                            r
                                .querySelector<HTMLInputElement>(
                                    ".option-image",
                                )!
                                .value.trim() || null,
                    }))
                    .filter((o) => o.name),
            };

            submit.disabled = true;
            const originalLabel = submit.textContent;
            submit.textContent =
                data.mode === "create" ? "Creating…" : "Saving…";

            try {
                const res = await fetch(
                    data.mode === "create"
                        ? "/api/templates"
                        : `/api/templates/${data.id}`,
                    {
                        method: data.mode === "create" ? "POST" : "PUT",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload),
                    },
                );
                const result = await res.json();
                if (res.ok && result.ok) {
                    window.location.href = `/template/${result.slug}`;
                    return;
                }
                errorEl.textContent =
                    result.error || "Something went wrong. Try again.";
            } catch {
                errorEl.textContent = "Network error. Try again.";
            }
            submit.disabled = false;
            submit.textContent = originalLabel;
        });
    });
</script>
