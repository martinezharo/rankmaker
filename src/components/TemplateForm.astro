---
// TemplateForm.astro — shared create/edit form for user templates.
// Images are upload-only: files go through POST /api/images (WebP re-encode
// + moderation) and the form stores the returned URL. Rows are rendered
// client-side from #template-form-data so create and edit share one row
// markup source.
import { CATEGORIES } from "../lib/categories";
import { MAX_OPTIONS, MIN_OPTIONS, type Visibility } from "../lib/templates";
import { defaultLocale, useTranslations } from "../i18n";

interface Props {
    mode: "create" | "edit";
    template?: {
        id: string;
        slug: string;
        title: string;
        description: string | null;
        category: string | null;
        cover_image: string | null;
        visibility?: Visibility;
        options: { name: string; image: string | null }[];
    };
}

const { mode, template } = Astro.props;

const locale = Astro.locals.locale ?? defaultLocale;
const t = useTranslations(locale);

const VISIBILITY_CHOICES: {
    value: Visibility;
    label: string;
    hint: string;
}[] = [
    {
        value: "public",
        label: t("form.visibilityPublicLabel"),
        hint: t("form.visibilityPublicHint"),
    },
    {
        value: "unlisted",
        label: t("form.visibilityUnlistedLabel"),
        hint: t("form.visibilityUnlistedHint"),
    },
    {
        value: "private",
        label: t("form.visibilityPrivateLabel"),
        hint: t("form.visibilityPrivateHint"),
    },
];

const initial = {
    mode,
    id: template?.id ?? null,
    slug: template?.slug ?? null,
    title: template?.title ?? "",
    description: template?.description ?? "",
    category: template?.category ?? "",
    visibility: template?.visibility ?? "public",
    cover_image: template?.cover_image ?? "",
    options: template?.options?.map((o) => ({
        name: o.name,
        image: o.image ?? "",
    })) ?? [],
    minOptions: MIN_OPTIONS,
    maxOptions: MAX_OPTIONS,
};

const inputClass =
    "w-full px-4 py-3 rounded-xl bg-surface border border-border text-sm text-text-primary placeholder:text-text-muted/60 focus:outline-none focus:border-primary/60 focus:ring-1 focus:ring-primary/30 transition-all";
---

<form id="template-form" class="space-y-6" novalidate>
    <!-- Details -->
    <section class="rounded-2xl bg-surface-elevated border border-border p-5 sm:p-6 space-y-5">
        <h2 class="text-sm font-bold text-text-primary uppercase tracking-wider flex items-center gap-2">
            <i class="fa-solid fa-pen text-primary text-xs"></i>
            {t("form.details")}
        </h2>

        <div>
            <div class="flex items-center justify-between mb-2">
                <label for="tf-title" class="text-sm font-semibold text-text-primary">{t("form.titleLabel")}</label>
                <span class="text-xs text-text-muted"><span id="tf-title-count">0</span>/80</span>
            </div>
            <input
                id="tf-title"
                type="text"
                maxlength="80"
                placeholder={t("form.titlePlaceholder")}
                class={inputClass}
                value={initial.title}
            />
        </div>

        <div>
            <div class="flex items-center justify-between mb-2">
                <label for="tf-description" class="text-sm font-semibold text-text-primary">
                    {t("form.descriptionLabel")}
                </label>
                <span class="text-xs text-text-muted"><span id="tf-desc-count">0</span>/300</span>
            </div>
            <textarea
                id="tf-description"
                maxlength="300"
                rows="3"
                placeholder={t("form.descriptionPlaceholder")}
                class={inputClass + " resize-none"}>{initial.description}</textarea>
        </div>

        <div>
            <label for="tf-category" class="block text-sm font-semibold text-text-primary mb-2">{t("form.categoryLabel")}</label>
            <div class="relative">
                <select
                    id="tf-category"
                    class={inputClass + " appearance-none pr-10 cursor-pointer"}
                >
                    <option value="" disabled selected={!initial.category}>
                        {t("form.categoryPlaceholder")}
                    </option>
                    {
                        CATEGORIES.map((c) => (
                            <option
                                value={c.name}
                                selected={c.name === initial.category}
                            >
                                {t(`categories.${c.name}`)}
                            </option>
                        ))
                    }
                </select>
                <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-text-muted text-xs pointer-events-none"></i>
            </div>
        </div>

        <div>
            <label for="tf-visibility" class="block text-sm font-semibold text-text-primary mb-2">{t("form.visibilityLabel")}</label>
            <div class="relative">
                <select
                    id="tf-visibility"
                    class={inputClass + " appearance-none pr-10 cursor-pointer"}
                >
                    {
                        VISIBILITY_CHOICES.map((v) => (
                            <option
                                value={v.value}
                                data-hint={v.hint}
                                selected={v.value === initial.visibility}
                            >
                                {v.label}
                            </option>
                        ))
                    }
                </select>
                <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-text-muted text-xs pointer-events-none"></i>
            </div>
            <p id="tf-visibility-hint" class="text-xs text-text-muted mt-2"></p>
        </div>
    </section>

    <!-- Cover image -->
    <section class="rounded-2xl bg-surface-elevated border border-border p-5 sm:p-6 space-y-4">
        <h2 class="text-sm font-bold text-text-primary uppercase tracking-wider flex items-center gap-2">
            <i class="fa-solid fa-image text-primary text-xs"></i>
            {t("form.coverImage")}
        </h2>

        <input
            id="tf-cover-file"
            type="file"
            accept="image/jpeg,image/png,image/webp,image/gif,image/avif"
            class="sr-only"
            tabindex="-1"
        />

        <div
            id="tf-cover-box"
            class="relative aspect-4/3 max-w-sm rounded-xl overflow-hidden bg-surface border border-border transition-colors"
        >
            <img
                id="tf-cover-preview"
                alt={t("form.coverPreviewAlt")}
                class="w-full h-full object-cover"
                style="display:none;"
            />
            <button
                type="button"
                id="tf-cover-trigger"
                class="absolute inset-0 flex flex-col items-center justify-center gap-2 text-text-muted hover:text-text-secondary hover:bg-white/5 transition-colors cursor-pointer"
            >
                <i id="tf-cover-icon" class="fa-solid fa-cloud-arrow-up text-2xl"></i>
                <span id="tf-cover-cta" class="text-xs font-medium">{t("form.uploadCta")}</span>
                <span id="tf-cover-hint" class="text-[11px] text-text-muted/70">{t("form.uploadHint")}</span>
            </button>
            <div
                id="tf-cover-actions"
                class="absolute top-2 right-2 gap-1.5"
                style="display:none;"
            >
                <button
                    type="button"
                    id="tf-cover-replace"
                    class="w-9 h-9 rounded-lg bg-black/55 backdrop-blur-sm text-white/90 hover:bg-black/75 flex items-center justify-center transition-colors"
                    title={t("form.replaceImage")}
                    aria-label={t("form.replaceImage")}
                >
                    <i class="fa-solid fa-arrows-rotate text-sm"></i>
                </button>
                <button
                    type="button"
                    id="tf-cover-remove"
                    class="w-9 h-9 rounded-lg bg-black/55 backdrop-blur-sm text-white/90 hover:bg-red-500/80 flex items-center justify-center transition-colors"
                    title={t("form.removeImage")}
                    aria-label={t("form.removeImage")}
                >
                    <i class="fa-solid fa-trash-can text-sm"></i>
                </button>
            </div>
        </div>
        <p id="tf-cover-error" class="text-xs text-red-400 min-h-4"></p>
    </section>

    <!-- Options -->
    <section class="rounded-2xl bg-surface-elevated border border-border p-5 sm:p-6 space-y-4">
        <div class="flex items-center justify-between">
            <h2 class="text-sm font-bold text-text-primary uppercase tracking-wider flex items-center gap-2">
                <i class="fa-solid fa-layer-group text-primary text-xs"></i>
                {t("form.options")}
            </h2>
            <span class="text-xs font-medium text-text-muted">
                <span id="tf-option-count">0</span>/{MAX_OPTIONS}
                <span class="ml-2 text-text-muted/70">{t("form.optionsMin", { n: MIN_OPTIONS })}</span>
            </span>
        </div>
        <p class="text-xs text-text-muted -mt-2">
            {t("form.optionsHelp")}
        </p>

        <input
            id="tf-option-file"
            type="file"
            accept="image/jpeg,image/png,image/webp,image/gif,image/avif"
            class="sr-only"
            tabindex="-1"
        />

        <div id="tf-options" class="space-y-3">
            <!-- Rows rendered by client script -->
        </div>

        <button
            type="button"
            id="tf-add-option"
            class="w-full flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-dashed border-border hover:border-primary/50 text-sm font-medium text-text-secondary hover:text-primary transition-all"
        >
            <i class="fa-solid fa-plus text-xs"></i>
            {t("form.addOption")}
        </button>
    </section>

    <!-- Submit -->
    <div class="space-y-3">
        <p id="tf-error" class="text-sm text-red-400 min-h-5"></p>
        <button
            type="submit"
            id="tf-submit"
            class="w-full sm:w-auto px-8 py-3.5 rounded-xl font-bold text-sm uppercase tracking-wider text-[#1a1205] bg-gradient-to-r from-gold-start to-gold-end hover:opacity-90 transition-all disabled:opacity-40 disabled:cursor-not-allowed"
        >
            {mode === "create" ? t("form.submitCreate") : t("form.submitSave")}
        </button>
    </div>
</form>

<!-- Option row markup (cloned by the client script) -->
<template id="tf-option-row-template">
    <div class="option-row flex flex-wrap items-center gap-3 p-3 rounded-xl bg-surface border border-border">
        <div class="relative shrink-0">
            <button
                type="button"
                class="option-thumb w-12 h-12 rounded-lg overflow-hidden bg-surface-elevated border border-dashed border-border hover:border-primary/60 flex items-center justify-center transition-colors cursor-pointer"
                aria-label={t("form.optionAddImage")}
                title={t("form.optionAddImage")}
            >
                <img
                    class="option-thumb-img w-full h-full object-cover"
                    alt=""
                    style="display:none;"
                />
                <i class="option-thumb-icon fa-solid fa-camera text-text-muted text-sm"></i>
            </button>
            <button
                type="button"
                class="option-image-remove absolute -top-1.5 -right-1.5 w-5 h-5 rounded-full bg-surface-elevated border border-border text-text-muted hover:text-red-400 hover:border-red-400/60 items-center justify-center transition-colors"
                style="display:none;"
                aria-label={t("form.removeImage")}
                title={t("form.removeImage")}
            >
                <i class="fa-solid fa-xmark text-[10px]"></i>
            </button>
        </div>
        <input
            type="text"
            maxlength="80"
            placeholder={t("form.optionNamePlaceholder")}
            class="option-name flex-1 min-w-0 px-3 py-2.5 rounded-lg bg-surface-elevated border border-border text-sm text-text-primary placeholder:text-text-muted/60 focus:outline-none focus:border-primary/60 transition-all"
        />
        <button
            type="button"
            class="option-remove w-9 h-9 shrink-0 rounded-lg flex items-center justify-center text-text-muted hover:text-red-400 hover:bg-red-400/10 transition-all"
            aria-label={t("form.removeOption")}
        >
            <i class="fa-solid fa-xmark text-sm"></i>
        </button>
        <p class="option-error basis-full text-xs text-red-400 min-h-0 empty:hidden"></p>
    </div>
</template>

{
    mode === "create" && (
        <div
            id="tf-ai-modal"
            class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
            role="dialog"
            aria-modal="true"
            aria-labelledby="tf-ai-title"
        >
            <div
                class="absolute inset-0 bg-black/60 animate-modal-bg"
                id="tf-ai-backdrop"
            />
            <div class="relative bg-surface-elevated border border-border rounded-2xl p-6 max-w-md w-full animate-modal-content">
                <div class="space-y-4">
                    <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto">
                        <i class="fa-solid fa-wand-magic-sparkles text-primary text-xl" />
                    </div>
                    <h3 id="tf-ai-title" class="text-lg font-bold text-text-primary text-center">
                        {t("form.aiDiscoverTitle")}
                    </h3>
                    <p
                        id="tf-ai-copy"
                        class="text-sm text-text-secondary leading-relaxed text-center"
                    >
                        {t("form.aiRewriteCopy")}
                    </p>
                    <div>
                        <div class="flex items-center justify-end mb-2">
                            <span class="text-xs text-text-muted">
                                <span id="tf-ai-count">0</span>/300
                            </span>
                        </div>
                        <textarea
                            id="tf-ai-text"
                            maxlength="300"
                            rows="5"
                            class={inputClass + " resize-none"}
                        />
                        <p
                            id="tf-ai-error"
                            class="text-xs text-red-400 min-h-4 mt-1"
                        />
                    </div>
                    <div class="flex items-center gap-3 pt-1">
                        <button
                            type="button"
                            id="tf-ai-keep"
                            class="flex-1 px-4 py-2.5 rounded-xl border border-border text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors"
                        >
                            {t("form.aiKeepMine")}
                        </button>
                        <button
                            type="button"
                            id="tf-ai-use"
                            class="flex-1 px-4 py-2.5 rounded-xl text-sm font-bold text-[#1a1205] bg-gradient-to-r from-gold-start to-gold-end hover:opacity-90 transition-all"
                        >
                            {t("form.aiUseDescription")}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    )
}

<script
    type="application/json"
    id="template-form-data"
    set:html={JSON.stringify(initial).replace(/</g, "\\u003c")}
/>

<script>
    import { openModal, closeModal } from "../scripts/modal-a11y";
    import { uploadTemplateImage } from "../scripts/image-upload";
    import { clientT, getClientLocale } from "../i18n/client";
    import { localizePath } from "../i18n";

    document.addEventListener("astro:page-load", () => {
        const form = document.getElementById(
            "template-form",
        ) as HTMLFormElement | null;
        if (!form || form.dataset.bound) return;
        form.dataset.bound = "1";

        const t = clientT();

        const data = JSON.parse(
            document.getElementById("template-form-data")!.textContent || "{}",
        );

        const title = document.getElementById("tf-title") as HTMLInputElement;
        const titleCount = document.getElementById("tf-title-count")!;
        const desc = document.getElementById(
            "tf-description",
        ) as HTMLTextAreaElement;
        const descCount = document.getElementById("tf-desc-count")!;
        const category = document.getElementById(
            "tf-category",
        ) as HTMLSelectElement;
        const visibility = document.getElementById(
            "tf-visibility",
        ) as HTMLSelectElement;
        const visibilityHint = document.getElementById("tf-visibility-hint")!;
        const coverFile = document.getElementById(
            "tf-cover-file",
        ) as HTMLInputElement;
        const coverBox = document.getElementById("tf-cover-box")!;
        const coverPreview = document.getElementById(
            "tf-cover-preview",
        ) as HTMLImageElement;
        const coverTrigger = document.getElementById(
            "tf-cover-trigger",
        ) as HTMLButtonElement;
        const coverIcon = document.getElementById("tf-cover-icon")!;
        const coverCta = document.getElementById("tf-cover-cta")!;
        const coverHint = document.getElementById("tf-cover-hint")!;
        const coverActions = document.getElementById("tf-cover-actions")!;
        const coverError = document.getElementById("tf-cover-error")!;
        const optionFile = document.getElementById(
            "tf-option-file",
        ) as HTMLInputElement;
        const optionsEl = document.getElementById("tf-options")!;
        const optionCount = document.getElementById("tf-option-count")!;
        const addBtn = document.getElementById("tf-add-option")!;
        const rowTemplate = document.getElementById(
            "tf-option-row-template",
        ) as HTMLTemplateElement;
        const errorEl = document.getElementById("tf-error")!;
        const submit = document.getElementById(
            "tf-submit",
        ) as HTMLButtonElement;

        // ── Image uploads ────────────────────────────────────────────
        // Files go to POST /api/images (re-encode + moderation); the form
        // only ever stores the returned URL. `pendingUploads` blocks submit
        // while anything is still in flight.
        let pendingUploads = 0;

        function uploadErrorMessage(code: string): string {
            switch (code) {
                case "image_rejected":
                    return t("form.errImageRejected");
                case "too_large":
                    return t("form.errImageTooLarge");
                case "unsupported_type":
                    return t("form.errImageType");
                case "rate_limited":
                    return t("form.errImageRateLimited");
                default:
                    return t("form.errImageUpload");
            }
        }

        // ── Cover upload ─────────────────────────────────────────────
        let coverUrl: string = data.cover_image || "";

        function renderCover(state: "empty" | "uploading" | "set") {
            coverActions.style.display = state === "set" ? "flex" : "none";
            coverTrigger.style.display = state === "set" ? "none" : "";
            if (state === "set") {
                coverPreview.src = coverUrl;
                coverPreview.style.display = "";
                return;
            }
            coverPreview.style.display = "none";
            coverPreview.removeAttribute("src");
            if (state === "uploading") {
                coverIcon.className = "fa-solid fa-spinner btn-spinner text-2xl";
                coverCta.textContent = t("form.uploading");
                coverHint.style.display = "none";
            } else {
                coverIcon.className = "fa-solid fa-cloud-arrow-up text-2xl";
                coverCta.textContent = t("form.uploadCta");
                coverHint.style.display = "";
            }
        }

        async function handleCoverFile(file: File) {
            coverError.textContent = "";
            pendingUploads++;
            renderCover("uploading");
            const result = await uploadTemplateImage(file, "cover");
            pendingUploads--;
            if (result.ok) {
                coverUrl = result.url;
                renderCover("set");
            } else {
                renderCover(coverUrl ? "set" : "empty");
                coverError.textContent = uploadErrorMessage(result.error);
            }
        }

        coverTrigger.addEventListener("click", () => coverFile.click());
        document
            .getElementById("tf-cover-replace")!
            .addEventListener("click", () => coverFile.click());
        document.getElementById("tf-cover-remove")!.addEventListener(
            "click",
            () => {
                coverUrl = "";
                coverError.textContent = "";
                renderCover("empty");
            },
        );
        coverFile.addEventListener("change", () => {
            const file = coverFile.files?.[0];
            coverFile.value = "";
            if (file) handleCoverFile(file);
        });

        // Drag & drop onto the cover box.
        coverBox.addEventListener("dragover", (e) => {
            e.preventDefault();
            coverBox.classList.add("border-primary/60");
        });
        coverBox.addEventListener("dragleave", () =>
            coverBox.classList.remove("border-primary/60"),
        );
        coverBox.addEventListener("drop", (e) => {
            e.preventDefault();
            coverBox.classList.remove("border-primary/60");
            const file = e.dataTransfer?.files?.[0];
            if (file) handleCoverFile(file);
        });

        renderCover(coverUrl ? "set" : "empty");

        // ── Option image uploads ─────────────────────────────────────
        // One hidden file input shared by every row; a click on a thumb
        // remembers its row until the change event fires.
        let optionUploadRow: HTMLElement | null = null;

        optionFile.addEventListener("change", () => {
            const file = optionFile.files?.[0];
            optionFile.value = "";
            const row = optionUploadRow;
            optionUploadRow = null;
            if (file && row && row.isConnected) handleOptionFile(row, file);
        });

        function renderOptionThumb(row: HTMLElement) {
            const url = row.dataset.image || "";
            const uploading = row.dataset.uploading === "1";
            const thumb = row.querySelector<HTMLButtonElement>(".option-thumb")!;
            const img =
                row.querySelector<HTMLImageElement>(".option-thumb-img")!;
            const icon = row.querySelector<HTMLElement>(".option-thumb-icon")!;
            const removeBtn = row.querySelector<HTMLElement>(
                ".option-image-remove",
            )!;
            removeBtn.style.display = url && !uploading ? "flex" : "none";
            if (uploading) {
                img.style.display = "none";
                icon.style.display = "";
                icon.className =
                    "option-thumb-icon fa-solid fa-spinner btn-spinner text-text-muted text-sm";
            } else if (url) {
                img.src = url;
                img.style.display = "";
                icon.style.display = "none";
                thumb.title = t("form.replaceImage");
                thumb.setAttribute("aria-label", t("form.replaceImage"));
            } else {
                img.style.display = "none";
                img.removeAttribute("src");
                icon.style.display = "";
                icon.className =
                    "option-thumb-icon fa-solid fa-camera text-text-muted text-sm";
                thumb.title = t("form.optionAddImage");
                thumb.setAttribute("aria-label", t("form.optionAddImage"));
            }
        }

        async function handleOptionFile(row: HTMLElement, file: File) {
            const optionError =
                row.querySelector<HTMLElement>(".option-error")!;
            optionError.textContent = "";
            row.dataset.uploading = "1";
            pendingUploads++;
            renderOptionThumb(row);
            const result = await uploadTemplateImage(file, "option");
            pendingUploads--;
            delete row.dataset.uploading;
            if (!row.isConnected) return;
            if (result.ok) {
                row.dataset.image = result.url;
            } else {
                optionError.textContent = uploadErrorMessage(result.error);
            }
            renderOptionThumb(row);
        }

        // ── Option rows ──────────────────────────────────────────────
        function rows(): HTMLElement[] {
            return Array.from(optionsEl.querySelectorAll(".option-row"));
        }

        function updateCount() {
            const n = rows().length;
            optionCount.textContent = String(n);
            (addBtn as HTMLButtonElement).style.display =
                n >= data.maxOptions ? "none" : "";
        }

        function addRow(name = "", image = "", focus = false) {
            if (rows().length >= data.maxOptions) return;
            const row = (
                rowTemplate.content.cloneNode(true) as DocumentFragment
            ).firstElementChild as HTMLElement;
            const nameInput =
                row.querySelector<HTMLInputElement>(".option-name")!;
            nameInput.value = name;
            if (image) row.dataset.image = image;

            row.querySelector<HTMLButtonElement>(
                ".option-thumb",
            )!.addEventListener("click", () => {
                if (row.dataset.uploading === "1") return;
                optionUploadRow = row;
                optionFile.click();
            });

            row.querySelector<HTMLElement>(
                ".option-image-remove",
            )!.addEventListener("click", () => {
                delete row.dataset.image;
                row.querySelector<HTMLElement>(".option-error")!.textContent = "";
                renderOptionThumb(row);
            });

            row.querySelector(".option-remove")!.addEventListener(
                "click",
                () => {
                    row.remove();
                    updateCount();
                },
            );

            renderOptionThumb(row);
            optionsEl.appendChild(row);
            updateCount();
            if (focus) nameInput.focus();
        }

        addBtn.addEventListener("click", () => addRow("", "", true));

        // Initial rows: existing options (edit) or MIN empty rows (create).
        if (data.options.length > 0) {
            data.options.forEach((o: { name: string; image: string }) =>
                addRow(o.name, o.image),
            );
        } else {
            for (let i = 0; i < data.minOptions; i++) addRow();
        }

        // ── Char counters ────────────────────────────────────────────
        function bindCounter(
            el: HTMLInputElement | HTMLTextAreaElement,
            counter: HTMLElement,
        ) {
            const update = () => (counter.textContent = String(el.value.length));
            el.addEventListener("input", update);
            update();
        }
        bindCounter(title, titleCount);
        bindCounter(desc, descCount);

        // ── Visibility hint ──────────────────────────────────────────
        function updateVisibilityHint() {
            const selected = visibility.selectedOptions[0];
            let hint = selected?.dataset.hint || "";
            // Editing into unlisted regenerates the slug — warn about it,
            // since the edit page promises the URL stays the same otherwise.
            if (
                data.mode === "edit" &&
                visibility.value === "unlisted" &&
                data.visibility !== "unlisted"
            ) {
                hint += t("form.visibilityUnlistedSlugWarning");
            }
            visibilityHint.textContent = hint;
        }
        visibility.addEventListener("change", updateVisibilityHint);
        updateVisibilityHint();

        // ── Submit ───────────────────────────────────────────────────
        function validate(skipDescLength = false): string | null {
            if (pendingUploads > 0) return t("form.errUploadsPending");
            if (title.value.trim().length < 3) return t("form.errTitle");
            // Description, category and cover image are only required for
            // public templates; private/unlisted may skip them.
            const isPublic = visibility.value === "public";
            if (isPublic && !skipDescLength && desc.value.trim().length < 15)
                return t("form.errDescription");
            if (isPublic && !category.value) return t("form.errCategory");
            if (!coverUrl && isPublic) return t("form.errCoverRequired");
            const opts = rows();
            const named = opts.filter(
                (r) =>
                    r
                        .querySelector<HTMLInputElement>(".option-name")!
                        .value.trim().length > 0,
            );
            if (named.length < data.minOptions)
                return t("form.errMinOptions", { n: data.minOptions });
            for (const r of opts) {
                const name = r
                    .querySelector<HTMLInputElement>(".option-name")!
                    .value.trim();
                if (!name && r.dataset.image)
                    return t("form.errOptionNameNeeded");
            }
            return null;
        }

        type Payload = {
            title: string;
            description: string;
            category: string;
            cover_image: string;
            visibility: string;
            options: { name: string; image: string | null }[];
        };

        const originalLabel = submit.textContent;

        function setBusy(busy: boolean) {
            submit.disabled = busy;
            if (busy) {
                const label =
                    data.mode === "create"
                        ? t("form.busyCreating")
                        : t("form.busySaving");
                // Spinner + text so a slow request shows visible motion, not
                // just a static label.
                submit.innerHTML = `<span class="inline-flex items-center justify-center gap-2"><i class="fa-solid fa-spinner btn-spinner"></i>${label}</span>`;
            } else {
                submit.textContent = originalLabel;
            }
        }

        async function actuallySubmit(payload: Payload) {
            setBusy(true);
            try {
                const res = await fetch(
                    data.mode === "create"
                        ? "/api/templates"
                        : `/api/templates/${data.id}`,
                    {
                        method: data.mode === "create" ? "POST" : "PUT",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload),
                    },
                );
                const result = await res.json();
                if (res.ok && result.ok) {
                    window.location.href = localizePath(
                        `/template/${result.slug}`,
                        getClientLocale(),
                    );
                    return;
                }
                errorEl.textContent = result.error || t("common.genericError");
            } catch {
                errorEl.textContent = t("common.networkError");
            }
            setBusy(false);
        }

        // ── AI description suggestion (create mode only) ────────────
        // Asked at most once per form session; the suggestion is cached so
        // a cancelled modal re-opens instantly. Any failure (timeout, 429,
        // 5xx) falls through to a normal submit — never blocks creation.
        type Suggestion = { description: string; mode: string };

        const aiModal = document.getElementById("tf-ai-modal");
        const aiTitleEl = document.getElementById("tf-ai-title");
        const aiText = document.getElementById(
            "tf-ai-text",
        ) as HTMLTextAreaElement | null;
        const aiCount = document.getElementById("tf-ai-count");
        const aiCopy = document.getElementById("tf-ai-copy");
        const aiError = document.getElementById("tf-ai-error");
        const aiKeepBtn = document.getElementById(
            "tf-ai-keep",
        ) as HTMLButtonElement | null;
        let aiAsked = false;
        let aiSuggestion: Suggestion | null = null;
        let pendingPayload: Payload | null = null;
        // "discover": description is valid, we pitch a more discoverable one.
        // "short": description is below the 15-char minimum, AI fills the gap.
        let aiModalKind: "discover" | "short" = "discover";

        if (aiText && aiCount) bindCounter(aiText, aiCount);

        async function fetchSuggestion(
            payload: Payload,
        ): Promise<Suggestion | null> {
            try {
                const res = await fetch("/api/templates/describe", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        title: payload.title,
                        category: payload.category,
                        options: payload.options.map((o) => o.name),
                        draft: payload.description,
                    }),
                    signal: AbortSignal.timeout(12000),
                });
                if (!res.ok) return null;
                const result = await res.json();
                return result.ok && typeof result.description === "string"
                    ? {
                          description: result.description,
                          mode: result.mode === "polish" ? "polish" : "rewrite",
                      }
                    : null;
            } catch {
                return null;
            }
        }

        function openAiModal(
            suggestion: Suggestion,
            payload: Payload,
            kind: "discover" | "short" = "discover",
        ) {
            pendingPayload = payload;
            aiModalKind = kind;
            if (kind === "short") {
                aiTitleEl!.textContent = t("form.aiShortTitle");
                aiCopy!.textContent = t("form.aiShortCopy");
                if (aiKeepBtn) aiKeepBtn.textContent = t("form.aiWriteMyOwn");
            } else {
                aiTitleEl!.textContent = t("form.aiDiscoverTitle");
                aiCopy!.textContent =
                    suggestion.mode === "polish"
                        ? t("form.aiPolishCopy")
                        : t("form.aiRewriteCopy");
                if (aiKeepBtn) aiKeepBtn.textContent = t("form.aiKeepMine");
            }
            aiText!.value = suggestion.description;
            aiText!.dispatchEvent(new Event("input"));
            aiError!.textContent = "";
            // Closing by Escape/backdrop must re-enable the submit button.
            openModal(aiModal!, { focus: aiText, onClose: () => setBusy(false) });
        }

        function closeAiModal() {
            closeModal(aiModal!);
        }

        document.getElementById("tf-ai-use")?.addEventListener("click", () => {
            const edited = aiText!.value.trim();
            if (edited.length < 15) {
                aiError!.textContent = t("form.aiMinChars");
                return;
            }
            // Keep the editor in sync so the text survives a failed submit.
            desc.value = edited;
            desc.dispatchEvent(new Event("input"));
            closeAiModal();
            actuallySubmit({ ...pendingPayload!, description: edited });
        });

        aiKeepBtn?.addEventListener("click", () => {
            closeAiModal();
            // Short mode: there's nothing valid to keep — send them back to
            // the editor to write their own instead of submitting.
            if (aiModalKind === "short") {
                desc.focus();
                return;
            }
            actuallySubmit(pendingPayload!);
        });

        document
            .getElementById("tf-ai-backdrop")
            ?.addEventListener("click", () => {
                closeAiModal();
                setBusy(false);
            });

        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            errorEl.textContent = "";

            // A too-short description routes to the AI modal instead of a
            // plain error — but only in create mode, where the modal exists.
            const descShort = desc.value.trim().length < 15;
            // The AI description assist (both the "short" and "discover"
            // modals) is only offered for public templates.
            const canAiAssist =
                data.mode === "create" &&
                !!aiModal &&
                !!aiText &&
                visibility.value === "public";

            const problem = validate(descShort && canAiAssist);
            if (problem) {
                errorEl.textContent = problem;
                return;
            }

            const payload: Payload = {
                title: title.value.trim(),
                description: desc.value.trim(),
                category: category.value,
                cover_image: coverUrl,
                visibility: visibility.value,
                options: rows()
                    .map((r) => ({
                        name: r
                            .querySelector<HTMLInputElement>(".option-name")!
                            .value.trim(),
                        image: r.dataset.image || null,
                    }))
                    .filter((o) => o.name),
            };

            // Too-short description: offer an AI-written one (any visibility).
            // If the AI is unavailable, fall back to the plain requirement.
            if (descShort && canAiAssist) {
                setBusy(true);
                if (!aiAsked) {
                    aiAsked = true;
                    aiSuggestion = await fetchSuggestion(payload);
                }
                if (aiSuggestion) {
                    openAiModal(aiSuggestion, payload, "short");
                    return;
                }
                setBusy(false);
                errorEl.textContent = t("form.errDescription");
                desc.focus();
                return;
            }

            // Discoverability pitch only makes sense for public templates.
            if (canAiAssist) {
                setBusy(true);
                if (!aiAsked) {
                    aiAsked = true;
                    aiSuggestion = await fetchSuggestion(payload);
                }
                if (
                    aiSuggestion &&
                    aiSuggestion.description !== payload.description
                ) {
                    openAiModal(aiSuggestion, payload, "discover");
                    return;
                }
            }

            await actuallySubmit(payload);
        });
    });
</script>
