---
// Footer.astro — Full footer with social, pages, categories, legal sections
import {
    defaultLocale,
    localeNames,
    locales,
    localizePath,
    unlocalizePath,
    useTranslations,
} from "../i18n";

const locale = Astro.locals.locale ?? defaultLocale;
const t = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);

const year = new Date().getFullYear();
// Base (unprefixed) path for the language switcher links; refreshed on the
// client on every navigation (the footer is transition:persist).
const basePath = unlocalizePath(Astro.url.pathname);
---

<footer
    transition:persist
    transition:name="site-footer"
    transition:animate="none"
    class="border-t border-border/50 bg-surface-elevated/50 mt-auto"
>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-10 lg:gap-16">
            <!-- Col 1: Brand + Social -->
            <div class="col-span-2 md:col-span-1 space-y-6">
                <a href={L("/")} class="inline-block max-w-full">
                    <img
                        src="/RANKMAKER-logo.webp"
                        alt="RANKMAKER"
                        class="h-7 w-auto max-w-full object-contain"
                    />
                </a>
                <p class="text-sm text-text-muted leading-relaxed">
                    {t("footer.tagline")}
                </p>
                <div class="flex items-center justify-between">
                    <a
                        href="https://www.instagram.com/rankmaker_/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-9 h-9 rounded-lg bg-white/5 hover:bg-primary/20 flex items-center justify-center text-text-muted hover:text-primary transition-all"
                        aria-label="Instagram"
                    >
                        <i class="fa-brands fa-instagram"></i>
                    </a>
                    <a
                        href="https://www.tiktok.com/@rankmaker_"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-9 h-9 rounded-lg bg-white/5 hover:bg-primary/20 flex items-center justify-center text-text-muted hover:text-primary transition-all"
                        aria-label="TikTok"
                    >
                        <i class="fa-brands fa-tiktok"></i>
                    </a>
                    <a
                        href="https://x.com/RANKMAKER_"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-9 h-9 rounded-lg bg-white/5 hover:bg-primary/20 flex items-center justify-center text-text-muted hover:text-primary transition-all"
                        aria-label="X"
                    >
                        <i class="fa-brands fa-x-twitter"></i>
                    </a>
                    <a
                        href="https://www.youtube.com/channel/UCEmHgu_LtKODJuEGU0XtpvQ"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-9 h-9 rounded-lg bg-white/5 hover:bg-primary/20 flex items-center justify-center text-text-muted hover:text-primary transition-all"
                        aria-label="YouTube"
                    >
                        <i class="fa-brands fa-youtube"></i>
                    </a>
                    <a
                        href="https://www.reddit.com/user/RANKMAKERnet/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-9 h-9 rounded-lg bg-white/5 hover:bg-primary/20 flex items-center justify-center text-text-muted hover:text-primary transition-all"
                        aria-label="Reddit"
                    >
                        <i class="fa-brands fa-reddit-alien"></i>
                    </a>
                </div>
                <div class="pt-2">
                    <a
                        href="https://github.com/martinezharo/rankmaker"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex w-full items-center justify-center gap-3 px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 hover:border-primary/50 transition-all group"
                    >
                        <i
                            class="fa-brands fa-github text-xl text-text-secondary group-hover:text-primary transition-colors"
                        ></i>
                        <div class="flex flex-col">
                            <span
                                class="text-[10px] uppercase tracking-widest text-text-muted font-bold"
                                >{t("footer.openSource")}</span
                            >
                            <span
                                class="text-xs text-text-secondary group-hover:text-text-primary transition-colors"
                                >{t("footer.contributeHere")}</span
                            >
                        </div>
                    </a>
                </div>
            </div>

            <!-- Col 2: Pages -->
            <div class="space-y-4">
                <h2
                    class="text-xs font-semibold uppercase tracking-widest text-text-muted"
                >
                    {t("footer.pages")}
                </h2>
                <ul class="space-y-2.5">
                    <li>
                        <a
                            href={L("/")}
                            class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                            >{t("nav.home")}</a
                        >
                    </li>
                    <li>
                        <a
                            href={L("/search")}
                            class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                            >{t("nav.findTemplates")}</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Col 3: Information -->
            <div class="space-y-4">
                <h2
                    class="text-xs font-semibold uppercase tracking-widest text-text-muted"
                >
                    {t("footer.information")}
                </h2>
                <ul class="space-y-2.5">
                    <li>
                        <a
                            href={L("/about")}
                            class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                            >{t("footer.aboutUs")}</a
                        >
                    </li>
                    <li>
                        <a
                            href={L("/contact")}
                            class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                            >{t("footer.contact")}</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Col 4: Legal -->
            <div class="space-y-4">
                <h2
                    class="text-xs font-semibold uppercase tracking-widest text-text-muted"
                >
                    {t("footer.legal")}
                </h2>
                <ul class="space-y-2.5">
                    <li>
                        <a
                            href={L("/privacy-policy")}
                            class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                            >{t("footer.privacyPolicy")}</a
                        >
                    </li>
                    <li>
                        <a
                            href={L("/terms-of-use")}
                            class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                            >{t("footer.termsOfUse")}</a
                        >
                    </li>
                    <li>
                        <a
                            href={L("/cookie-policy")}
                            class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                            >{t("footer.cookiePolicy")}</a
                        >
                    </li>
                    <li>
                        <a
                            href={L("/legal-notice")}
                            class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                            >{t("footer.legalNotice")}</a
                        >
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bottom bar: copyright + language switcher -->
        <div
            class="mt-12 pt-8 border-t border-border/50 flex flex-col sm:flex-row items-center justify-between gap-6"
        >
            <p class="text-xs text-text-muted order-2 sm:order-1">
                © {year} RANKMAKER
            </p>

            <!-- Language switcher — hrefs refreshed on the client since the
                 footer is transition:persist. -->
            <div
                class="lang-switcher relative order-1 sm:order-2 w-full sm:w-auto sm:min-w-[200px]"
            >
                <button
                    type="button"
                    class="lang-switcher-btn w-full inline-flex items-center justify-between gap-2 px-4 py-2.5 rounded-xl text-sm font-medium text-text-secondary hover:text-text-primary border border-border hover:border-border-hover transition-all"
                    aria-haspopup="true"
                    aria-expanded="false"
                    aria-label={`${t("nav.language")}: ${localeNames[locale]}`}
                >
                    <span class="flex items-center gap-2">
                        <i class="fa-solid fa-globe text-xs"></i>
                        <span class="lang-current-name"
                            >{localeNames[locale]}</span
                        >
                    </span>
                    <i
                        class="fa-solid fa-chevron-down text-[10px] text-text-muted transition-transform lang-chevron"
                    ></i>
                </button>
                <div
                    class="lang-menu absolute left-0 right-0 bottom-full mb-2 rounded-xl bg-surface-elevated border border-border shadow-xl shadow-black/40 py-1.5 z-50"
                    style="display:none;"
                >
                    {
                        locales.map((loc) => (
                            <a
                                href={localizePath(basePath, loc)}
                                hreflang={loc}
                                data-lang={loc}
                                data-astro-reload
                                class={`lang-option flex items-center justify-between px-4 py-2.5 text-sm transition-colors hover:bg-white/5 ${loc === locale ? "text-text-primary font-medium" : "text-text-secondary hover:text-text-primary"}`}
                            >
                                {localeNames[loc]}
                                {loc === locale && (
                                    <i class="fa-solid fa-check text-primary text-xs" />
                                )}
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</footer>

<script>
    import { getClientLocale } from "../i18n/client";
    import { localizePath, unlocalizePath, localeNames } from "../i18n";

    // The footer is transition:persist, so the language switcher links (and the
    // current-locale label) are rendered once and must be refreshed on every
    // navigation to point at the localized variant of the *current* page.
    function refreshLangLinks() {
        const locale = getClientLocale();
        const base =
            unlocalizePath(window.location.pathname) +
            window.location.search +
            window.location.hash;
        document
            .querySelectorAll<HTMLAnchorElement>(".lang-option")
            .forEach((a) => {
                const loc = a.dataset.lang;
                if (loc) a.href = localizePath(base, loc as any);
            });
        document
            .querySelectorAll<HTMLElement>(".lang-current-name")
            .forEach(
                (el) =>
                    (el.textContent =
                        localeNames[locale as keyof typeof localeNames] ??
                        locale),
            );
    }

    function closeLangMenus() {
        document
            .querySelectorAll<HTMLElement>(".lang-menu")
            .forEach((m) => (m.style.display = "none"));
        document
            .querySelectorAll<HTMLElement>(".lang-chevron")
            .forEach((c) => (c.style.transform = ""));
        document
            .querySelectorAll<HTMLElement>(".lang-switcher-btn")
            .forEach((b) => b.setAttribute("aria-expanded", "false"));
    }

    function bindLangSwitchers() {
        document
            .querySelectorAll<HTMLElement>(".lang-switcher-btn")
            .forEach((btn) => {
                if (btn.dataset.bound) return;
                btn.dataset.bound = "1";
                const menu =
                    btn.parentElement?.querySelector<HTMLElement>(".lang-menu");
                const chevron = btn.querySelector<HTMLElement>(".lang-chevron");
                if (!menu) return;
                btn.addEventListener("click", (e) => {
                    e.stopPropagation();
                    const isOpen = menu.style.display !== "none";
                    closeLangMenus();
                    if (!isOpen) {
                        menu.style.display = "";
                        btn.setAttribute("aria-expanded", "true");
                        if (chevron) chevron.style.transform = "rotate(180deg)";
                    }
                });
            });
    }

    document.addEventListener("astro:page-load", () => {
        refreshLangLinks();
        bindLangSwitchers();
        closeLangMenus();
    });

    // Close the menu when clicking outside the switcher. Bound once (the footer
    // persists across view transitions).
    document.addEventListener("click", () => closeLangMenus());
</script>
