---
// RecommendedTemplates.astro — single blended row of similar/related templates
// shown at the foot of a template page (visible under all three views).
import TemplateCard from "./TemplateCard.astro";
import type { Template } from "../lib/templates";

interface Props {
	templates: Template[];
}

const { templates } = Astro.props;

if (templates.length === 0) return;
---

<section
	data-recommended
	class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-10 border-t border-border/50"
>
	<!-- Section Header -->
	<div class="flex items-center gap-3 mb-5">
		<div
			class="w-9 h-9 rounded-xl bg-primary/10 flex items-center justify-center shrink-0"
		>
			<i class="fa-solid fa-wand-magic-sparkles text-primary text-sm"></i>
		</div>
		<h2 class="text-lg font-bold text-text-primary tracking-tight">
			You might also like
		</h2>
		<div class="flex-1 h-px bg-border/50 ml-2"></div>
	</div>

	<!-- Cards: horizontal drag-scroll on mobile, wrapping grid on desktop -->
	<div
		class="flex gap-4 overflow-x-auto scrollbar-hide pb-2 snap-x snap-mandatory md:grid md:grid-cols-4 md:gap-5 md:overflow-x-visible md:snap-none"
	>
		{
			templates.map((template) => (
				<div
					data-rec-slug={template.slug}
					class="min-w-[70vw] sm:min-w-[45vw] md:min-w-0 snap-start"
				>
					<TemplateCard template={template} />
				</div>
			))
		}
	</div>
</section>

<script>
	// Hide templates this visitor has already played from the row, then trim to
	// a full row of 8. Played set = localStorage (anonymous + same device) ∪ the
	// logged-in user's server-side plays. The SSR over-fetches (12) so the row
	// stays full after hiding. Fails open — show everything on error.
	import { getPlayedSlugs } from "../scripts/history";

	const VISIBLE = 8;

	async function filterPlayed() {
		const section =
			document.querySelector<HTMLElement>("[data-recommended]");
		if (!section) return;

		const played = (() => {
			try {
				return getPlayedSlugs();
			} catch {
				return new Set<string>();
			}
		})();
		try {
			const res = await fetch("/api/me/history");
			if (res.ok) {
				const data = (await res.json()) as { slugs?: string[] };
				(data.slugs ?? []).forEach((s) => played.add(s));
			}
		} catch {
			/* anonymous or offline — localStorage set is enough */
		}

		let shown = 0;
		section
			.querySelectorAll<HTMLElement>("[data-rec-slug]")
			.forEach((card) => {
				const slug = card.dataset.recSlug ?? "";
				const hide = played.has(slug) || shown >= VISIBLE;
				card.style.display = hide ? "none" : "";
				if (!hide) shown++;
			});
		// If every recommendation was played, drop the empty row entirely.
		if (shown === 0) section.style.display = "none";
	}

	document.addEventListener("astro:page-load", filterPlayed);
</script>
