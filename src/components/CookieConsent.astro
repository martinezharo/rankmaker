---
import { defaultLocale, localizePath, useTranslations } from "../i18n";

const locale = Astro.locals.locale ?? defaultLocale;
const t = useTranslations(locale);
---

<div
    id="cookie-banner"
    class="fixed bottom-6 right-6 z-50 max-w-sm w-[calc(100%-3rem)] bg-surface-elevated border border-border rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.5)] p-5 transform translate-y-20 opacity-0 transition-all duration-500 pointer-events-none"
    role="alert"
>
    <div class="flex flex-col gap-4">
        <div class="flex items-start gap-3">
            <div
                class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0"
            >
                <i class="fa-solid fa-cookie-bite text-primary text-lg"></i>
            </div>
            <div class="space-y-1">
                <h3 class="text-sm font-bold text-text-primary">
                    {t("cookie.title")}
                </h3>
                <p class="text-xs text-text-secondary leading-relaxed">
                    {t("cookie.body")}
                </p>
            </div>
        </div>

        <div class="flex items-center gap-3 pt-1">
            <button
                id="accept-cookies"
                class="flex-1 py-2 rounded-xl bg-primary hover:bg-primary-light text-white text-xs font-bold transition-all active:scale-95"
            >
                {t("cookie.accept")}
            </button>
            <button
                id="reject-cookies"
                class="flex-1 py-2 rounded-xl border border-border hover:bg-white/5 text-xs font-medium text-text-secondary hover:text-text-primary transition-all active:scale-95"
            >
                {t("cookie.reject")}
            </button>
            <a
                href={localizePath("/cookie-policy", locale)}
                class="px-4 py-2 rounded-xl border border-border hover:bg-white/5 text-xs text-text-muted hover:text-text-primary transition-all text-center"
            >
                {t("cookie.policy")}
            </a>
        </div>
    </div>
</div>

<script is:inline>
    (function () {
        const STORAGE_KEY = "rankmaker_cookie_consent";
        const GA_ID = "G-LER7ZFV5BV";

        // Inject Google Analytics only after the user has accepted. Guarded on
        // window so repeated astro:page-load runs never double-load gtag.
        function loadAnalytics() {
            if (window.__rmAnalyticsLoaded) return;
            window.__rmAnalyticsLoaded = true;
            const s = document.createElement("script");
            s.async = true;
            s.src = "https://www.googletagmanager.com/gtag/js?id=" + GA_ID;
            document.head.appendChild(s);
            window.dataLayer = window.dataLayer || [];
            window.gtag = function () {
                window.dataLayer.push(arguments);
            };
            window.gtag("js", new Date());
            window.gtag("config", GA_ID);
        }

        function hide(banner) {
            banner.classList.add(
                "translate-y-20",
                "opacity-0",
                "pointer-events-none",
            );
        }

        function initBanner() {
            const banner = document.getElementById("cookie-banner");
            const acceptBtn = document.getElementById("accept-cookies");
            const rejectBtn = document.getElementById("reject-cookies");
            if (!banner || !acceptBtn || !rejectBtn) return;

            const consent = localStorage.getItem(STORAGE_KEY);
            if (consent === "true") {
                loadAnalytics();
                return; // already decided — keep the banner hidden
            }
            if (consent === "false") return;

            // No decision yet — reveal the banner after a short delay.
            setTimeout(() => {
                banner.classList.remove(
                    "translate-y-20",
                    "opacity-0",
                    "pointer-events-none",
                );
            }, 1000);

            // Bind once (the banner element persists within a page session).
            if (banner.dataset.bound) return;
            banner.dataset.bound = "1";
            acceptBtn.addEventListener("click", () => {
                localStorage.setItem(STORAGE_KEY, "true");
                hide(banner);
                loadAnalytics();
            });
            rejectBtn.addEventListener("click", () => {
                localStorage.setItem(STORAGE_KEY, "false");
                hide(banner);
            });
        }

        // Run on initial load and re-run on Astro view transitions.
        initBanner();
        document.addEventListener("astro:page-load", initBanner);
    })();
</script>
