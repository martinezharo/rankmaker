---
import { defaultLocale, useTranslations } from "../i18n";

const locale = Astro.locals.locale ?? defaultLocale;
const t = useTranslations(locale);

// Interactive hero demo: a 4-option mini ranking that auto-plays (or lets the
// visitor tap a card to decide the round) and ends on a mini results list,
// mirroring the real battle/results views in miniature. All four images are
// rendered stacked inside each card and toggled by opacity, so switching
// duels never waits on a network fetch (no flash).
const demoItems = [
	{ name: t("home.demoStarWars"), image: "/hero/star-wars.webp" },
	{ name: t("home.demoMarvel"), image: "/hero/marvel.webp" },
	{ name: t("home.demoHarryPotter"), image: "/hero/harry-potter.webp" },
	{ name: t("home.demoLotr"), image: "/hero/lotr.webp" },
];
const clientItems = demoItems.map((item, idx) => ({ idx, ...item }));
---

<div class="relative w-full max-w-md mx-auto lg:max-w-lg">
	<!-- Back glow -->
	<div
		class="absolute -inset-8 bg-primary/10 blur-3xl rounded-[3rem] pointer-events-none"
	>
	</div>

	<div
		id="hero-demo"
		class="relative rounded-2xl border border-border bg-surface-elevated/90 backdrop-blur-xl p-4 sm:p-5 shadow-2xl shadow-black/40"
	>
		<!-- Mini top bar (mirrors the battle top bar) -->
		<div class="flex items-center justify-between gap-3 mb-2">
			<div class="flex items-baseline gap-2 min-w-0">
				<span
					id="hero-demo-label-battle"
					class="text-[10px] uppercase tracking-widest font-semibold text-text-muted"
					>{t("ranking.rankingLabel")}</span
				>
				<span
					id="hero-demo-label-results"
					class="hidden text-[10px] uppercase tracking-widest font-semibold text-gradient-gold"
					>{t("ranking.results")}</span
				>
				<span class="text-sm font-bold text-text-primary truncate"
					>{t("home.demoTitle")}</span
				>
			</div>
			<span
				id="hero-demo-counter"
				class="text-[11px] font-semibold text-text-secondary tabular-nums whitespace-nowrap"
				>1 / 5</span
			>
		</div>
		<div class="h-1.5 rounded-full bg-border overflow-hidden mb-4">
			<div
				id="hero-demo-bar"
				class="h-full bg-gradient-to-r from-primary to-primary-light rounded-full transition-all duration-500"
				style="width: 0%"
			>
			</div>
		</div>

		<!-- Mini battle arena -->
		<div id="hero-demo-battle">
			<div class="relative flex items-stretch gap-3">
				{
					/* The first duel (items 0 vs 1) is pre-rendered so the cards
					   are never empty before the script takes over. */
					["a", "b"].map((side, sideIdx) => (
						<button
							id={`hero-demo-card-${side}`}
							type="button"
							aria-label={demoItems[sideIdx].name}
							class="group flex-1 min-w-0 flex flex-col rounded-xl bg-surface border-2 border-border hover:border-primary/60 transition-all duration-200 overflow-hidden cursor-pointer active:scale-[0.97]"
						>
							<div class="relative aspect-square overflow-hidden bg-surface">
								<img
									src={demoItems[sideIdx].image}
									alt=""
									data-demo-photo
									width="512"
									height="512"
									decoding="async"
									fetchpriority="high"
									class="w-full h-full object-cover transition-all duration-200 group-hover:scale-105"
								/>
							</div>
							<div class="flex-1 flex items-center justify-center px-2 py-2.5 min-h-12 border-t border-border/60">
								<span
									data-demo-name
									class="text-xs sm:text-sm font-bold text-text-primary text-center leading-tight line-clamp-2"
								>
									{demoItems[sideIdx].name}
								</span>
							</div>
						</button>
					))
				}

				<!-- VS badge -->
				<div
					class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10 pointer-events-none"
				>
					<div
						class="w-9 h-9 rounded-full bg-surface border-2 border-primary/40 flex items-center justify-center animate-vs-pulse"
					>
						<span class="text-xs font-black uppercase text-gradient-gold"
							>{t("ranking.vs")}</span
						>
					</div>
				</div>
			</div>
			<p class="mt-3.5 text-xs text-text-muted text-center">
				{t("ranking.tapPreferred")}
			</p>
		</div>

		<!-- Mini results (mirrors the full-ranking list) -->
		<div id="hero-demo-results" class="hidden flex-col justify-center">
			<div id="hero-demo-list" class="space-y-2"></div>
		</div>
	</div>
</div>

<script
	type="application/json"
	id="hero-demo-data"
	is:inline
	set:html={JSON.stringify(clientItems)}
/>

<script>
	// Bundled module: runs once; `astro:page-load` re-runs heroDemoInit on
	// every View Transitions navigation (and the initial load). The generation
	// token invalidates timers left over from a previous page instance.
	interface DemoItem {
		idx: number;
		name: string;
		image: string;
	}

	let generation = 0;

	const esc = (s: string) =>
		s.replace(
			/[&<>"']/g,
			(c) =>
				({
					"&": "&amp;",
					"<": "&lt;",
					">": "&gt;",
					'"': "&quot;",
					"'": "&#39;",
				})[c] as string,
		);

	// Step-driven merge sort of exactly 4 items: sort both pairs, then merge.
	// 4–5 comparisons per run; choose() returns the final order when done.
	function makeSorter(arr: DemoItem[]) {
		let stage = 0;
		let left: DemoItem[] = [];
		let right: DemoItem[] = [];
		const merged: DemoItem[] = [];
		let i = 0;
		let j = 0;
		return {
			current(): [DemoItem, DemoItem] {
				if (stage === 0) return [arr[0], arr[1]];
				if (stage === 1) return [arr[2], arr[3]];
				return [left[i], right[j]];
			},
			choose(side: 0 | 1): DemoItem[] | null {
				const [x, y] = this.current();
				const w = side === 0 ? x : y;
				const l = side === 0 ? y : x;
				if (stage === 0) {
					left = [w, l];
					stage = 1;
					return null;
				}
				if (stage === 1) {
					right = [w, l];
					stage = 2;
					return null;
				}
				if (w === left[i]) i++;
				else j++;
				merged.push(w);
				if (i >= left.length) return merged.concat(right.slice(j));
				if (j >= right.length) return merged.concat(left.slice(i));
				return null;
			},
		};
	}

	function heroDemoInit() {
		const token = ++generation;
		const root = document.getElementById("hero-demo");
		const dataEl = document.getElementById("hero-demo-data");
		if (!root || !dataEl) return;

		let items: DemoItem[];
		try {
			items = JSON.parse(dataEl.textContent || "[]");
		} catch {
			return;
		}
		if (!Array.isArray(items) || items.length !== 4) return;

		// Only the first visible duel is in the HTML. Warm the remaining demo
		// images after the browser has handled first paint/input so the hero does
		// not compete with six hidden image downloads on the critical path.
		const warmDemoImages = () => {
			for (const item of items.slice(2)) {
				const img = new Image();
				img.decoding = "async";
				img.src = item.image;
			}
		};
		const idle = (window as any).requestIdleCallback as
			| ((cb: () => void, opts?: { timeout: number }) => number)
			| undefined;
		if (idle) idle(warmDemoImages, { timeout: 2500 });
		else window.setTimeout(warmDemoImages, 1200);

		const battleEl = document.getElementById("hero-demo-battle");
		const resultsEl = document.getElementById("hero-demo-results");
		const listEl = document.getElementById("hero-demo-list");
		const barEl = document.getElementById("hero-demo-bar");
		const counterEl = document.getElementById("hero-demo-counter");
		const labelBattle = document.getElementById("hero-demo-label-battle");
		const labelResults = document.getElementById("hero-demo-label-results");
		const cardA = document.getElementById("hero-demo-card-a");
		const cardB = document.getElementById("hero-demo-card-b");
		if (
			!battleEl ||
			!resultsEl ||
			!listEl ||
			!barEl ||
			!counterEl ||
			!labelBattle ||
			!labelResults ||
			!cardA ||
			!cardB
		)
			return;

		const cards = [cardA, cardB];
		const alive = () => token === generation;
		const TOTAL = 5;
		const GLOW_HOLD = 550;
		const FADE = 200;
		const MEDALS = ["medal-gold", "medal-silver", "medal-bronze"];

		function renderResultsList(ranked: DemoItem[], animate: boolean) {
			listEl!.innerHTML = ranked
				.map((item, idx) => {
					const rowTone =
						idx < 3
							? "bg-primary/5 border border-primary/15"
							: "bg-surface border border-border";
					const badge =
						idx < 3
							? MEDALS[idx]
							: "rounded-full bg-border/40 text-text-secondary";
					const anim = animate
						? ` animate-rank-slide" style="animation-delay:${idx * 0.09}s`
						: "";
					return `
				<div class="flex items-center gap-2.5 p-2 pr-3 rounded-xl ${rowTone}${anim}">
					<div class="w-6 h-6 flex items-center justify-center text-[10px] font-black shrink-0 ${badge}">${idx + 1}</div>
					<div class="w-8 h-8 rounded-lg overflow-hidden bg-surface shrink-0">
						<img src="${esc(item.image)}" alt="" class="w-full h-full object-cover" />
					</div>
					<span class="text-xs sm:text-sm font-semibold text-text-primary truncate">${esc(item.name)}</span>
					${idx === 0 ? `<i class="fa-solid fa-crown text-amber-400 text-sm ml-auto${animate ? ' animate-crown" style="animation-delay:0.5s' : ""}"></i>` : ""}
				</div>`;
				})
				.join("");
		}

		function showResultsView(ranked: DemoItem[], animate: boolean) {
			// Freeze the battle height so the panel doesn't jump between views;
			// the results list is vertically centered in the same space.
			resultsEl!.style.minHeight = `${battleEl!.offsetHeight}px`;
			battleEl!.classList.add("hidden");
			resultsEl!.classList.remove("hidden");
			resultsEl!.classList.add("flex");
			labelBattle!.classList.add("hidden");
			labelResults!.classList.remove("hidden");
			barEl!.style.width = "100%";
			counterEl!.innerHTML =
				'<i class="fa-solid fa-check text-emerald-400"></i>';
			renderResultsList(ranked, animate);
		}

		// Reduced motion: render a static finished ranking, no auto-play loop.
		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			showResultsView(items, false);
			return;
		}

		let sorter = makeSorter(items);
		let round = 1;
		let autoTimer = 0;
		let locked = false;

		function setCardContent(card: HTMLElement, item: DemoItem) {
			const photo = card.querySelector<HTMLImageElement>("[data-demo-photo]");
			if (photo && photo.getAttribute("src") !== item.image) {
				photo.src = item.image;
			}
			const name = card.querySelector("[data-demo-name]");
			if (name) name.textContent = item.name;
			card.setAttribute("aria-label", item.name);
		}

		function showPair() {
			const [a, b] = sorter.current();
			setCardContent(cardA!, a);
			setCardContent(cardB!, b);
			counterEl!.textContent = `${Math.min(round, TOTAL)} / ${TOTAL}`;
			barEl!.style.width = `${((round - 1) / TOTAL) * 100}%`;
			locked = false;
			clearTimeout(autoTimer);
			autoTimer = window.setTimeout(
				() => pick(Math.random() < 0.5 ? 0 : 1),
				2200,
			);
		}

		function pick(side: 0 | 1) {
			if (!alive() || locked) return;
			locked = true;
			clearTimeout(autoTimer);
			const winner = cards[side];
			const loser = cards[side === 0 ? 1 : 0];
			winner.classList.add("battle-card-winner");
			loser.classList.add("opacity-30");
			const ranked = sorter.choose(side);
			window.setTimeout(() => {
				if (!alive()) return;
				if (ranked) {
					winner.classList.remove("battle-card-winner");
					loser.classList.remove("opacity-30");
					showResultsView(ranked, true);
					window.setTimeout(() => {
						if (!alive()) return;
						restart();
					}, 5000);
					return;
				}
				// Crossfade to the next duel: soften both cards out (inline
				// styles so they win over the winner/loser classes), swap the
				// content while invisible, then ease back in.
				for (const card of cards) {
					card.style.opacity = "0";
					card.style.transform = "scale(0.96)";
				}
				window.setTimeout(() => {
					if (!alive()) return;
					winner.classList.remove("battle-card-winner");
					loser.classList.remove("opacity-30");
					round++;
					showPair();
					for (const card of cards) {
						card.style.opacity = "";
						card.style.transform = "";
					}
				}, FADE + 30);
			}, GLOW_HOLD);
		}

		function restart() {
			// Reshuffle so every loop plays (and ends) differently.
			const shuffled = items.slice();
			for (let k = shuffled.length - 1; k > 0; k--) {
				const r = Math.floor(Math.random() * (k + 1));
				[shuffled[k], shuffled[r]] = [shuffled[r], shuffled[k]];
			}
			sorter = makeSorter(shuffled);
			round = 1;
			resultsEl!.classList.add("hidden");
			resultsEl!.classList.remove("flex");
			battleEl!.classList.remove("hidden");
			labelResults!.classList.add("hidden");
			labelBattle!.classList.remove("hidden");
			showPair();
		}

		cardA.addEventListener("click", () => pick(0));
		cardB.addEventListener("click", () => pick(1));

		// Don't burn rounds off-screen: start once the panel is visible. The
		// first run keeps the server-rendered pair (no reshuffle), so the
		// hand-off from SSR markup to the script is seamless.
		const io = new IntersectionObserver(
			(entries) => {
				if (entries.some((e) => e.isIntersecting)) {
					io.disconnect();
					if (alive()) showPair();
				}
			},
			{ threshold: 0.3 },
		);
		io.observe(root);
	}

	document.addEventListener("astro:page-load", heroDemoInit);
</script>
