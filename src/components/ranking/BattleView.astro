---
import { defaultLocale, useTranslations } from "../../i18n";

interface Props {
    title: string;
}
const { title } = Astro.props;

const locale = Astro.locals.locale ?? defaultLocale;
const t = useTranslations(locale);
---

<section id="battle-view" class="hidden min-h-[calc(100dvh-4rem)]">
    <!-- Top Bar -->
    <div
        class="sticky top-16 z-30 bg-surface/90 backdrop-blur-xl border-b border-border/50"
    >
        <div
            class="mx-auto max-w-4xl px-4 sm:px-6 py-3 flex flex-col gap-2.5 sm:flex-row sm:items-center sm:justify-between"
        >
            <!-- Progress -->
            <div class="flex items-center gap-3">
                <span
                    id="battle-progress"
                    role="status"
                    aria-live="polite"
                    aria-atomic="true"
                    class="text-sm font-semibold text-text-primary whitespace-nowrap"
                    >{t("ranking.roundProgress", { current: 1, total: 10 })}</span
                >
                <div
                    class="flex-1 sm:flex-none sm:w-32 h-1.5 rounded-full bg-border overflow-hidden"
                >
                    <div
                        id="battle-progress-bar"
                        class="h-full bg-gradient-to-r from-primary to-primary-light rounded-full transition-all duration-500"
                        style="width: 0%"
                    >
                    </div>
                </div>
                <span
                    id="battle-skipped-count"
                    role="status"
                    aria-live="polite"
                    aria-atomic="true"
                    class="hidden whitespace-nowrap text-[11px] font-semibold text-sky-400"
                ></span>
            </div>
            <!-- Actions -->
            <div
                class="flex items-center justify-between gap-1 sm:justify-end sm:gap-2"
            >
                <button
                    id="battle-undo-btn"
                    class="inline-flex items-center justify-center min-h-11 px-3 py-2 rounded-lg text-xs font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
                    disabled
                >
                    <i class="fa-solid fa-rotate-left mr-1"></i>{t("ranking.undo")}
                </button>
                <button
                    id="battle-skip-btn"
                    class="inline-flex items-center justify-center min-h-11 px-3 py-2 rounded-lg text-xs font-medium text-sky-400 hover:text-sky-300 hover:bg-sky-400/10 transition-colors"
                >
                    <i class="fa-solid fa-forward mr-1"></i>{t("ranking.skipForLater")}
                </button>
                <button
                    id="battle-finish-btn"
                    class="inline-flex items-center justify-center min-h-11 px-3 py-2 rounded-lg text-xs font-medium text-amber-400 hover:text-amber-300 hover:bg-amber-400/10 transition-colors"
                >
                    <i class="fa-solid fa-flag-checkered mr-1"></i>{t("ranking.finishEarly")}
                </button>
            </div>
        </div>
    </div>

    <!-- Template title in battle -->
    <div class="text-center mt-6 mb-2 px-4">
        <p
            class="text-xs text-text-muted uppercase tracking-widest font-semibold"
        >
            {t("ranking.rankingLabel")}
        </p>
        <h2
            id="battle-title"
            class="text-lg sm:text-xl font-bold text-text-primary mt-1"
        >
            {title}
        </h2>
    </div>

    <!-- Battle Arena -->
    <div class="mx-auto max-w-4xl px-4 sm:px-6 py-4 sm:py-6 flex flex-col items-center">
        <div
            class="w-full flex flex-col xs:flex-row items-center xs:items-stretch justify-center gap-4 xs:gap-3 sm:gap-6 relative"
        >
            <!-- Card A — role=button div (not <button>) so the remove control
                 can be a real nested button; the controller adds Enter/Space
                 keyboard handling to keep it operable like the button it was. -->
            <div
                id="battle-card-a"
                role="button"
                tabindex="0"
                class="battle-card group flex flex-col w-full xs:w-auto xs:flex-1 xs:min-w-0 sm:flex-none sm:w-72 rounded-2xl bg-surface-elevated border-2 border-border hover:border-primary/60 transition-all duration-200 overflow-hidden cursor-pointer active:scale-[0.97]"
            >
                <div class="relative aspect-square shrink-0 overflow-hidden bg-surface">
                    <img
                        id="battle-img-a"
                        alt=""
                        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    />
                    <!-- Fallback A -->
                    <div
                        id="battle-fallback-a"
                        class="absolute inset-0 flex flex-col items-center justify-center p-3 sm:p-4 text-center bg-gradient-to-br from-surface-elevated to-surface border border-white/5 hidden"
                    >
                        <span
                            id="battle-fallback-text-a"
                            class="font-bold text-text-primary/90 leading-tight text-base xs:text-lg sm:text-2xl line-clamp-3"
                        >
                        </span>
                    </div>
                    <button
                        id="battle-remove-a"
                        type="button"
                        class="absolute top-2 right-2 z-10 w-9 h-9 rounded-lg bg-black/55 backdrop-blur-sm text-white/80 hover:bg-red-500 hover:text-white flex items-center justify-center transition-colors disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer"
                        aria-label={t("ranking.removeModalTitle")}
                    >
                        <i class="fa-solid fa-trash-can text-xs"></i>
                    </button>
                </div>
                <div class="flex-1 flex items-center justify-center p-3 sm:p-4 min-h-[3.5rem]">
                    <p
                        id="battle-name-a"
                        class="text-sm sm:text-base font-bold text-text-primary text-center line-clamp-2"
                    >
                    </p>
                </div>
            </div>

            <!-- VS Badge -->
            <div
                class="shrink-0 z-10 xs:absolute xs:left-1/2 xs:top-1/2 xs:-translate-x-1/2 xs:-translate-y-1/2"
            >
                <div
                    class="w-10 h-10 sm:w-14 sm:h-14 rounded-full bg-surface border-2 border-primary/40 flex items-center justify-center animate-vs-pulse"
                >
                    <span
                        class="text-sm sm:text-lg font-black uppercase text-gradient-gold"
                        >{t("ranking.vs")}</span
                    >
                </div>
            </div>

            <!-- Card B — same role=button pattern as Card A -->
            <div
                id="battle-card-b"
                role="button"
                tabindex="0"
                class="battle-card group flex flex-col w-full xs:w-auto xs:flex-1 xs:min-w-0 sm:flex-none sm:w-72 rounded-2xl bg-surface-elevated border-2 border-border hover:border-primary/60 transition-all duration-200 overflow-hidden cursor-pointer active:scale-[0.97]"
            >
                <div class="relative aspect-square shrink-0 overflow-hidden bg-surface">
                    <img
                        id="battle-img-b"
                        alt=""
                        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    />
                    <!-- Fallback B -->
                    <div
                        id="battle-fallback-b"
                        class="absolute inset-0 flex flex-col items-center justify-center p-3 sm:p-4 text-center bg-gradient-to-br from-surface-elevated to-surface border border-white/5 hidden"
                    >
                        <span
                            id="battle-fallback-text-b"
                            class="font-bold text-text-primary/90 leading-tight text-base xs:text-lg sm:text-2xl line-clamp-3"
                        >
                        </span>
                    </div>
                    <button
                        id="battle-remove-b"
                        type="button"
                        class="absolute top-2 right-2 z-10 w-9 h-9 rounded-lg bg-black/55 backdrop-blur-sm text-white/80 hover:bg-red-500 hover:text-white flex items-center justify-center transition-colors disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer"
                        aria-label={t("ranking.removeModalTitle")}
                    >
                        <i class="fa-solid fa-trash-can text-xs"></i>
                    </button>
                </div>
                <div class="flex-1 flex items-center justify-center p-3 sm:p-4 min-h-[3.5rem]">
                    <p
                        id="battle-name-b"
                        class="text-sm sm:text-base font-bold text-text-primary text-center line-clamp-2"
                    >
                    </p>
                </div>
            </div>
        </div>

        <p
            id="battle-hint"
            class="mt-6 sm:mt-8 text-sm text-text-muted text-center"
        >
            {t("ranking.tapPreferred")}
        </p>
    </div>
</section>
