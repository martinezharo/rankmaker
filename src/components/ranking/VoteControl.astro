---
// Up/down vote control for the current template. Rendered in the battle and
// results views; wired client-side by the ranking script in template/[slug].astro
// (fetches state from /api/templates/vote, casts via POST, syncs all instances).
import { defaultLocale, useTranslations } from "../../i18n";

const locale = Astro.locals.locale ?? defaultLocale;
const t = useTranslations(locale);
---

<div
    class="template-vote inline-flex items-center gap-1 rounded-full border border-border bg-surface-elevated px-1.5 py-1"
>
    <button
        type="button"
        class="vote-up w-7 h-7 rounded-full flex items-center justify-center text-text-muted hover:text-primary hover:bg-primary/10 transition-colors"
        data-value="1"
        aria-label={t("ranking.voteUpAria")}
    >
        <i class="fa-solid fa-arrow-up text-xs"></i>
    </button>
    <span
        class="vote-score min-w-6 text-center text-sm font-bold text-text-primary tabular-nums"
        >0</span
    >
    <button
        type="button"
        class="vote-down w-7 h-7 rounded-full flex items-center justify-center text-text-muted hover:text-red-400 hover:bg-red-400/10 transition-colors"
        data-value="-1"
        aria-label={t("ranking.voteDownAria")}
    >
        <i class="fa-solid fa-arrow-down text-xs"></i>
    </button>
</div>
