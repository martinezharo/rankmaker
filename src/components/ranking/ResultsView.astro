---
import Avatar from "../Avatar.astro";
import type { Creator } from "../../lib/templates";
import { defaultLocale, localizePath, useTranslations } from "../../i18n";

interface Props {
    title: string;
    creator?: Creator;
}
const { title, creator } = Astro.props;

const locale = Astro.locals.locale ?? defaultLocale;
const t = useTranslations(locale);
---

<section id="results-view" class="hidden min-h-[calc(100dvh-4rem)]">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 py-10 pb-28">
        <!-- Results Header -->
        <div class="text-center mb-10">
            <p
                class="text-xs text-text-muted uppercase tracking-widest font-semibold"
            >
                {t("ranking.results")}
            </p>
            <h2
                id="results-title"
                class="text-2xl sm:text-3xl font-bold text-text-primary mt-2"
            >
                {title}
            </h2>
            {
                creator ? (
                    <a
                        href={localizePath(
                            `/u/${encodeURIComponent(creator.username)}`,
                            locale,
                        )}
                        class="group/creator inline-flex items-center justify-center gap-2 mt-3"
                    >
                        <Avatar
                            avatar={creator.avatar}
                            size="sm"
                            verified={creator.isVerified}
                        />
                        <span class="text-sm text-text-secondary group-hover/creator:text-text-primary transition-colors">
                            {t("ranking.by")}{" "}
                            <span class="font-semibold">
                                @{creator.username}
                            </span>
                        </span>
                    </a>
                ) : (
                    <p class="text-sm text-text-secondary mt-2">
                        <br />
                    </p>
                )
            }
        </div>

        <!-- Podium -->
        <div
            id="results-podium"
            class="flex items-end justify-center gap-3 sm:gap-5 mb-12 min-h-[280px]"
        >
            <!-- Filled dynamically -->
        </div>

        <!-- Full Ranking -->
        <div class="mb-10">
            <div class="flex items-center gap-3 mb-4">
                <h3 class="text-lg font-bold text-text-primary">
                    {t("ranking.fullRanking")}
                </h3>
                <div class="flex-1 h-px bg-border/50"></div>
            </div>
            <div id="results-list" class="space-y-2">
                <!-- Filled dynamically -->
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <button
                id="action-history"
                class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-surface-elevated border border-border hover:border-primary/40 text-sm font-medium text-text-secondary hover:text-text-primary transition-all"
            >
                <i class="fa-solid fa-clock-rotate-left text-xs text-primary/70"
                ></i>{t("ranking.battleHistory")}
            </button>
            <button
                id="action-rank-again"
                class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-surface-elevated border border-border hover:border-primary/40 text-sm font-medium text-text-secondary hover:text-text-primary transition-all"
            >
                <i class="fa-solid fa-rotate text-xs text-primary/70"></i>{
                    t("ranking.rankAgain")
                }
            </button>
            <button
                id="action-share-template"
                class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-surface-elevated border border-border hover:border-primary/40 text-sm font-medium text-text-secondary hover:text-text-primary transition-all"
            >
                <i class="fa-solid fa-share-nodes text-xs text-primary/70"
                ></i>{t("ranking.shareTemplate")}
            </button>
            <button
                id="action-download-image"
                class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-surface-elevated border border-border hover:border-primary/40 text-sm font-medium text-text-secondary hover:text-text-primary transition-all"
            >
                <i class="fa-solid fa-image text-xs text-primary/70"
                ></i>{t("ranking.downloadImage")}
            </button>
            <button
                id="action-share-x"
                class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-surface-elevated border border-border hover:border-primary/40 text-sm font-medium text-text-secondary hover:text-text-primary transition-all"
            >
                <i class="fa-brands fa-x-twitter text-xs text-primary/70"
                ></i>{t("ranking.shareOnX")}
            </button>
            <button
                id="action-reorder"
                class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-surface-elevated border border-border hover:border-primary/40 text-sm font-medium text-text-secondary hover:text-text-primary transition-all"
            >
                <i class="fa-solid fa-arrows-up-down text-xs text-primary/70"
                ></i><span id="action-reorder-label">{t("ranking.reorderManually")}</span>
            </button>
        </div>
    </div>
</section>
