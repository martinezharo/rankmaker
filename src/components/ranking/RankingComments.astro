---
// RankingComments.astro — threaded, votable comments for a template page.
// Sits just above the "You might also like" row (outside every view container)
// so it's visible at the foot of all three ranking views. The thread is loaded
// client-side because template pages are publicly cached and the comments need
// the current session (auth, own-comment, per-user vote).
interface Props {
	slug: string;
}
const { slug } = Astro.props;
---

<section
	data-comments
	data-slug={slug}
	class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-10 border-t border-border/50"
>
	<!-- Header -->
	<div class="flex items-center gap-3 mb-6">
		<div
			class="w-9 h-9 rounded-xl bg-primary/10 flex items-center justify-center shrink-0"
		>
			<i class="fa-solid fa-comments text-primary text-sm"></i>
		</div>
		<h2 class="text-lg font-bold text-text-primary tracking-tight">
			Comments
			<span data-comments-count class="text-text-muted font-semibold"></span>
		</h2>
		<div class="flex-1 h-px bg-border/50 ml-2"></div>
	</div>

	<!-- Composer (top-level) — filled in by the client once it knows the session -->
	<div data-composer-slot class="mb-8"></div>

	<!-- Thread -->
	<div data-comments-list class="space-y-1">
		<div
			data-comments-loading
			class="py-8 text-center text-sm text-text-muted"
		>
			<i class="fa-solid fa-spinner btn-spinner mr-2"></i>Loading comments…
		</div>
	</div>

	<!-- Full-ranking modal (reused for every "View full ranking") -->
	<div
		id="comment-ranking-modal"
		class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4"
		role="dialog"
		aria-modal="true"
		aria-labelledby="comment-ranking-title"
	>
		<div
			data-modal-backdrop
			class="absolute inset-0 bg-black/70 backdrop-blur-sm animate-modal-bg"
		>
		</div>
		<div
			class="relative w-full max-w-md rounded-2xl bg-surface-elevated border border-border shadow-2xl animate-modal-content flex flex-col max-h-[85vh]"
		>
			<div class="flex items-center gap-3 p-5 border-b border-border/60">
				<div data-modal-avatar class="shrink-0"></div>
				<h3
					id="comment-ranking-title"
					class="text-base font-bold text-text-primary truncate flex-1"
				>
				</h3>
				<button
					type="button"
					data-modal-close
					aria-label="Close"
					class="shrink-0 w-8 h-8 rounded-lg bg-surface border border-border flex items-center justify-center text-text-muted hover:text-text-primary hover:border-border-hover transition-colors"
				>
					<i class="fa-solid fa-xmark text-sm"></i>
				</button>
			</div>
			<ol data-modal-list class="space-y-1.5 p-5 overflow-y-auto"></ol>
		</div>
	</div>
</section>

<script>
	import { avatarHtml } from "../../lib/avatars";
	import { openModal, closeModal } from "../../scripts/modal-a11y";
	import {
		MAX_BODY_LEN,
		type CommentNode,
		type RankedItem,
	} from "../../scripts/comments";

	type Author = { username: string; avatar: string; isVerified: boolean };
	type ThreadResponse = {
		currentUser: Author | null;
		comments: CommentNode[];
	};

	let state: ThreadResponse | null = null;

	// ── small helpers ────────────────────────────────────────────────
	function esc(s: string): string {
		return s
			.replace(/&/g, "&amp;")
			.replace(/</g, "&lt;")
			.replace(/>/g, "&gt;")
			.replace(/"/g, "&quot;");
	}

	function relTime(iso: string): string {
		// Stored as UTC "YYYY-MM-DD HH:MM:SS" (datetime('now')) — make it explicit.
		const ms = Date.parse(iso.includes("T") ? iso : iso.replace(" ", "T") + "Z");
		if (isNaN(ms)) return "";
		const s = Math.max(0, Math.round((Date.now() - ms) / 1000));
		if (s < 60) return "just now";
		const m = Math.floor(s / 60);
		if (m < 60) return `${m}m ago`;
		const h = Math.floor(m / 60);
		if (h < 24) return `${h}h ago`;
		const d = Math.floor(h / 24);
		if (d < 30) return `${d}d ago`;
		const mo = Math.floor(d / 30);
		if (mo < 12) return `${mo}mo ago`;
		return `${Math.floor(mo / 12)}y ago`;
	}

	const posLabel = (i: number) => `${i + 1}`;
	const posCls = (i: number) =>
		i === 0
			? "medal-gold text-base font-black"
			: i === 1
				? "medal-silver text-base font-black"
				: i === 2
					? "medal-bronze text-base font-black"
					: "bg-border/60 text-text-muted text-sm font-black";

	// ── markup builders ──────────────────────────────────────────────
	function composerHtml(parentId: string | null): string {
		const reply = parentId !== null;
		return `
			<form data-comment-form data-parent="${parentId ?? ""}" class="rounded-2xl bg-surface-elevated border border-border p-4 space-y-3">
				<textarea data-comment-input rows="${reply ? 2 : 3}" maxlength="${MAX_BODY_LEN}"
					placeholder="${reply ? "Write a reply…" : "Share what you think…"}"
					class="w-full px-4 py-3 rounded-xl bg-surface border border-border text-sm text-text-primary placeholder:text-text-muted/50 focus:outline-none focus:border-primary/60 focus:ring-1 focus:ring-primary/30 transition-all resize-none field-sizing-content"></textarea>
				<div class="flex items-center gap-2 justify-end">
					${reply ? `<button type="button" data-reply-cancel class="px-4 py-2 rounded-xl text-sm font-medium text-text-secondary border border-border hover:border-border-hover transition-all">Cancel</button>` : ""}
					<button type="submit" data-comment-submit class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold text-zinc-950 bg-gradient-gold hover:opacity-90 transition-all">
						${reply ? "Reply" : "Comment"}
					</button>
				</div>
				<p data-comment-error class="hidden text-xs text-red-400"></p>
			</form>`;
	}

	function loginPromptHtml(): string {
		const next = encodeURIComponent(location.pathname);
		return `
			<div class="rounded-2xl bg-surface-elevated border border-border p-5 flex items-center gap-4 flex-wrap">
				<div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
					<i class="fa-solid fa-comment-dots text-primary"></i>
				</div>
				<p class="text-sm text-text-secondary flex-1 min-w-[12rem]">Join the conversation — log in to comment and vote.</p>
				<a href="/api/auth/login?next=${next}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold text-zinc-950 bg-gradient-gold hover:opacity-90 transition-all">
					<i class="fa-brands fa-github text-xs"></i> Log in
				</a>
			</div>`;
	}

	function topPickHtml(c: CommentNode): string {
		if (!c.topPick) return "";
		const img = c.topPick.image
			? `<span class="w-6 h-6 rounded-md overflow-hidden bg-surface border border-border shrink-0"><img src="${esc(c.topPick.image)}" alt="" class="w-full h-full object-cover" /></span>`
			: "";
		return `
			<button type="button" data-open-ranking data-id="${c.id}"
				class="inline-flex items-center gap-2 mt-2 mb-1 pl-2 pr-3 py-1 rounded-full bg-primary/5 border border-primary/20 hover:border-primary/50 hover:bg-primary/10 transition-all group">
				<i class="fa-solid fa-crown text-xs text-amber-400"></i>
				${img}
				<span class="text-xs font-medium text-text-secondary group-hover:text-text-primary transition-colors">
					${esc(c.topPick.name)}
				</span>
				<span class="text-[11px] text-primary/80 font-semibold">· View ranking</span>
			</button>`;
	}

	function voteHtml(c: CommentNode): string {
		const up = c.myVote === 1;
		const down = c.myVote === -1;
		return `
			<div class="flex flex-col items-center gap-0.5 shrink-0">
				<button type="button" data-vote data-dir="1" aria-label="Upvote"
					class="vote-btn w-7 h-7 rounded-lg flex items-center justify-center transition-colors hover:bg-surface-hover ${up ? "text-primary" : "text-text-muted hover:text-text-secondary"}">
					<i class="fa-solid fa-caret-up text-lg"></i>
				</button>
				<span data-score class="text-xs font-bold tabular-nums ${up ? "text-primary" : down ? "text-blue-400" : "text-text-secondary"}">${c.score}</span>
				<button type="button" data-vote data-dir="-1" aria-label="Downvote"
					class="vote-btn w-7 h-7 rounded-lg flex items-center justify-center transition-colors hover:bg-surface-hover ${down ? "text-blue-400" : "text-text-muted hover:text-text-secondary"}">
					<i class="fa-solid fa-caret-down text-lg"></i>
				</button>
			</div>`;
	}

	function commentHtml(c: CommentNode): string {
		const indent =
			c.depth > 0
				? ` style="margin-left:${c.depth * 1.25}rem"`
				: "";
		const indentCls = c.depth > 0 ? "border-l border-border/70 pl-3" : "";

		if (c.isDeleted) {
			return `
				<article data-comment data-id="${c.id}" data-depth="${c.depth}"${indent}>
					<div class="${indentCls} py-3 text-sm text-text-muted italic">[comment deleted]</div>
				</article>`;
		}

		const a = c.author as Author;
		const avatar = avatarHtml(a.avatar, 28, a.isVerified);
		const del = c.mine
			? `<button type="button" data-delete class="hover:text-red-400 transition-colors">Delete</button>`
			: "";

		return `
			<article data-comment data-id="${c.id}" data-depth="${c.depth}"
				data-up="${c.up}" data-down="${c.down}" data-myvote="${c.myVote}"${indent}>
				<div class="${indentCls} flex gap-3 py-3">
					${voteHtml(c)}
					<div class="flex-1 min-w-0">
						<div class="flex items-center gap-2 flex-wrap">
							<span class="cursor-pointer" data-profile-href="/u/${encodeURIComponent(a.username)}" title="View @${esc(a.username)}'s profile">${avatar}</span>
							<a href="/u/${encodeURIComponent(a.username)}" class="text-sm font-semibold text-text-primary hover:text-primary transition-colors">@${esc(a.username)}</a>
							<span class="text-xs text-text-muted">· ${relTime(c.createdAt)}</span>
						</div>
						${topPickHtml(c)}
						<p class="text-sm text-text-primary/90 mt-1 whitespace-pre-wrap break-words">${esc(c.body)}</p>
						<div class="flex items-center gap-4 mt-2 text-xs font-medium text-text-muted">
							<button type="button" data-reply class="inline-flex items-center gap-1.5 hover:text-text-primary transition-colors">
								<i class="fa-solid fa-reply text-[10px]"></i> Reply
							</button>
							${del}
						</div>
						<div data-reply-slot class="mt-3 hidden"></div>
					</div>
				</div>
			</article>`;
	}

	// ── rendering ────────────────────────────────────────────────────
	function render(section: HTMLElement): void {
		if (!state) return;
		const composerSlot =
			section.querySelector<HTMLElement>("[data-composer-slot]");
		if (composerSlot) {
			composerSlot.innerHTML = state.currentUser
				? composerHtml(null)
				: loginPromptHtml();
		}

		const countEl = section.querySelector<HTMLElement>("[data-comments-count]");
		const visible = state.comments.filter((c) => !c.isDeleted).length;
		if (countEl) countEl.textContent = visible ? `(${visible})` : "";

		const list = section.querySelector<HTMLElement>("[data-comments-list]");
		if (!list) return;
		if (state.comments.length === 0) {
			list.innerHTML = `<p class="py-8 text-center text-sm text-text-muted">No comments yet. Be the first to share your take.</p>`;
			return;
		}
		list.innerHTML = state.comments.map(commentHtml).join("");
	}

	async function load(section: HTMLElement): Promise<void> {
		const slug = section.dataset.slug ?? "";
		try {
			const res = await fetch(
				`/api/comments?slug=${encodeURIComponent(slug)}`
			);
			if (!res.ok) throw new Error(String(res.status));
			state = (await res.json()) as ThreadResponse;
			render(section);
		} catch {
			const list =
				section.querySelector<HTMLElement>("[data-comments-list]");
			if (list)
				list.innerHTML = `<p class="py-8 text-center text-sm text-text-muted">Couldn't load comments.</p>`;
		}
	}

	// ── voting ───────────────────────────────────────────────────────
	function applyVoteUi(
		article: HTMLElement,
		up: number,
		down: number,
		myVote: number
	): void {
		article.dataset.up = String(up);
		article.dataset.down = String(down);
		article.dataset.myvote = String(myVote);
		const score = article.querySelector<HTMLElement>("[data-score]");
		if (score) {
			score.textContent = String(up - down);
			score.className = `text-xs font-bold tabular-nums ${myVote === 1 ? "text-primary" : myVote === -1 ? "text-blue-400" : "text-text-secondary"}`;
		}
		const upBtn = article.querySelector<HTMLElement>('[data-vote][data-dir="1"]');
		const downBtn = article.querySelector<HTMLElement>('[data-vote][data-dir="-1"]');
		if (upBtn)
			upBtn.className = `vote-btn w-7 h-7 rounded-lg flex items-center justify-center transition-colors hover:bg-surface-hover ${myVote === 1 ? "text-primary" : "text-text-muted hover:text-text-secondary"}`;
		if (downBtn)
			downBtn.className = `vote-btn w-7 h-7 rounded-lg flex items-center justify-center transition-colors hover:bg-surface-hover ${myVote === -1 ? "text-blue-400" : "text-text-muted hover:text-text-secondary"}`;
	}

	async function vote(article: HTMLElement, dir: number): Promise<void> {
		if (!state?.currentUser) {
			location.href = `/api/auth/login?next=${encodeURIComponent(location.pathname)}`;
			return;
		}
		const id = article.dataset.id ?? "";
		const prevUp = Number(article.dataset.up ?? 0);
		const prevDown = Number(article.dataset.down ?? 0);
		const prevMine = Number(article.dataset.myvote ?? 0);
		const next = prevMine === dir ? 0 : dir;

		// Optimistic update.
		const optUp = prevUp - (prevMine === 1 ? 1 : 0) + (next === 1 ? 1 : 0);
		const optDown =
			prevDown - (prevMine === -1 ? 1 : 0) + (next === -1 ? 1 : 0);
		applyVoteUi(article, optUp, optDown, next);

		try {
			const res = await fetch(`/api/comments/${id}/vote`, {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ value: next }),
			});
			if (!res.ok) throw new Error(String(res.status));
			const data = (await res.json()) as {
				up: number;
				down: number;
				myVote: number;
			};
			applyVoteUi(article, data.up, data.down, data.myVote);
		} catch {
			applyVoteUi(article, prevUp, prevDown, prevMine); // revert
		}
	}

	// ── modal ────────────────────────────────────────────────────────
	function openRanking(section: HTMLElement, id: string): void {
		const c = state?.comments.find((x) => x.id === id);
		if (!c || !c.result) return;
		const modal = section.querySelector<HTMLElement>(
			"#comment-ranking-modal"
		);
		if (!modal) return;
		const a = c.author as Author;
		const title = modal.querySelector<HTMLElement>("#comment-ranking-title");
		if (title) title.textContent = `@${a.username}'s ranking`;
		const av = modal.querySelector<HTMLElement>("[data-modal-avatar]");
		if (av) av.innerHTML = avatarHtml(a.avatar, 32, a.isVerified);
		const ol = modal.querySelector<HTMLElement>("[data-modal-list]");
		if (ol)
			ol.innerHTML = c.result
				.map(
					(item: RankedItem, i: number) => `
				<li class="flex items-center gap-3 p-2 rounded-xl ${i === 0 ? "bg-amber-400/[0.06] border border-amber-400/15" : "hover:bg-surface-hover"}">
					<span class="flex items-center justify-center w-9 h-9 rounded-lg shrink-0 ${posCls(i)}">${posLabel(i)}</span>
					<div class="w-10 h-10 rounded-lg overflow-hidden bg-surface shrink-0 border border-border">
						${item.image ? `<img src="${esc(item.image)}" alt="" class="w-full h-full object-cover" />` : ""}
					</div>
					<span class="text-sm font-medium text-text-primary truncate flex-1">${esc(item.name)}</span>
				</li>`
				)
				.join("");
		openModal(modal);
	}

	// ── posting ──────────────────────────────────────────────────────
	async function submitForm(
		section: HTMLElement,
		form: HTMLFormElement
	): Promise<void> {
		const input = form.querySelector<HTMLTextAreaElement>(
			"[data-comment-input]"
		);
		const btn = form.querySelector<HTMLButtonElement>("[data-comment-submit]");
		const errEl = form.querySelector<HTMLElement>("[data-comment-error]");
		if (!input || !btn) return;

		const text = input.value.trim();
		if (!text) {
			input.focus();
			return;
		}
		const parentId = form.dataset.parent || null;

		const label = btn.innerHTML;
		btn.disabled = true;
		btn.innerHTML = `<i class="fa-solid fa-spinner btn-spinner"></i>`;
		if (errEl) errEl.classList.add("hidden");

		try {
			const res = await fetch("/api/comments", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({
					slug: section.dataset.slug ?? "",
					body: text,
					parentId,
				}),
			});
			const data = (await res.json()) as { ok?: boolean; error?: string };
			if (res.ok && data.ok) {
				input.value = "";
				await load(section); // re-fetch so ordering/threading stay correct
				return;
			}
			if (errEl) {
				errEl.textContent = data.error || "Something went wrong.";
				errEl.classList.remove("hidden");
			}
		} catch {
			if (errEl) {
				errEl.textContent = "Network error. Try again.";
				errEl.classList.remove("hidden");
			}
		}
		btn.disabled = false;
		btn.innerHTML = label;
	}

	async function del(section: HTMLElement, article: HTMLElement): Promise<void> {
		const id = article.dataset.id ?? "";
		try {
			const res = await fetch(`/api/comments/${id}`, { method: "DELETE" });
			if (res.ok) await load(section);
		} catch {
			/* ignore — leave the comment as-is on failure */
		}
	}

	// ── event wiring (delegated) ─────────────────────────────────────
	function onClick(section: HTMLElement, ev: MouseEvent): void {
		const t = ev.target as HTMLElement;

		const voteBtn = t.closest<HTMLElement>("[data-vote]");
		if (voteBtn) {
			const article = voteBtn.closest<HTMLElement>("[data-comment]");
			if (article) void vote(article, Number(voteBtn.dataset.dir));
			return;
		}

		const openBtn = t.closest<HTMLElement>("[data-open-ranking]");
		if (openBtn) {
			openRanking(section, openBtn.dataset.id ?? "");
			return;
		}

		const replyBtn = t.closest<HTMLElement>("[data-reply]");
		if (replyBtn) {
			const article = replyBtn.closest<HTMLElement>("[data-comment]");
			const slot = article?.querySelector<HTMLElement>("[data-reply-slot]");
			if (slot && article) {
				if (slot.classList.contains("hidden")) {
					slot.innerHTML = composerHtml(article.dataset.id ?? "");
					slot.classList.remove("hidden");
					slot.querySelector<HTMLTextAreaElement>("[data-comment-input]")?.focus();
				} else {
					slot.classList.add("hidden");
					slot.innerHTML = "";
				}
			}
			return;
		}

		const cancelBtn = t.closest<HTMLElement>("[data-reply-cancel]");
		if (cancelBtn) {
			const slot = cancelBtn.closest<HTMLElement>("[data-reply-slot]");
			if (slot) {
				slot.classList.add("hidden");
				slot.innerHTML = "";
			}
			return;
		}

		const delBtn = t.closest<HTMLElement>("[data-delete]");
		if (delBtn) {
			const article = delBtn.closest<HTMLElement>("[data-comment]");
			if (article) void del(section, article);
			return;
		}

		const modalClose = t.closest<HTMLElement>(
			"[data-modal-close],[data-modal-backdrop]"
		);
		if (modalClose) {
			const modal = section.querySelector<HTMLElement>(
				"#comment-ranking-modal"
			);
			if (modal) closeModal(modal);
		}
	}

	function onSubmit(section: HTMLElement, ev: Event): void {
		const form = (ev.target as HTMLElement)?.closest<HTMLFormElement>(
			"[data-comment-form]"
		);
		if (!form) return;
		ev.preventDefault();
		void submitForm(section, form);
	}

	// Refresh the thread when the user finishes ranking on this page, so their
	// freshly-saved ranking badge appears without a reload. Stable reference so
	// remove+add keeps a single registration across page-loads.
	function onRankingSaved(ev: Event): void {
		const section = document.querySelector<HTMLElement>("[data-comments]");
		if (!section || !state?.currentUser) return;
		const detail = (ev as CustomEvent<{ slug?: string }>).detail;
		if (detail?.slug && detail.slug !== section.dataset.slug) return;
		void load(section);
	}

	function init(): void {
		const section = document.querySelector<HTMLElement>("[data-comments]");
		if (!section) return;
		state = null;
		void load(section);
		const click = (ev: MouseEvent) => onClick(section, ev);
		const submit = (ev: Event) => onSubmit(section, ev);
		section.addEventListener("click", click);
		section.addEventListener("submit", submit);
		document.removeEventListener("rankmaker:ranking-saved", onRankingSaved);
		document.addEventListener("rankmaker:ranking-saved", onRankingSaved);
	}

	document.addEventListener("astro:page-load", init);
