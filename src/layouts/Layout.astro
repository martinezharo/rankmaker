---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { ViewTransitions } from "astro:transitions";
import {
    CONTENT_LOCALIZED,
    defaultLocale,
    localizePath,
    locales,
    unlocalizePath,
    useTranslations,
} from "../i18n";

interface Props {
    title: string;
    description?: string;
    image?: string | null;
    /** Ask search engines not to index this page (private/unlisted templates). */
    noindex?: boolean;
    /** Preload this image as the LCP candidate (e.g. the template cover). */
    preloadImage?: string | null;
}

const locale = Astro.locals.locale ?? defaultLocale;
const t = useTranslations(locale);

const {
    title,
    description = t("seo.defaultDescription"),
    image,
    noindex = false,
    preloadImage,
} = Astro.props;

const SITE_URL = "https://rankmaker.net";
// After the i18n middleware rewrite, Astro.url.pathname is the canonical
// (unprefixed) path. Build per-locale URLs from it for canonical + hreflang.
const basePath = unlocalizePath(Astro.url.pathname);
// While content isn't localized (CONTENT_LOCALIZED=false), the locale variants
// are near-duplicates of the English page, so they canonicalize to English and
// emit no hreflang — consolidating the duplicates onto one URL. Flip the flag
// (see src/i18n/config.ts) to restore self-canonical + hreflang per locale.
const canonicalURL = new URL(
    localizePath(basePath, CONTENT_LOCALIZED ? locale : defaultLocale),
    SITE_URL,
);
const alternates = locales.map((loc) => ({
    hreflang: loc,
    href: new URL(localizePath(basePath, loc), SITE_URL).toString(),
}));
// og:image must be an absolute URL
const ogImage = image
    ? new URL(image, SITE_URL).toString()
    : `${SITE_URL}/favicon.webp`;
---

<!doctype html>
<html lang={locale}>
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/webp" href="/favicon.webp" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        {noindex && <meta name="robots" content="noindex, nofollow" />}
        <link rel="canonical" href={canonicalURL} />

        <!-- hreflang alternates: one per locale + x-default (English).
             Suppressed while CONTENT_LOCALIZED is false — the locale variants
             share the same English content, so advertising them as language
             alternates would be misleading and spread crawl budget. -->
        {
            CONTENT_LOCALIZED &&
                !noindex &&
                alternates.map((alt) => (
                    <link
                        rel="alternate"
                        hreflang={alt.hreflang}
                        href={alt.href}
                    />
                ))
        }
        {
            CONTENT_LOCALIZED && !noindex && (
                <link
                    rel="alternate"
                    hreflang="x-default"
                    href={new URL(localizePath(basePath, defaultLocale), SITE_URL).toString()}
                />
            )
        }

        <!-- Open Graph / Twitter -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:site_name" content="RANKMAKER" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />

        <!-- Cover images are served from jsDelivr — open the connection early. -->
        <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
        {
            preloadImage && (
                <link
                    rel="preload"
                    as="image"
                    href={preloadImage}
                    fetchpriority="high"
                />
            )
        }

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap"
            rel="stylesheet"
        />

        <!-- Font Awesome -->
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
            integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
            crossorigin="anonymous"
            referrerpolicy="no-referrer"
        />

        <!-- Google Analytics is loaded only after cookie consent — see
             CookieConsent.astro (gtag is injected on Accept / stored consent). -->

        <!-- Cloudflare Web Analytics — installed manually (not auto-injected):
             Cloudflare skips edge auto-injection when the response carries a CSP
             (see src/middleware.ts), so the beacon is added here and the beacon
             host is allow-listed in the CSP. It's cookieless, so it needs no
             consent gate and loads for every visitor. -->
        <script
            is:inline
            defer
            src="https://static.cloudflareinsights.com/beacon.min.js"
            data-cf-beacon='{"token": "7cafed3cd4f74c66b7f9e9ddb934aaed"}'
        ></script>

        <!-- View Transitions -->
        <ViewTransitions />
    </head>
    <body class="flex flex-col min-h-dvh">
        <!-- Navigation progress bar (feedback for slow connections during
             ClientRouter page fetches) — persisted across swaps. -->
        <div id="nav-progress" transition:persist aria-hidden="true"></div>

        <!-- Background noise layer -->
        <div class="fixed inset-0 -z-20 bg-surface"></div>
        <div
            class="fixed inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,rgba(132,0,255,0.08),transparent_60%)]"
        >
        </div>

        <!-- Header/Footer carry transition:persist on their root elements
             (the directive is ignored when placed on component tags). -->
        <Header />
        <main class="flex-1">
            <slot />
        </main>
        <Footer />
        <CookieConsent />

        <!-- Navigation progress bar: grows toward 90% while the next page is
             fetched, then snaps to 100% and fades out once it loads. Gives slow
             connections immediate feedback that a click registered. -->
        <script>
            (function () {
                if ((window as any).__rmNavProgress) return;
                (window as any).__rmNavProgress = true;

                const bar = () =>
                    document.getElementById(
                        "nav-progress",
                    ) as HTMLElement | null;
                let timer: ReturnType<typeof setInterval> | undefined;
                let width = 0;

                function start() {
                    const el = bar();
                    if (!el) return;
                    clearInterval(timer);
                    width = 8;
                    el.classList.remove("is-done");
                    el.classList.add("is-loading");
                    el.style.width = width + "%";
                    // Ease toward 90% so the bar keeps moving on slow fetches
                    // without ever pretending to be finished.
                    timer = setInterval(() => {
                        width += (90 - width) * 0.15;
                        el.style.width = width + "%";
                    }, 200);
                }

                function done() {
                    const el = bar();
                    if (!el) return;
                    clearInterval(timer);
                    el.classList.remove("is-loading");
                    el.classList.add("is-done");
                    el.style.width = "100%";
                    setTimeout(() => {
                        if (el.classList.contains("is-done"))
                            el.style.width = "0";
                    }, 500);
                }

                document.addEventListener("astro:before-preparation", start);
                document.addEventListener("astro:page-load", done);
                // A failed/aborted navigation still settles the bar.
                document.addEventListener("astro:after-swap", done);

                // Links with data-astro-reload (e.g. "Create Ranking") do a
                // full browser navigation, so the ClientRouter events above
                // never fire. Catch the click and show the bar until the
                // browser swaps the document. pageshow handles bfcache returns.
                document.addEventListener("click", (e) => {
                    const a = (e.target as HTMLElement | null)?.closest?.(
                        "a[data-astro-reload]",
                    ) as HTMLAnchorElement | null;
                    if (!a || a.target === "_blank") return;
                    if (e.defaultPrevented || e.button !== 0) return;
                    if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
                    start();
                });
                window.addEventListener("pageshow", done);
            })();
        </script>

        <!-- Replace the static "N ranked" mockup with real counts from D1 -->
        <script>
            import { clientT } from "../i18n/client";

            type Counts = Record<string, number>;

            // Fetch the slug -> count map once per page session.
            // On failure resolve to null (don't clobber server-rendered
            // numbers) and reset the cache so the next navigation retries.
            let countsPromise: Promise<Counts | null> | null = null;
            function getCounts(): Promise<Counts | null> {
                if (!countsPromise) {
                    countsPromise = fetch("/api/counts")
                        .then((r) => {
                            if (!r.ok) throw new Error("counts " + r.status);
                            return r.json();
                        })
                        .then((data) => (data?.counts as Counts) || {})
                        .catch(() => {
                            countsPromise = null;
                            return null;
                        });
                }
                return countsPromise;
            }

            // Apply the cached counts to every [data-count-slug] within `root`.
            function applyRankCounts(root: ParentNode = document) {
                const counts = (window as any).__rmCounts as Counts | undefined;
                if (!counts) return;
                const t = clientT();
                root.querySelectorAll<HTMLElement>(
                    "[data-count-slug]",
                ).forEach((el) => {
                    const slug = el.dataset.countSlug;
                    if (!slug) return;
                    const n = counts[slug] || 0;
                    el.textContent = t("card.ranked", {
                        n: n.toLocaleString(),
                    });
                });
            }

            // Exposed so client-rendered grids (e.g. search) can re-apply counts.
            (window as any).__applyRankCounts = applyRankCounts;

            function refreshCounts() {
                getCounts().then((counts) => {
                    // Fetch failed — keep the server-rendered numbers as-is.
                    if (!counts) return;
                    (window as any).__rmCounts = counts;
                    applyRankCounts(document);
                    // Let client-rendered views (e.g. search) re-sort by counts.
                    document.dispatchEvent(new CustomEvent("rm:counts"));
                });
            }

            document.addEventListener("astro:page-load", refreshCounts);

            // Creator "links" inside template cards: the card is already an
            // <a>, so creators are spans with [data-profile-href] handled by
            // one delegated listener (covers server- and client-rendered cards).
            if (!(window as any).__rmProfileNav) {
                (window as any).__rmProfileNav = true;
                document.addEventListener("click", (e) => {
                    const target = e.target as HTMLElement | null;
                    const el = target?.closest?.(
                        "[data-profile-href]",
                    ) as HTMLElement | null;
                    if (!el) return;
                    e.preventDefault();
                    e.stopPropagation();
                    const href = el.getAttribute("data-profile-href");
                    if (href) window.location.href = href;
                });
            }
        </script>
    </body>
</html>
